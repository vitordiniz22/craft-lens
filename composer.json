{
  "name": "vitordiniz22/craft-lens",
  "description": "AI-powered image analysis, tagging, and search for Craft CMS assets. Automatically generate alt text, extract colors, detect faces and content issues, find duplicates, and organize your media library with 20+ smart filters.",
  "keywords": [
    "craftcms",
    "craft-plugin",
    "image-analysis",
    "alt-text",
    "accessibility",
    "ai",
    "tagging",
    "asset-management",
    "seo",
    "duplicate-detection",
    "ocr"
  ],
  "type": "craft-plugin",
  "license": "proprietary",
  "authors": [
    {
      "name": "Vitor Diniz",
      "email": "vitordiniz22@gmail.com",
      "homepage": "https://github.com/vitordiniz22"
    }
  ],
  "homepage": "https://github.com/vitordiniz22/craft-lens/wiki",
  "support": {
    "email": "vitordiniz22@gmail.com",
    "issues": "https://github.com/vitordiniz22/craft-lens/issues",
    "source": "https://github.com/vitordiniz22/craft-lens",
    "docs": "https://github.com/vitordiniz22/craft-lens/wiki",
    "rss": "https://github.com/vitordiniz22/craft-lens/releases.atom"
  },
  "require": {
    "php": ">=8.2",
    "craftcms/cms": "^5.0.0",
    "wamania/php-stemmer": "4.0"
  },
  "require-dev": {
    "codeception/codeception": "^5.2.0",
    "codeception/module-asserts": "^3.0.0",
    "codeception/module-datafactory": "^3.0.0",
    "codeception/module-phpbrowser": "^3.0.0",
    "codeception/module-rest": "^3.3.2",
    "codeception/module-yii2": "^1.1.9",
    "craftcms/ecs": "dev-main",
    "craftcms/phpstan": "dev-main",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload-dev": {
    "psr-4": {
      "vitordiniz22\\craftlenstests\\": "tests/"
    }
  },
  "autoload": {
    "psr-4": {
      "vitordiniz22\\craftlens\\": "src/"
    }
  },
  "extra": {
    "handle": "lens",
    "name": "Lens",
    "class": "vitordiniz22\\craftlens\\Plugin",
    "developer": "Vitor Diniz",
    "developerUrl": "https://github.com/vitordiniz22",
    "documentationUrl": "https://github.com/vitordiniz22/craft-lens/wiki",
    "changelogUrl": "https://raw.githubusercontent.com/vitordiniz22/craft-lens/main/CHANGELOG.md",
    "editions": [
      {
        "name": "Lite",
        "handle": "lite"
      },
      {
        "name": "Pro",
        "handle": "pro",
        "features": [
          "Find any asset instantly with smart search and advanced filters",
          "Review Queue to track and verify AI results across your library",
          "Analyze your entire media library in one click",
          "Detect duplicate and near-identical images automatically",
          "AI-powered semantic search in the native asset picker",
          "Full dashboard with usage stats, insights, and attention alerts",
          "Custom condition rules for stock photos and text-in-image filtering",
          "Edit AI-generated tags, colors, and extracted text per asset"
        ]
      }
    ]
  },
  "scripts": {
    "check-cs": "ecs check --ansi",
    "fix-cs": "ecs check --ansi --fix",
    "phpstan": "phpstan --memory-limit=1G",
    "test": "php vendor/bin/codecept run --ansi",
    "test-unit": "php vendor/bin/codecept run unit --ansi",
    "test-integration": "php vendor/bin/codecept run integration --ansi",
    "test-functional": "php vendor/bin/codecept run functional --ansi",
    "test-coverage": "php vendor/bin/codecept run --coverage --coverage-html --ansi",
    "test-setup": "bash tests/setup.sh"
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.2"
    },
    "allow-plugins": {
      "yiisoft/yii2-composer": true,
      "craftcms/plugin-installer": true
    }
  }
}
