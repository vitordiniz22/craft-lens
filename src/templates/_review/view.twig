{% extends '_layouts/cp' %}

{% set title = 'Review: ' ~ analysis.filename %}
{% set selectedSubnavItem = 'review' %}

{% block content %}
    {% include 'lens/_review/_toolbar' with {
        currentMode: 'focus',
        totalCount: totalCount,
        currentIndex: currentIndex
    } %}

    <form method="post" action="" accept-charset="UTF-8" data-lens-target="review-form">
        {{ csrfInput() }}
        {{ actionInput('lens/review/approve') }}
        {{ hiddenInput('analysisId', analysis.analysisId) }}

        {# Hidden inputs for modifications - updated by JavaScript on edit #}
        {# Text fields use named inputs directly (no hidden duplication needed) #}
        <input type="hidden" name="tags" data-lens-control="field-tags">
        <input type="hidden" name="dominantColors" data-lens-control="field-colors">
        <input type="hidden" name="focalPointX" data-lens-control="focal-x">
        <input type="hidden" name="focalPointY" data-lens-control="focal-y">
        <input type="hidden" name="containsPeople" data-lens-control="field-containsPeople">
        <input type="hidden" name="faceCount" data-lens-control="field-faceCount">
        {# Detection toggle hidden inputs — synced by JS from radio selections #}
        <input type="hidden" name="nsfwScore" data-lens-control="field-nsfwScore" value="{{ analysis.nsfwScore ?? 0 }}">
        <input type="hidden" name="hasWatermark" data-lens-control="field-hasWatermark" value="{{ analysis.hasWatermark ? '1' : '0' }}">
        <input type="hidden" name="containsBrandLogo" data-lens-control="field-containsBrandLogo" value="{{ analysis.containsBrandLogo ? '1' : '0' }}">

        <div class="lens-review-panels lens-gap-24" data-lens-target="review-view">
            {# Left Panel - Image #}
            <div class="lens-review-left lens-flex-column lens-gap-12">
                <div class="lens-review-image-container" data-lens-target="image-container">
                    <img data-lens-target="review-image"
                         src="{{ analysis.previewUrl }}"
                         alt="{{ analysis.filename }}">

                    {% if analysis.focalPointX %}
                        <div class="lens-review-focal-marker" data-lens-target="focal-marker"
                             style="left: {{ (analysis.focalPointX * 100)|round(2) }}%;
                                    top: {{ (analysis.focalPointY * 100)|round(2) }}%;"></div>
                    {% endif %}
                </div>

                <div class="lens-review-zoom-controls">
                    <button type="button" class="btn small" data-lens-action="zoom-out">&minus;</button>
                    <span data-lens-target="zoom-level">100%</span>
                    <button type="button" class="btn small" data-lens-action="zoom-fit">{{ 'Fit'|t('lens') }}</button>
                    <button type="button" class="btn small" data-lens-action="zoom-in">&plus;</button>
                </div>

                {% if analysis.similarImages is not empty %}
                    <div class="lens-review-similar">
                        <h4>{{ 'Similar Images'|t('lens') }}</h4>
                        <div class="lens-review-similar-list">
                            {% for similar in analysis.similarImages %}
                                <a href="{{ similar.editUrl }}">
                                    <img src="{{ similar.thumbnailUrl }}" alt="{{ similar.filename }}">
                                    <span>{{ (similar.similarity * 100)|round }}%</span>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>

            {# Right Panel - Reuse analysis components #}
            <div class="lens-review-right">
                <div class="lens-review-asset-header">
                    <h3>{{ analysis.filename }}</h3>
                    <div class="lens-review-meta">
                        {{ analysis.fileSize|filesize }} &bull;
                        {{ analysis.uploadDate|datetime('short') }}
                    </div>
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <h4 class="lens-section-header__title">{{ 'Description'|t('lens') }}</h4>
                        <p class="lens-section-header__intro">{{ 'AI-suggested metadata. Edit directly to customize.'|t('lens') }}</p>
                    </div>
                    {% include 'lens/_components/analysis/content-section' with {
                        analysis: analysis,
                        assetTitle: analysis.assetTitle ?? '',
                        assetAlt: analysis.assetAlt ?? '',
                        isAutoGeneratedTitle: analysis.isAutoGeneratedTitle ?? false,
                        isAltEmpty: analysis.isAltEmpty ?? true,
                        altFieldInLayout: analysis.altFieldInLayout ?? true,
                        fieldState: 'editing'
                    } %}
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <h4 class="lens-section-header__title">{{ 'Taxonomy'|t('lens') }}</h4>
                    </div>
                    {% include 'lens/_components/analysis/taxonomy-section' with {
                        analysis: analysis,
                        analysisTags: analysis.tags,
                        analysisColors: analysis.colors,
                        fieldState: 'editing'
                    } %}
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <h4 class="lens-section-header__title">{{ 'Quality & Focal Point'|t('lens') }}</h4>
                    </div>
                    {% include 'lens/_components/analysis/quality-section' with {
                        analysis: analysis,
                        fieldState: 'editing'
                    } %}
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <h4 class="lens-section-header__title">{{ 'Flags & Detection'|t('lens') }}</h4>
                    </div>
                    {% include 'lens/_components/analysis/safety-section' with {
                        analysis: analysis,
                        fieldState: 'editing'
                    } %}
                </div>

                <div class="lens-section">
                    {% include 'lens/_components/analysis/editable-field' with {
                        fieldName: 'extractedText',
                        label: 'Extracted Text'|t('lens'),
                        value: analysis.extractedText,
                        aiValue: analysis.extractedTextAi,
                        confidence: null,
                        editedBy: analysis.extractedTextEditedBy,
                        editedAt: analysis.extractedTextEditedAt,
                        inputType: 'textarea',
                        featured: false,
                        analysisId: analysis.analysisId,
                        fieldState: 'editing'
                    } %}
                </div>

                {% if analysis.exif %}
                    <div class="lens-section">
                        <div class="lens-section-header">
                            <h4 class="lens-section-header__title">{{ 'Technical Info'|t('lens') }}</h4>
                        </div>
                        {% include 'lens/_components/analysis/technical-section' with {
                            analysis: analysis,
                            exifData: analysis.exif
                        } %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="lens-review-action-bar lens-flex-center lens-gap-8">
            {% if prevId %}
                <a href="{{ cpUrl('lens/review/' ~ prevId) }}" class="btn">
                    &larr; {{ 'Previous'|t('lens') }}
                </a>
            {% else %}
                <button type="button" class="btn" disabled>&larr; {{ 'Previous'|t('lens') }}</button>
            {% endif %}

            <button type="submit" class="btn submit">
                {{ 'Approve & Next'|t('lens') }} <kbd>A</kbd>
            </button>

            <button type="submit" class="btn"
                    formaction="{{ actionUrl('lens/review/skip') }}">
                {{ 'Skip'|t('lens') }} <kbd>S</kbd>
            </button>

            <button type="submit" class="btn"
                    formaction="{{ actionUrl('lens/review/reject') }}">
                {{ 'Reject'|t('lens') }} <kbd>R</kbd>
            </button>

            {% if nextId %}
                <a href="{{ cpUrl('lens/review/' ~ nextId) }}" class="btn">
                    {{ 'Next'|t('lens') }} &rarr;
                </a>
            {% else %}
                <button type="button" class="btn" disabled>{{ 'Next'|t('lens') }} &rarr;</button>
            {% endif %}
        </div>
    </form>
{% endblock %}
