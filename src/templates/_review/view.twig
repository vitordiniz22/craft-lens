{% extends '_layouts/cp' %}

{% set title = 'Review: {title}'|t('lens', {title: analysis.assetTitle ?? analysis.filename}) %}
{% set selectedSubnavItem = 'review' %}

{% block content %}
    {% include 'lens/_review/_toolbar' with {
        currentMode: 'focus',
        totalCount: totalCount,
        currentIndex: currentIndex
    } %}

    <form method="post" action="" accept-charset="UTF-8" data-lens-target="review-form">
        {{ csrfInput() }}
        {{ actionInput('lens/review/approve') }}
        {{ hiddenInput('analysisId', analysis.analysisId) }}

        {# Hidden inputs for modifications - updated by JavaScript on edit #}
        {# Text fields use named inputs directly (no hidden duplication needed) #}
        <input type="hidden" name="tags" data-lens-control="field-tags">
        <input type="hidden" name="dominantColors" data-lens-control="field-colors">
        <input type="hidden" name="focalPointX" data-lens-control="focal-x" value="{{ analysis.focalPointX ?? '' }}">
        <input type="hidden" name="focalPointY" data-lens-control="focal-y" value="{{ analysis.focalPointY ?? '' }}">
        <input type="hidden" name="containsPeople" data-lens-control="field-containsPeople">
        <input type="hidden" name="faceCount" data-lens-control="field-faceCount">
        {# Detection toggle hidden inputs — synced by JS from radio selections #}
        <input type="hidden" name="nsfwScore" data-lens-control="field-nsfwScore" value="{{ analysis.nsfwScore ?? 0 }}">
        <input type="hidden" name="hasWatermark" data-lens-control="field-hasWatermark" value="{{ analysis.hasWatermark ? '1' : '0' }}">
        <input type="hidden" name="containsBrandLogo" data-lens-control="field-containsBrandLogo" value="{{ analysis.containsBrandLogo ? '1' : '0' }}">

        <div class="lens-review-panels" data-lens-target="review-view">
            {# Left Panel - Image #}
            <div class="lens-review-left">
                <div class="lens-review-image-container">
                    <div class="lens-review-image-inner" data-lens-target="image-container"
                         data-lens-focal-x-ai="{{ analysis.focalPointXAi ?? '' }}"
                         data-lens-focal-y-ai="{{ analysis.focalPointYAi ?? '' }}"
                         data-lens-asset-has-focal-point="{{ analysis.assetHasFocalPoint ? '1' : '0' }}"
                         {% if analysis.assetFocalPoint %}
                             data-lens-asset-focal-x="{{ analysis.assetFocalPoint.x }}"
                             data-lens-asset-focal-y="{{ analysis.assetFocalPoint.y }}"
                         {% endif %}>
                        <img data-lens-target="review-image"
                             src="{{ analysis.previewUrl }}"
                             alt="{{ analysis.filename }}">

                        {% set fpMatchesAsset = analysis.assetHasFocalPoint
                            and analysis.assetFocalPoint
                            and analysis.focalPointX
                            and (analysis.focalPointX|round(2) == analysis.assetFocalPoint.x|round(2))
                            and (analysis.focalPointY|round(2) == analysis.assetFocalPoint.y|round(2)) %}

                        {# Active focal point marker (red = AI/editing, Craft-native = matches asset) #}
                        <div class="lens-review-focal-marker{{ fpMatchesAsset ? ' lens-review-focal-marker--current' : '' }}" data-lens-target="focal-marker"
                             {% if analysis.focalPointX is not null %}
                                 style="left: {{ (analysis.focalPointX * 100)|round(2) }}%;
                                        top: {{ (analysis.focalPointY * 100)|round(2) }}%;"
                             {% else %}
                                 style="display: none;"
                             {% endif %}></div>

                        {# Static reference — asset's current FP in Craft-native style (hidden when they overlap or no analysis FP) #}
                        {% if analysis.assetHasFocalPoint and analysis.assetFocalPoint %}
                            <div class="lens-review-focal-ref" data-lens-target="focal-ref"
                                 style="left: {{ (analysis.assetFocalPoint.x * 100)|round(2) }}%;
                                        top: {{ (analysis.assetFocalPoint.y * 100)|round(2) }}%;
                                        {{ (fpMatchesAsset or analysis.focalPointX is null) ? 'display: none;' : '' }}"></div>
                        {% endif %}

                        <span class="lens-review-focal-hint" data-lens-target="focal-hint">
                            {{ 'Click to set focal point'|t('lens') }}
                        </span>
                    </div>
                </div>

                <div class="lens-review-focal-status" data-lens-target="focal-status">
                    <span class="lens-review-focal-status__icon">&#9678;</span>
                    <span data-lens-target="focal-status-text">
                        {% if analysis.focalPointX %}
                            {{ 'Focal: {x}, {y}'|t('lens', {
                                x: (analysis.focalPointX * 100)|round ~ '%',
                                y: (analysis.focalPointY * 100)|round ~ '%'
                            }) }}
                        {% else %}
                            {{ 'No focal point set'|t('lens') }}
                        {% endif %}
                    </span>
                    {% if analysis.focalPointX and analysis.assetHasFocalPoint and not fpMatchesAsset %}
                        <span data-lens-target="focal-status-badge" class="lens-review-focal-badge">
                            {{ 'AI'|t('lens') }}
                        </span>
                    {% else %}
                        <span data-lens-target="focal-status-badge" class="lens-review-focal-badge" style="display: none;"></span>
                    {% endif %}
                </div>

                {# Focal point action bar — visible when review FP differs from asset's existing FP #}
                {% if analysis.assetHasFocalPoint and analysis.assetFocalPoint %}
                    <div class="lens-ai-suggestion-inline" data-lens-target="fp-actions"
                         {% if fpMatchesAsset %}style="display: none;"{% endif %}>
                        <span class="lens-ai-suggestion-icon lens-ai-suggestion-icon--ai">{{ iconSvg('wand-magic-sparkles')|attr({width: 12, height: 12}) }}</span>
                        <span class="lens-ai-suggestion-icon lens-ai-suggestion-icon--action">{{ iconSvg('triangle-exclamation')|attr({width: 12, height: 12}) }}</span>
                        <span data-lens-target="fp-actions-text">
                            {{ 'Different focal point suggested'|t('lens') }}
                        </span>
                        &middot;
                        <button type="button" class="lens-revert-trigger"
                                data-lens-action="focal-accept">
                            {{ 'Accept'|t('lens') }}
                        </button>
                        <span class="lens-focal-undo-group">
                            &middot;
                            <button type="button" class="lens-revert-trigger"
                                    data-lens-action="focal-use-current"
                                    data-lens-asset-focal-x="{{ analysis.assetFocalPoint.x }}"
                                    data-lens-asset-focal-y="{{ analysis.assetFocalPoint.y }}">
                                {{ 'Undo'|t('lens') }}
                            </button>
                        </span>
                    </div>
                {% endif %}

                {% if analysis.similarImages is not empty %}
                    {% include 'lens/_components/analysis/similar-assets-notice' with {
                        similarImages: analysis.similarImages,
                        asset: null,
                        variant: 'review'
                    } %}
                {% endif %}
            </div>

            {# Right Panel - Reuse analysis components #}
            <div class="lens-review-right">
                <div class="lens-review-asset-header">
                    <h3>{{ analysis.assetTitle ?? analysis.filename }}</h3>
                    <div class="lens-review-meta">
                        <a href="{{ analysis.editUrl }}" target="_blank">{{ analysis.filename }}</a> &bull;
                        {{ analysis.fileSize|filesize }} &bull;
                        {{ analysis.uploadDate|datetime('short') }}
                    </div>
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <span class="lens-section-header__title">{{ 'Description'|t('lens') }}</span>
                        <p class="lens-section-header__intro">{{ 'AI-suggested metadata. Edit directly to customize.'|t('lens') }}</p>
                    </div>
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/content-section' with {
                            analysis: analysis,
                            assetTitle: analysis.assetTitle ?? '',
                            assetAlt: analysis.assetAlt ?? '',
                            isAutoGeneratedTitle: analysis.isAutoGeneratedTitle ?? false,
                            isAltEmpty: analysis.isAltEmpty ?? true,
                            altFieldInLayout: analysis.altFieldInLayout ?? true,
                            fieldState: 'editing',
                            siteContent: analysis.siteContent ?? [],
                            isAltTranslatable: analysis.isAltTranslatable ?? false,
                            isTitleTranslatable: analysis.isTitleTranslatable ?? false
                        } %}
                    </div>
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <span class="lens-section-header__title">{{ 'Taxonomy'|t('lens') }}</span>
                    </div>
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/taxonomy-section' with {
                            analysis: analysis,
                            analysisTags: analysis.tags,
                            analysisColors: analysis.colors,
                            fieldState: 'editing'
                        } %}
                    </div>
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <span class="lens-section-header__title">{{ 'Quality & Focal Point'|t('lens') }}</span>
                    </div>
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/quality-section' with {
                            analysis: analysis,
                            fieldState: 'editing'
                        } %}
                    </div>
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <span class="lens-section-header__title">{{ 'Flags & Detection'|t('lens') }}</span>
                    </div>
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/safety-section' with {
                            analysis: analysis,
                            fieldState: 'editing'
                        } %}
                    </div>
                </div>

                <div class="lens-section">
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/editable-field' with {
                            fieldName: 'extractedText',
                            label: 'Extracted Text'|t('lens'),
                            value: analysis.extractedText,
                            aiValue: analysis.extractedTextAi,
                            confidence: null,
                            editedBy: analysis.extractedTextEditedBy,
                            editedAt: analysis.extractedTextEditedAt,
                            inputType: 'textarea',
                            featured: false,
                            analysisId: analysis.analysisId,
                            fieldState: 'editing'
                        } %}
                    </div>
                </div>

                {% if analysis.exif %}
                    <div class="lens-section">
                        <div class="lens-section-header">
                            <span class="lens-section-header__title">{{ 'Technical Info'|t('lens') }}</span>
                        </div>
                        <div class="lens-section-body">
                            {% include 'lens/_components/analysis/technical-section' with {
                                analysis: analysis,
                                exifData: analysis.exif
                            } %}
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="lens-review-action-bar">
            {% if prevId %}
                <a href="{{ cpUrl('lens/review/' ~ prevId) }}" class="btn">
                    &larr; {{ 'Previous'|t('lens') }}
                </a>
            {% else %}
                <button type="button" class="btn" disabled>&larr; {{ 'Previous'|t('lens') }}</button>
            {% endif %}

            <button type="submit" class="btn submit" data-lens-action="review-approve">
                {{ 'Approve & Next'|t('lens') }} <kbd>A</kbd>
            </button>

            <button type="submit" class="btn"
                    formaction="{{ actionUrl('lens/review/skip') }}"
                    data-lens-action="review-skip">
                {{ 'Skip'|t('lens') }} <kbd>S</kbd>
            </button>

            <button type="submit" class="btn"
                    formaction="{{ actionUrl('lens/review/reject') }}"
                    data-lens-action="review-reject">
                {{ 'Reject'|t('lens') }} <kbd>R</kbd>
            </button>

            {% if nextId %}
                <a href="{{ cpUrl('lens/review/' ~ nextId) }}" class="btn">
                    {{ 'Next'|t('lens') }} &rarr;
                </a>
            {% else %}
                <button type="button" class="btn" disabled>{{ 'Next'|t('lens') }} &rarr;</button>
            {% endif %}
        </div>
    </form>
{% endblock %}
