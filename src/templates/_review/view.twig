{% extends '_layouts/cp' %}

{% set displayTitle = (analysis.isAutoGeneratedTitle and analysis.suggestedTitle)
    ? analysis.suggestedTitle
    : (analysis.assetTitle ?? analysis.filename) %}
{% set title = 'Review: {title}'|t('lens', {title: displayTitle}) %}
{% set selectedSubnavItem = 'review' %}

{% block content %}
    {% include 'lens/_review/_toolbar' with {
        currentMode: 'focus',
        totalCount: totalCount,
        currentIndex: currentIndex
    } %}

    <form method="post" action="" accept-charset="UTF-8" data-lens-target="review-form">
        {{ csrfInput() }}
        {{ actionInput('lens/review/approve') }}
        {{ hiddenInput('analysisId', analysis.analysisId) }}

        {# Hidden inputs for modifications - updated by JavaScript on edit #}
        {# Text fields use named inputs directly (no hidden duplication needed) #}
        <input type="hidden" name="tags" data-lens-control="field-tags">
        <input type="hidden" name="focalPointX" data-lens-control="focal-x" value="{{ analysis.focalPointX ?? '' }}">
        <input type="hidden" name="focalPointY" data-lens-control="focal-y" value="{{ analysis.focalPointY ?? '' }}">
        <input type="hidden" name="containsPeople" data-lens-control="field-containsPeople" value="{{ analysis.containsPeople ? '1' : '0' }}">
        <input type="hidden" name="faceCount" data-lens-control="field-faceCount" value="{{ analysis.faceCount }}">
        {# Detection toggle hidden inputs — synced by JS from radio selections #}
        <input type="hidden" name="nsfwScore" data-lens-control="field-nsfwScore" value="{{ analysis.nsfwScore ?? 0 }}">
        <input type="hidden" name="hasWatermark" data-lens-control="field-hasWatermark" value="{{ analysis.hasWatermark ? '1' : '0' }}">
        <input type="hidden" name="containsBrandLogo" data-lens-control="field-containsBrandLogo" value="{{ analysis.containsBrandLogo ? '1' : '0' }}">

        {# Template for dynamically inserted lock icon — cloned by JS #}
        <template data-lens-target="lock-template">
            {% include 'lens/_components/analysis/_tooltip-lock' only %}
        </template>

        <div class="lens-review-panels" data-lens-target="review-view">
            {# Left Panel - Image + Focal Point #}
            <div class="lens-review-left">
                {% include 'lens/_review/_focal-point-panel' with {
                    analysis: analysis
                } %}
            </div>

            {# Right Panel - Reuse analysis components #}
            <div class="lens-review-right">
                <div class="lens-review-asset-header">
                    <h3>
                        <a href="{{ analysis.editUrl }}" target="_blank">{{ analysis.filename }}</a>
                    </h3>
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <span class="lens-section-header__title">{{ 'Description'|t('lens') }}</span>
                        <p class="lens-section-header__intro">{{ 'Ready-to-use metadata for accessibility and search.'|t('lens') }}</p>
                    </div>
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/content-section' with {
                            analysis: analysis,
                            assetTitle: analysis.assetTitle ?? '',
                            assetAlt: analysis.assetAlt ?? '',
                            isAutoGeneratedTitle: analysis.isAutoGeneratedTitle ?? false,
                            isAltEmpty: analysis.isAltEmpty ?? true,
                            altFieldInLayout: analysis.altFieldInLayout ?? true,
                            fieldState: 'editing',
                            siteContent: analysis.siteContent ?? [],
                            isAltTranslatable: analysis.isAltTranslatable ?? false,
                            isTitleTranslatable: analysis.isTitleTranslatable ?? false,
                            currentSiteId: craft.app.sites.primarySite.id,
                            primarySiteId: craft.app.sites.primarySite.id
                        } %}
                    </div>
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <span class="lens-section-header__title">{{ 'Taxonomy'|t('lens') }}</span>
                        <p class="lens-section-header__intro">{{ 'AI-generated tags for categorization.'|t('lens') }}</p>
                    </div>
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/taxonomy-section' with {
                            analysis: analysis,
                            analysisTags: analysis.tags,
                            fieldState: 'editing'
                        } %}
                    </div>
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <span class="lens-section-header__title">{{ 'Focal Point'|t('lens') }}</span>
                        <p class="lens-section-header__intro">{{ 'AI-suggested focus point for cropping and asset transforms.'|t('lens') }}</p>
                    </div>
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/focal-point-section' with {
                            analysis: analysis,
                            fieldState: 'editing'
                        } %}
                    </div>
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <span class="lens-section-header__title">{{ 'Image Assessment'|t('lens') }}</span>
                        <p class="lens-section-header__intro">{{ 'Technical checks to ensure your image is web-ready.'|t('lens') }}</p>
                    </div>
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/quality-section' with {
                            analysis: analysis,
                            fieldState: 'editing'
                        } %}
                    </div>
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <span class="lens-section-header__title">{{ 'Flags & Detection'|t('lens') }}</span>
                        <p class="lens-section-header__intro">{{ 'Safety signals to help guide editorial decisions.'|t('lens') }}</p>
                    </div>
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/safety-section' with {
                            analysis: analysis,
                            fieldState: 'editing'
                        } %}
                    </div>
                </div>

                <div class="lens-section">
                    <div class="lens-section-header">
                        <span class="lens-section-header__title">{{ 'Extracted Text'|t('lens') }}</span>
                        <p class="lens-section-header__intro">{{ 'Text detected within the image via OCR.'|t('lens') }}</p>
                    </div>
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/extracted-text-regions' with {
                            analysis: analysis,
                            analysisId: analysis.analysisId,
                            fieldState: 'editing',
                        } %}
                    </div>
                </div>

            </div>
        </div>

        {% include 'lens/_review/_action-bar' with {
            prevId: prevId,
            nextId: nextId
        } %}
    </form>
{% endblock %}
