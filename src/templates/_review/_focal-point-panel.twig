{#
 # Focal Point Panel — Image display with interactive focal point editing
 #
 # Expected variables:
 #   analysis - array (review-page analysis data with focalPointX/Y, assetHasFocalPoint, etc.)
 #}
<div class="lens-review-image-container">
    <div class="lens-review-image-inner" data-lens-target="image-container"
         data-lens-focal-x-ai="{{ analysis.focalPointXAi ?? '' }}"
         data-lens-focal-y-ai="{{ analysis.focalPointYAi ?? '' }}"
         data-lens-asset-has-focal-point="{{ analysis.assetHasFocalPoint ? '1' : '0' }}"
         {% if analysis.assetFocalPoint %}
             data-lens-asset-focal-x="{{ analysis.assetFocalPoint.x }}"
             data-lens-asset-focal-y="{{ analysis.assetFocalPoint.y }}"
         {% endif %}>
        <img data-lens-target="review-image"
             src="{{ analysis.previewUrl }}"
             alt="{{ analysis.filename }}">

        {% set fpMatchesAsset = analysis.assetHasFocalPoint
            and analysis.assetFocalPoint
            and analysis.focalPointX
            and (analysis.focalPointX|round(2) == analysis.assetFocalPoint.x|round(2))
            and (analysis.focalPointY|round(2) == analysis.assetFocalPoint.y|round(2)) %}

        {# Active focal point marker (red = AI/editing, Craft-native = matches asset) #}
        <div class="lens-review-focal-marker{{ fpMatchesAsset ? ' lens-review-focal-marker--current' : '' }}" data-lens-target="focal-marker"
             {% if analysis.focalPointX is not null %}
                 style="left: {{ (analysis.focalPointX * 100)|round(2) }}%;
                        top: {{ (analysis.focalPointY * 100)|round(2) }}%;"
             {% else %}
                 hidden
             {% endif %}></div>

        {# Static reference — asset's current FP in Craft-native style (hidden when they overlap or no analysis FP) #}
        {% if analysis.assetHasFocalPoint and analysis.assetFocalPoint %}
            <div class="lens-review-focal-ref" data-lens-target="focal-ref"
                 style="left: {{ (analysis.assetFocalPoint.x * 100)|round(2) }}%;
                        top: {{ (analysis.assetFocalPoint.y * 100)|round(2) }}%;"
                 {% if fpMatchesAsset or analysis.focalPointX is null %}hidden{% endif %}></div>
        {% endif %}

        <span class="lens-review-focal-hint" data-lens-target="focal-hint">
            {{ 'Click to set focal point'|t('lens') }}
        </span>
    </div>
</div>

<div class="lens-review-focal-status" data-lens-target="focal-status">
    <span data-lens-target="focal-status-text">
        {% if analysis.focalPointX %}
            {{ 'Focal: {x}, {y}'|t('lens', {
                x: (analysis.focalPointX * 100)|round ~ '%',
                y: (analysis.focalPointY * 100)|round ~ '%'
            }) }}
        {% else %}
            {{ 'No focal point set'|t('lens') }}
        {% endif %}
    </span>
    {% if analysis.focalPointX %}
        {% set fpMatchesAi = analysis.focalPointXAi is not null
            and (analysis.focalPointX|round(4) == analysis.focalPointXAi|round(4))
            and (analysis.focalPointY|round(4) == analysis.focalPointYAi|round(4)) %}
        {% if fpMatchesAsset %}
            <span data-lens-target="focal-status-badge" class="lens-review-focal-badge lens-review-focal-badge--original">
                {{ 'Original'|t('lens') }}
            </span>
        {% elseif fpMatchesAi %}
            <span data-lens-target="focal-status-badge" class="lens-review-focal-badge">
                {{ 'AI'|t('lens') }}
            </span>
        {% else %}
            <span data-lens-target="focal-status-badge" class="lens-review-focal-badge lens-review-focal-badge--edited">
                {{ 'Edited'|t('lens') }}
            </span>
        {% endif %}
    {% else %}
        <span data-lens-target="focal-status-badge" class="lens-review-focal-badge" hidden></span>
    {% endif %}

    {# Inline Reset button — visible only when user-edited, asset has existing FP,
       AND AI suggestion differs from asset original (otherwise "Revert to AI" already covers it) #}
    {% if analysis.assetHasFocalPoint and analysis.assetFocalPoint %}
        {% set aiMatchesAsset = analysis.focalPointXAi is not null
            and (analysis.focalPointXAi|round(4) == analysis.assetFocalPoint.x|round(4))
            and (analysis.focalPointYAi|round(4) == analysis.assetFocalPoint.y|round(4)) %}
        {% set showReset = analysis.focalPointX is not null
            and not fpMatchesAsset
            and not aiMatchesAsset %}
        <button type="button" class="lens-review-focal-reset lens-revert-trigger lens-revert-trigger--original"
                data-lens-action="focal-use-current"
                data-lens-target="focal-reset-btn"
                data-lens-asset-focal-x="{{ analysis.assetFocalPoint.x }}"
                data-lens-asset-focal-y="{{ analysis.assetFocalPoint.y }}"
                {% if not showReset %}hidden{% endif %}>
            {{ 'Revert to original'|t('lens') }}
        </button>
    {% else %}
        <button type="button" class="lens-review-focal-reset lens-revert-trigger"
                data-lens-target="focal-reset-btn" hidden>
            {{ 'Reset'|t('lens') }}
        </button>
    {% endif %}
</div>

{# AI focal point revert — visible when FP differs from AI suggestion #}
{% if analysis.focalPointXAi is not null and analysis.focalPointYAi is not null %}
    {% set fpMatchesAi = analysis.focalPointX is not null
        and (analysis.focalPointXAi|round(2) == analysis.focalPointX|round(2))
        and (analysis.focalPointYAi|round(2) == analysis.focalPointY|round(2)) %}

    <div class="lens-ai-suggestion-inline" data-lens-target="fp-ai-revert"
         {% if fpMatchesAi %}hidden{% endif %}>
        <craft-tooltip text="{{ 'AI suggested'|t('lens') }}"><button type="button" class="lens-ai-badge-icon lens-ai-suggestion-icon--ai">{{ iconSvg('wand-magic-sparkles')|attr({width: 12, height: 12}) }}</button></craft-tooltip>
        <span data-lens-target="fp-ai-revert-text">
            {{ 'AI suggested: {x}, {y}'|t('lens', {
                x: (analysis.focalPointXAi * 100)|round ~ '%',
                y: (analysis.focalPointYAi * 100)|round ~ '%'
            }) }}
        </span>
        <span class="lens-ai-suggestion-actions">
            <button type="button" class="lens-revert-trigger"
                    data-lens-action="focal-revert"
                    data-lens-focal-x-ai="{{ analysis.focalPointXAi }}"
                    data-lens-focal-y-ai="{{ analysis.focalPointYAi }}">
                {{ 'Revert to AI'|t('lens') }}
            </button>
        </span>
    </div>
{% endif %}

{% if analysis.similarImages is not empty %}
    {% include 'lens/_components/analysis/similar-assets-notice' with {
        similarImages: analysis.similarImages,
        asset: null,
        variant: 'review'
    } %}
{% endif %}
