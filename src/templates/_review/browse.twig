{% extends '_layouts/cp' %}

{% set title = 'Review AI Suggestions'|t('lens') %}
{% set selectedSubnavItem = 'review' %}

{% block content %}
    {% if pendingCount > 0 %}
        {% include 'lens/_review/_toolbar' with {
            currentMode: 'browse',
            totalCount: totalCount
        } %}

        {% include 'lens/_components/inline-notice' with {
            type: 'info',
            title: 'What is Review?'|t('lens'),
            message: 'Lens analyzed these assets and generated AI metadata, tags, alt text, focal points, and descriptions. Review each one to verify the AI\'s work, correct any mistakes, and approve or reject. Assets are fully usable immediately after analysis; review is optional, but it ensures your library data is accurate and trustworthy.'|t('lens')
        } %}

        <div class="lens-browse-grid">
            {% for item in items %}
                {% set asset = assets[item.assetId] ?? null %}

                {% if asset %}
                    {% include 'lens/_components/asset-card' with {
                        asset: asset,
                        analysis: analysisMap[asset.id] ?? null,
                        linkUrl: cpUrl('lens/review/' ~ item.analysisId),
                        showTags: false,
                        showColors: false,
                        showMeta: true,
                        avgConfidence: item.avgConfidence,
                        tagCount: item.tagCount,
                    } only %}
                {% endif %}
            {% endfor %}
        </div>

        {% include 'lens/_components/pagination' with {
            total: totalCount,
            page: page,
            totalPages: totalPages,
            baseUrl: 'lens/review',
            pageParam: 'page',
        } only %}
    {% else %}
        {% if hasAnalyses %}
            {% include 'lens/_components/empty-state' with {
                heading: 'No Pending Reviews'|t('lens'),
                description: 'All AI suggestions have been reviewed.'|t('lens'),
                cta: {label: 'Go to Dashboard'|t('lens'), url: 'lens'}
            } %}
        {% else %}
            {% include 'lens/_components/empty-state' with {
                heading: 'No Pending Reviews'|t('lens'),
                description: 'Analyze your images to generate AI suggestions for review.'|t('lens'),
                cta: {label: 'Go to Dashboard'|t('lens'), url: 'lens'}
            } %}
        {% endif %}
    {% endif %}
{% endblock %}
