{% extends '_layouts/cp' %}

{% set title = 'Bulk Review Actions'|t('lens') %}
{% set selectedSubnavItem = 'review' %}

{% block content %}
    {% if totalCount > 0 %}
        {% include 'lens/_review/_toolbar' with {
            currentMode: 'bulk',
            totalCount: totalCount
        } %}

        <form method="post" action="" accept-charset="UTF-8" data-lens-target="bulk-review-form">
            {{ csrfInput() }}
            {{ actionInput('lens/review/bulk-approve') }}

            <div class="lens-bulk-actions">
                <button type="button" class="btn small" data-lens-action="bulk-select-all">{{ 'Select All'|t('lens') }}</button>
                <button type="button" class="btn small" data-lens-action="bulk-select-high">{{ 'Select High Confidence (>80%)'|t('lens') }}</button>
                <button type="button" class="btn small" data-lens-action="bulk-deselect-all">{{ 'Deselect All'|t('lens') }}</button>
                <span class="lens-selection-count" data-lens-target="bulk-selection-count">{{ '0 selected'|t('lens') }}</span>
                <div class="lens-bulk-buttons">
                    <button type="submit" class="btn small submit" disabled data-lens-action="bulk-approve">
                        {{ 'Approve Selected'|t('lens') }}
                    </button>
                    <button type="submit" class="btn small"
                            data-lens-action="bulk-reject"
                            data-lens-form-action="lens/review/bulk-reject"
                            disabled>
                        {{ 'Reject Selected'|t('lens') }}
                    </button>
                </div>
            </div>

            <div class="lens-bulk-grid">
                {% for item in items %}
                    <label class="lens-bulk-item" data-lens-confidence="{{ item.avgConfidence }}">
                        <input type="checkbox" name="ids[]" value="{{ item.analysisId }}" data-lens-control="bulk-checkbox">
                        <div class="lens-bulk-item__image">
                            <img src="{{ item.thumbnailUrl }}" alt="{{ item.filename }}">
                            <div class="lens-bulk-item__overlay">
                                <span class="lens-bulk-item__checkmark">✓</span>
                            </div>
                        </div>
                        <div class="lens-bulk-item__info">
                            <div class="lens-bulk-item__title">{{ item.suggestedTitle ?: item.filename }}</div>
                            <div class="lens-bulk-item__meta">
                                {% if item.avgConfidence >= 0.8 %}
                                    <span class="lens-confidence-badge lens-confidence-badge--high">{{ (item.avgConfidence * 100)|round }}%</span>
                                {% elseif item.avgConfidence >= 0.5 %}
                                    <span class="lens-confidence-badge lens-confidence-badge--medium">{{ (item.avgConfidence * 100)|round }}%</span>
                                {% else %}
                                    <span class="lens-confidence-badge lens-confidence-badge--low">{{ (item.avgConfidence * 100)|round }}%</span>
                                {% endif %}
                                <span class="lens-tag-count">{{ item.tagCount }} {{ 'tags'|t('lens') }}</span>
                            </div>
                        </div>
                    </label>
                {% endfor %}
            </div>
        </form>
    {% else %}
        {% include 'lens/_components/empty-state' with {
            heading: 'No Pending Reviews'|t('lens'),
            description: 'All AI suggestions have been reviewed.'|t('lens')
        } %}
    {% endif %}
{% endblock %}
