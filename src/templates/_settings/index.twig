{% extends '_layouts/cp' %}

{% set title = 'Settings'|t('lens') %}
{% set selectedSubnavItem = 'settings' %}
{% set fullPageForm = true %}

{% import '_includes/forms.twig' as forms %}

{% block content %}
    {{ actionInput('lens/settings/save') }}
    {{ redirectInput('lens/settings') }}

    {# ==================== SECTION: AI Provider ==================== #}
    <h2>{{ 'AI Provider'|t('lens') }}</h2>
    <p>{{ 'Choose the AI provider for image analysis. Each provider offers equivalent features, so pick based on your preferred pricing and existing API access.'|t('lens') }}</p>

    {{ forms.radioGroupField({
        first: true,
        label: 'AI Provider'|t('lens'),
        id: 'aiProvider',
        name: 'settings[aiProvider]',
        value: settings.aiProvider,
        options: [
            {label: 'OpenAI'|t('lens'), value: 'openai'},
            {label: 'Google Gemini'|t('lens'), value: 'gemini'},
            {label: 'Anthropic Claude'|t('lens'), value: 'claude'},
        ],
        toggle: true,
        targetPrefix: '#aiProvider--',
        errors: settings.getErrors('aiProvider'),
    }) }}

    <h3>{{ 'API Configuration'|t('lens') }}</h3>
    <p>{{ 'Add your API key and select a model. For production use, store keys as environment variables.'|t('lens') }}</p>

    {# --- OpenAI Settings --- #}
    <div id="aiProvider--openai" class="nested-fields{% if settings.aiProvider != 'openai' %} hidden{% endif %}">
        {{ forms.autosuggestField({
            label: 'OpenAI API Key'|t('lens'),
            instructions: 'Accepts environment variables (e.g., `$OPENAI_API_KEY`). [Get your API key](https://platform.openai.com/api-keys).'|t('lens'),
            id: 'openaiApiKey',
            name: 'settings[openaiApiKey]',
            value: settings.openaiApiKey,
            suggestEnvVars: true,
            required: true,
            errors: settings.getErrors('openaiApiKey'),
        }) }}

        {{ forms.selectField({
            label: 'OpenAI Model'|t('lens'),
            instructions: 'Mini is the best starting point for most sites. Upgrade to GPT-5.2 for complex scenes or detailed alt text. Use Nano to minimize costs on high-volume libraries.'|t('lens'),
            id: 'openaiModel',
            name: 'settings[openaiModel]',
            value: settings.openaiModel,
            options: [
                {label: 'GPT-5 Mini — $0.25/1M tokens (recommended)'|t('lens'), value: 'gpt-5-mini'},
                {label: 'GPT-5.2 — $1.75/1M tokens (highest quality)'|t('lens'), value: 'gpt-5.2'},
                {label: 'GPT-5 Nano — $0.05/1M tokens (lowest cost)'|t('lens'), value: 'gpt-5-nano'},
            ],
            errors: settings.getErrors('openaiModel'),
        }) }}
    </div>

    {# --- Google Gemini Settings --- #}
    <div id="aiProvider--gemini" class="nested-fields{% if settings.aiProvider != 'gemini' %} hidden{% endif %}">
        {{ forms.autosuggestField({
            label: 'Gemini API Key'|t('lens'),
            instructions: 'Accepts environment variables (e.g., `$GEMINI_API_KEY`). [Get your API key](https://aistudio.google.com/app/apikey).'|t('lens'),
            id: 'geminiApiKey',
            name: 'settings[geminiApiKey]',
            value: settings.geminiApiKey,
            suggestEnvVars: true,
            required: true,
            errors: settings.getErrors('geminiApiKey'),
        }) }}

        {{ forms.selectField({
            label: 'Gemini Model'|t('lens'),
            instructions: 'Flash is the best balance of speed and quality for most sites. Use Pro for the highest accuracy on complex images. Flash Lite minimizes costs on high-volume libraries.'|t('lens'),
            id: 'geminiModel',
            name: 'settings[geminiModel]',
            value: settings.geminiModel,
            options: [
                {label: 'Gemini 2.5 Flash — $0.30/1M tokens (recommended)'|t('lens'), value: 'gemini-2.5-flash'},
                {label: 'Gemini 2.5 Pro — $1.25/1M tokens (highest quality)'|t('lens'), value: 'gemini-2.5-pro'},
                {label: 'Gemini 2.5 Flash Lite — $0.10/1M tokens (lowest cost)'|t('lens'), value: 'gemini-2.5-flash-lite'},
            ],
            errors: settings.getErrors('geminiModel'),
        }) }}
    </div>

    {# --- Claude (Anthropic) Settings --- #}
    <div id="aiProvider--claude" class="nested-fields{% if settings.aiProvider != 'claude' %} hidden{% endif %}">
        {{ forms.autosuggestField({
            label: 'Claude API Key'|t('lens'),
            instructions: 'Accepts environment variables (e.g., `$ANTHROPIC_API_KEY`). [Get your API key](https://console.anthropic.com/).'|t('lens'),
            id: 'claudeApiKey',
            name: 'settings[claudeApiKey]',
            value: settings.claudeApiKey,
            suggestEnvVars: true,
            required: true,
            errors: settings.getErrors('claudeApiKey'),
        }) }}

        {{ forms.selectField({
            label: 'Claude Model'|t('lens'),
            instructions: 'Sonnet is the best balance of quality and cost for most sites. Use Opus for the highest accuracy on complex images. Haiku minimizes costs on high-volume libraries.'|t('lens'),
            id: 'claudeModel',
            name: 'settings[claudeModel]',
            value: settings.claudeModel,
            options: [
                {label: 'Claude Sonnet 4.5 — $3.00/1M tokens (recommended)'|t('lens'), value: 'claude-sonnet-4-5-20250929'},
                {label: 'Claude Opus 4.5 — $5.00/1M tokens (highest quality)'|t('lens'), value: 'claude-opus-4-5-20251101'},
                {label: 'Claude Haiku 4.5 — $1.00/1M tokens (lowest cost)'|t('lens'), value: 'claude-haiku-4-5-20251001'},
            ],
            errors: settings.getErrors('claudeModel'),
        }) }}
    </div>

    <hr>

    {# ==================== SECTION: Asset Processing ==================== #}
    <h2>{{ 'Asset Processing'|t('lens') }}</h2>
    <p>{{ 'Control when and how Lens analyzes your assets. All processing runs in the background and uploads are never delayed.'|t('lens') }}</p>

    {{ forms.lightswitchField({
        first: true,
        label: 'Auto-Process on Upload'|t('lens'),
        instructions: 'When a new image is uploaded, Lens will automatically generate alt text, tags, and other metadata in the background.'|t('lens'),
        id: 'autoProcessOnUpload',
        name: 'settings[autoProcessOnUpload]',
        on: settings.autoProcessOnUpload,
    }) }}

    {{ forms.lightswitchField({
        label: 'Require Human Review'|t('lens'),
        instructions: 'Hold AI-generated metadata for review before applying it to assets. Recommended for published sites where accuracy matters. Pending assets appear in the Review Queue.'|t('lens'),
        id: 'requireReviewBeforeApply',
        name: 'settings[requireReviewBeforeApply]',
        on: settings.requireReviewBeforeApply,
    }) }}

    {{ forms.checkboxSelectField({
        label: 'Volumes to Process'|t('lens'),
        instructions: 'Choose which volumes Lens should analyze. If none are selected, all volumes are processed. Exclude volumes with non-photo assets like icons, PDFs, or design files.'|t('lens'),
        id: 'enabledVolumes',
        name: 'settings[enabledVolumes]',
        values: settings.enabledVolumes,
        options: volumeOptions,
        errors: settings.getErrors('enabledVolumes'),
    }) }}

    <hr>

    {# ==================== SECTION: Semantic Search ==================== #}
    <h2>{{ 'Semantic Search'|t('lens') }}</h2>
    <p>{{ 'Enhance the native asset selector with AI-powered search. When enabled, the search bar in every asset selector modal is replaced with Lens semantic search — editors can describe what they\'re looking for instead of remembering filenames.'|t('lens') }}</p>

    {{ forms.lightswitchField({
        first: true,
        label: 'Enable Semantic Asset Search'|t('lens'),
        instructions: 'Replaces the native search in asset selector modals with Lens search. Queries match against AI-generated alt text, descriptions, tags, and extracted text.'|t('lens'),
        id: 'enableSemanticSearch',
        name: 'settings[enableSemanticSearch]',
        on: settings.enableSemanticSearch,
    }) }}

{% endblock %}
