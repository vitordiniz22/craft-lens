{# Section 2: Analysis Coverage - always visible #}
<div class="lens-dashboard-section lens-processing pane">
    <h2 class="lens-section-header__title">{{ 'Analysis Coverage'|t('lens') }}</h2>

    {% set totalImages = processingStats.totalImages %}
    {% set analyzed = processingStats.analyzed %}
    {% set unprocessed = processingStats.unprocessed %}
    {% set processing = processingStats.processing|default(0) %}
    {% set pendingReview = processingStats.pendingReview|default(0) %}
    {% set failed = processingStats.failed|default(0) %}
    {% set processed = max(0, totalImages - unprocessed) %}
    {% set waiting = max(0, unprocessed - failed) %}

    <div class="lens-processing__status" data-state="{{ processingState }}">
        {% if processingState == 'processing' %}
            {# Processing state #}
            <div class="lens-processing-active">
                {% set progress = processingProgress %}
                {% set percentComplete = progress.percentComplete|default(0) %}
                <div class="lens-processing__progress-header">
                    <span class="lens-processing__progress-label">{{ 'Processing'|t('lens') }}</span>
                    <span class="lens-processing__progress-text">
                        {{ progress.completed|default(0)|number_format }} {{ 'of'|t('lens') }} {{ progress.total|default(totalImages)|number_format }}
                        ({{ percentComplete|round }}%)
                    </span>
                </div>
                <div class="lens-progress">
                    <div class="lens-progress-fill" style="width: {{ percentComplete }}%"></div>
                </div>
                {% if queueInfo.estimatedMinutes is defined and queueInfo.estimatedMinutes %}
                    <div class="lens-processing__estimate">
                        {{ 'Estimated: ~{minutes} minutes remaining'|t('lens', {minutes: queueInfo.estimatedMinutes}) }}
                    </div>
                {% endif %}
                <div class="lens-actions__grid">
                    <form method="post" action="{{ actionUrl('lens/bulk/cancel') }}">
                        {{ csrfInput() }}
                        <button type="submit" class="btn">{{ 'Pause'|t('lens') }}</button>
                    </form>
                </div>
            </div>
        {% elseif unprocessed > 0 %}
            {# Assets waiting state #}
            <div class="lens-processing-waiting">
                {% set percentComplete = totalImages > 0 ? min(100, ((processed / totalImages) * 100)) : 0 %}
                <div class="lens-processing__progress-header">
                    <span class="lens-processing__progress-text">
                        {{ processed|number_format }} {{ 'of'|t('lens') }} {{ totalImages|number_format }}
                        ({{ percentComplete|round }}%)
                    </span>
                </div>
                <div class="lens-progress">
                    <div class="lens-progress-fill" style="width: {{ percentComplete }}%"></div>
                </div>
                <div class="lens-processing__waiting-info">
                    <span class="lens-processing__waiting-count">{{ unprocessed|number_format }} {{ 'unprocessed'|t('lens') }}</span>
                </div>
                <div class="lens-actions__grid">
                    {% if waiting > 0 %}
                        <form method="post" action="{{ actionUrl('lens/bulk/process') }}">
                            {{ csrfInput() }}
                            <button type="submit" class="btn submit">{{ 'Start Analysis'|t('lens') }}</button>
                        </form>
                    {% endif %}
                    {% if failed > 0 %}
                        <form method="post" action="{{ actionUrl('lens/bulk/retry-failed') }}">
                            {{ csrfInput() }}
                            <button type="submit" class="btn{% if waiting == 0 %} submit{% endif %}">{{ 'Retry {count} Failed'|t('lens', {count: failed}) }}</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        {% else %}
            {# Idle/Complete state #}
            <div class="lens-processing--complete">
                <div class="lens-processing__progress-header">
                    <span class="lens-processing__progress-text">
                        {{ processed|number_format }} {{ 'of'|t('lens') }} {{ totalImages|number_format }} {{ 'complete'|t('lens') }}
                    </span>
                    <span class="lens-processing__complete-icon">{{ iconSvg('check') }}</span>
                </div>
                <div class="lens-progress lens-progress--complete">
                    <div class="lens-progress-fill" style="width: 100%"></div>
                </div>
            </div>
        {% endif %}
    </div>
</div>
