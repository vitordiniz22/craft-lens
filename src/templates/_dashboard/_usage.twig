{# Section 7: Usage & Costs #}
{% set hasUsageData = allTimeUsage.totalAssets > 0 %}
{% if hasUsageData %}
<div class="lens-dashboard-section lens-usage pane">
    <h2 class="lens-section-header__title">{{ 'Usage & Costs'|t('lens') }}</h2>

    {# Primary stat cards: all-time totals #}
    {% set avgCost = allTimeUsage.totalAssets > 0
        ? allTimeUsage.totalCost / allTimeUsage.totalAssets
        : 0 %}

    <div class="lens-usage__cards">
        <div class="lens-usage__card">
            <div class="lens-usage__card-value">{{ allTimeUsage.totalAssets|number_format }}</div>
            <div class="lens-usage__card-label">{{ 'Processed'|t('lens') }}</div>
        </div>
        <div class="lens-usage__card">
            <div class="lens-usage__card-value">${{ allTimeUsage.totalCost|number_format(4) }}</div>
            <div class="lens-usage__card-label">{{ 'Total Spent'|t('lens') }}</div>
        </div>
        <div class="lens-usage__card">
            <div class="lens-usage__card-value">${{ avgCost|number_format(4) }}</div>
            <div class="lens-usage__card-label">{{ 'Per Asset'|t('lens') }}</div>
        </div>
    </div>

    {# Projection line #}
    <div class="lens-usage__projection">
        {% if costProjection.remainingAssets > 0 %}
            {{ costProjection.remainingAssets|number_format }} {{ 'assets remaining'|t('lens') }}
            &middot;
            {{ 'Est.'|t('lens') }} ${{ costProjection.estimatedCost|number_format(4) }} {{ 'to complete'|t('lens') }}
        {% else %}
            {{ 'All assets processed'|t('lens') }}
        {% endif %}
    </div>

    {# Monthly summary (secondary) #}
    {% if monthlyUsage.assetsProcessed > 0 or lastMonthUsage.assetsProcessed > 0 %}
    <div class="lens-usage__monthly">
        {% if monthlyUsage.assetsProcessed > 0 %}
        <div class="lens-usage__month-line">
            {{ 'This month:'|t('lens') }}
            {{ monthlyUsage.assetsProcessed|number_format }} {{ 'processed'|t('lens') }}
            &middot;
            ${{ monthlyUsage.totalCost|number_format(4) }} {{ 'spent'|t('lens') }}
        </div>
        {% endif %}
        {% if lastMonthUsage.assetsProcessed > 0 %}
        <div class="lens-usage__month-line">
            {{ 'Last month:'|t('lens') }}
            {{ lastMonthUsage.assetsProcessed|number_format }} {{ 'processed'|t('lens') }}
            &middot;
            ${{ lastMonthUsage.totalCost|number_format(4) }} {{ 'spent'|t('lens') }}
        </div>
        {% endif %}
    </div>
    {% endif %}
</div>
{% endif %}
