{% extends '_layouts/cp' %}

{% set title = 'Dashboard'|t('lens') %}
{% set selectedSubnavItem = 'dashboard' %}

{% block content %}
<div class="lens-dashboard-page">
    {% if hasUnresolvedIssues %}
        {% include 'lens/_components/setup-banner' with {
            checks: setupStatus,
            title: hasCriticalIssues ? 'Setup Required'|t('lens') : 'Configuration Tips'|t('lens'),
            description: hasCriticalIssues
                ? 'Lens needs configuration before it can analyze your assets. Setup takes about 2 minutes.'|t('lens')
                : 'Complete these optional steps to get the most out of Lens.'|t('lens')
        } %}
    {% endif %}

    {% if not hasCriticalIssues %}
        {% if not lens.isPro %}
            {% include 'lens/_components/upgrade-banner' %}
        {% endif %}

        {% if processingStats.totalImages == 0 %}
            {% include 'lens/_dashboard/_empty-state' %}
        {% else %}
            {% if lens.isPro %}
                {% include 'lens/_dashboard/_attention' %}
            {% endif %}

            {% include 'lens/_dashboard/_library-health' %}

            {% if lens.isPro %}
                {% include 'lens/_dashboard/_processing-status' %}
            {% endif %}

            {% if lens.isPro %}
                {% include 'lens/_dashboard/_quick-insights' %}
                {% include 'lens/_dashboard/_recent-activity' %}
                {% include 'lens/_dashboard/_usage' %}
            {% else %}
                {% include 'lens/_dashboard/_recent-activity' with {
                    recentActivity: recentActivity|slice(0, 5)
                } %}
            {% endif %}
        {% endif %}
    {% endif %}
</div>

{% endblock %}
