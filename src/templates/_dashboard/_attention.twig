{# Section 1: Needs Attention - only shows when issues exist #}
{% if attentionItems|length %}
<div class="lens-dashboard-section lens-attention">
    <h2 class="lens-section-header__title">{{ 'Needs Attention'|t('lens') }}</h2>
    <div class="lens-attention__cards lens-gap-12">
        {% for item in attentionItems %}
            <a href="{{ cpUrl(item.url) }}" class="lens-attention__card lens-flex-center lens-gap-8">
                <span class="lens-attention__icon" data-icon="{{ item.icon }}"></span>
                <span class="lens-attention__count">{{ item.count }}</span>
                <span class="lens-attention__label">{{ item.label }}</span>
            </a>
        {% endfor %}
    </div>
</div>
{% endif %}
