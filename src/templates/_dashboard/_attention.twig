{# Section 1: Needs Attention - only shows when issues exist #}
{% if attentionItems|length %}
<div class="lens-dashboard-section lens-attention-section">
    <h2 class="lens-section-title">{{ 'Needs Attention'|t('lens') }}</h2>
    <div class="lens-attention-cards">
        {% for item in attentionItems %}
            <a href="{{ cpUrl(item.url) }}" class="lens-attention-card">
                <span class="lens-attention-icon" data-icon="{{ item.icon }}"></span>
                <span class="lens-attention-count">{{ item.count }}</span>
                <span class="lens-attention-label">{{ item.label }}</span>
            </a>
        {% endfor %}
    </div>
</div>
{% endif %}
