{# Section 4: Quick Actions #}
<div class="lens-dashboard-section lens-actions">
    <div class="lens-actions__grid lens-gap-12">
        {% if unprocessedCount > 0 %}
            <form method="post" action="{{ actionUrl('lens/bulk/process') }}" class="lens-actions__form">
                {{ csrfInput() }}
                <button type="submit" class="btn submit">
                    {{ 'Analyze All Unprocessed'|t('lens') }}
                </button>
            </form>
        {% endif %}

        <a href="{{ cpUrl('lens/review') }}" class="btn">
            {{ 'Review Queue'|t('lens') }}
            {% if pendingReviewCount > 0 %}
                <span class="lens-badge lens-badge--error-solid">{{ pendingReviewCount }}</span>
            {% endif %}
        </a>

    </div>
</div>
