{#
 # Image Quality Distribution — Stacked bar with legend and issue pills.
 #
 # Expected variables:
 #   qualityDistribution - array{high: int, medium: int, low: int, total: int}
 #   qualityIssueCounts  - array{blurry: int, tooDark: int, tooBright: int, lowContrast: int}
 #}

{% set total = qualityDistribution.total %}
{% set highPct = total > 0 ? ((qualityDistribution.high / total) * 100)|round(1) : 0 %}
{% set medPct = total > 0 ? ((qualityDistribution.medium / total) * 100)|round(1) : 0 %}
{% set lowPct = total > 0 ? ((qualityDistribution.low / total) * 100)|round(1) : 0 %}

<div class="lens-health-subheader">
    <h3 class="lens-field-label">{{ 'Image Quality'|t('lens') }}</h3>
    <span class="lens-coverage__metric-counts">{{ '{count} analyzed'|t('lens', {count: total}) }}</span>
</div>

{# Stacked quality bar #}
<div class="lens-progress lens-quality-bar">
    {% if qualityDistribution.high > 0 %}
        <a href="{{ cpUrl('lens/search', {qualityPreset: 'high'}) }}"
           class="lens-quality-bar__segment lens-quality-bar__segment--high"
           style="width: {{ highPct }}%"
           title="{{ 'High'|t('lens') }}: {{ qualityDistribution.high }}">
        </a>
    {% endif %}
    {% if qualityDistribution.medium > 0 %}
        <a href="{{ cpUrl('lens/search', {qualityPreset: 'medium'}) }}"
           class="lens-quality-bar__segment lens-quality-bar__segment--medium"
           style="width: {{ medPct }}%"
           title="{{ 'Medium'|t('lens') }}: {{ qualityDistribution.medium }}">
        </a>
    {% endif %}
    {% if qualityDistribution.low > 0 %}
        <a href="{{ cpUrl('lens/search', {qualityPreset: 'low'}) }}"
           class="lens-quality-bar__segment lens-quality-bar__segment--low"
           style="width: {{ lowPct }}%"
           title="{{ 'Low'|t('lens') }}: {{ qualityDistribution.low }}">
        </a>
    {% endif %}
</div>

{# Legend #}
<div class="lens-quality-legend">
    <a href="{{ cpUrl('lens/search', {qualityPreset: 'high'}) }}" class="lens-quality-legend__item">
        <span class="lens-quality-legend__dot lens-quality-legend__dot--high"></span>
        {{ 'High'|t('lens') }} ({{ qualityDistribution.high }})
    </a>
    <a href="{{ cpUrl('lens/search', {qualityPreset: 'medium'}) }}" class="lens-quality-legend__item">
        <span class="lens-quality-legend__dot lens-quality-legend__dot--medium"></span>
        {{ 'Medium'|t('lens') }} ({{ qualityDistribution.medium }})
    </a>
    <a href="{{ cpUrl('lens/search', {qualityPreset: 'low'}) }}" class="lens-quality-legend__item">
        <span class="lens-quality-legend__dot lens-quality-legend__dot--low"></span>
        {{ 'Low'|t('lens') }} ({{ qualityDistribution.low }})
    </a>
</div>

{# Issue pills — only shown when issues exist #}
{% set hasIssues = qualityIssueCounts.blurry > 0 or qualityIssueCounts.tooDark > 0 or qualityIssueCounts.tooBright > 0 or qualityIssueCounts.lowContrast > 0 %}
{% if hasIssues %}
    <div class="lens-quality-issues">
        {% if qualityIssueCounts.blurry > 0 %}
            <a href="{{ cpUrl('lens/search', {'qualityIssues[]': 'blurry'}) }}" class="lens-quality-issue">
                <span class="lens-quality-issue__count">{{ qualityIssueCounts.blurry }}</span>
                {{ 'Blurry'|t('lens') }}
            </a>
        {% endif %}
        {% if qualityIssueCounts.tooDark > 0 %}
            <a href="{{ cpUrl('lens/search', {'qualityIssues[]': 'tooDark'}) }}" class="lens-quality-issue">
                <span class="lens-quality-issue__count">{{ qualityIssueCounts.tooDark }}</span>
                {{ 'Too Dark'|t('lens') }}
            </a>
        {% endif %}
        {% if qualityIssueCounts.tooBright > 0 %}
            <a href="{{ cpUrl('lens/search', {'qualityIssues[]': 'tooBright'}) }}" class="lens-quality-issue">
                <span class="lens-quality-issue__count">{{ qualityIssueCounts.tooBright }}</span>
                {{ 'Too Bright'|t('lens') }}
            </a>
        {% endif %}
        {% if qualityIssueCounts.lowContrast > 0 %}
            <a href="{{ cpUrl('lens/search', {'qualityIssues[]': 'lowContrast'}) }}" class="lens-quality-issue">
                <span class="lens-quality-issue__count">{{ qualityIssueCounts.lowContrast }}</span>
                {{ 'Low Contrast'|t('lens') }}
            </a>
        {% endif %}
    </div>
{% endif %}
