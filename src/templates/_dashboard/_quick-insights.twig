{# Section 5: Quick Insights - only shows when data exists #}
{% if topTags|length or dominantColors|length %}
<div class="lens-dashboard-section pane">
    <div class="lens-section-header">
        <h2 class="lens-section-header__title">{{ 'Quick Insights'|t('lens') }}</h2>
    </div>

    <div class="lens-insights__grid">
        {# Top Tags - compact inline list #}
        {% if topTags|length %}
        <div class="lens-insights__block">
            <h3 class="lens-field-label">{{ 'Top Tags'|t('lens') }}</h3>
            <div class="inline-chips">
                {% for item in topTags %}
                <a href="{{ cpUrl('lens/search', {tags: item.tag}) }}" class="chip">
                    <div class="chip-content">
                        <span class="chip-label">{{ item.tag }}</span>
                    </div>
                    <span class="badge">{{ item.count }}</span>
                </a>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# Dominant Colors - 5 small swatches #}
        {% if dominantColors|length %}
        <div class="lens-insights__block">
            <h3 class="lens-field-label">{{ 'Dominant Colors'|t('lens') }}</h3>
            <div class="lens-insights__colors">
                {% for color in dominantColors %}
                    <a href="{{ cpUrl('lens/search', {color: color.hex}) }}"
                       class="lens-swatch lens-swatch--md lens-swatch--interactive"
                       style="background-color: {{ color.hex }}"
                       title="{{ color.hex }} ({{ color.count }} {{ color.count == 1 ? 'asset'|t('lens') : 'assets'|t('lens') }})">
                        <span class="visually-hidden">{{ color.hex }}</span>
                    </a>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endif %}
