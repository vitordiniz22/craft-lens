{# Section 5: Quick Insights - only shows when data exists #}
{% if topTags|length %}
<div class="lens-dashboard-section pane">
    <div class="lens-section-header">
        <h2 class="lens-section-header__title">{{ 'Quick Insights'|t('lens') }}</h2>
    </div>

    <div class="lens-insights__block">
        <h3 class="lens-field-label">{{ 'Top Tags'|t('lens') }}</h3>
        <div class="inline-chips">
            {% for item in topTags %}
            <a href="{{ cpUrl('lens/search', {tags: item.tag}) }}" class="chip">
                <div class="chip-content">
                    <span class="chip-label">{{ item.tag }}</span>
                </div>
                <span class="badge">{{ item.count }}</span>
            </a>
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}
