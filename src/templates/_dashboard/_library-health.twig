{# Section 3: Metadata Coverage - only shows when assets have been analyzed #}
{% if altTextCoverage.total > 0 %}
<div class="lens-dashboard-section pane">
    <div class="lens-section-header">
        <h2 class="lens-section-header__title">{{ 'Library Health'|t('lens') }}</h2>
    </div>

    <div class="lens-coverage__metrics">
        {# Analysis Coverage — processing-aware for both editions #}
        {% if processingStats is defined %}
            {% set isProcessing = (processingStats.processing|default(0)) > 0 %}
            {% set analysisPercentage = processingStats.totalImages > 0 ? ((processingStats.analyzed / processingStats.totalImages) * 100)|round(1) : 0 %}
            {% set unanalyzed = processingStats.totalImages - processingStats.analyzed %}

            {# Link destination: Pro → bulk page, Lite → assets filter #}
            {% if isProcessing %}
                {% set linkUrl = lens.isPro ? cpUrl('lens/bulk') : cpUrl('assets', {source: 'lens:not-analysed'}) %}
                {% set linkText = lens.isPro ? 'View progress'|t('lens') : 'View assets'|t('lens') %}
            {% elseif unanalyzed > 0 %}
                {% set linkUrl = lens.isPro ? cpUrl('lens/bulk') : cpUrl('assets', {source: 'lens:not-analysed'}) %}
                {% set linkText = lens.isPro ? 'Bulk process'|t('lens') : 'View missing'|t('lens') %}
            {% else %}
                {% set linkUrl = null %}
                {% set linkText = null %}
            {% endif %}

            {% include 'lens/_dashboard/_coverage-metric' with {
                label: isProcessing ? 'Processing'|t('lens') : 'Analyzed'|t('lens'),
                percentage: analysisPercentage,
                covered: processingStats.analyzed,
                total: processingStats.totalImages,
                linkUrl: linkUrl,
                linkText: linkText,
                isProcessing: isProcessing,
            } only %}
        {% endif %}

        {# Review Coverage — only when review workflow is active #}
        {% if lens.isReviewActive and overviewStats is defined %}
            {% set reviewedCount = overviewStats.approved|default(0) %}
            {% set totalReviewable = (overviewStats.approved|default(0)) + (overviewStats.pendingReview|default(0)) %}
            {% set reviewPercentage = totalReviewable > 0 ? ((reviewedCount / totalReviewable) * 100)|round(1) : 0 %}

            {% include 'lens/_dashboard/_coverage-metric' with {
                label: 'Reviewed'|t('lens'),
                percentage: reviewPercentage,
                covered: reviewedCount,
                total: totalReviewable,
                linkUrl: cpUrl('lens/review'),
                linkText: 'Review queue'|t('lens'),
            } only %}
        {% endif %}

        {# Alt Text Coverage #}
        {% set altMissing = altTextCoverage.total - altTextCoverage.withAltText %}
        {% include 'lens/_dashboard/_coverage-metric' with {
            label: 'Alt Text'|t('lens'),
            percentage: altTextCoverage.percentage,
            covered: altTextCoverage.withAltText,
            total: altTextCoverage.total,
            linkUrl: altMissing > 0 ? (lens.isPro ? cpUrl('lens/search', {missingAltText: 1}) : cpUrl('assets', {source: 'lens:missing-alt-text'})) : null,
            linkText: 'View missing'|t('lens'),
        } only %}

        {# Tag Coverage #}
        {% if lens.isPro %}
            {% set tagMissing = taggedPercentage.total - taggedPercentage.withTags %}
            {% include 'lens/_dashboard/_coverage-metric' with {
                label: 'Tags'|t('lens'),
                percentage: taggedPercentage.percentage,
                covered: taggedPercentage.withTags,
                total: taggedPercentage.total,
                linkUrl: tagMissing > 0 ? cpUrl('lens/search', {unprocessed: 1}) : null,
                linkText: 'View missing'|t('lens'),
            } only %}
        {% endif %}

        {# Focal Point Coverage #}
        {% set fpMissing = focalPointCoverage.total - focalPointCoverage.withFocalPoint %}
        {% include 'lens/_dashboard/_coverage-metric' with {
            label: 'Focal Point'|t('lens'),
            percentage: focalPointCoverage.percentage,
            covered: focalPointCoverage.withFocalPoint,
            total: focalPointCoverage.total,
            linkUrl: fpMissing > 0 ? (lens.isPro ? cpUrl('lens/search', {hasFocalPoint: 0}) : cpUrl('assets', {source: 'lens:missing-focal-point'})) : null,
            linkText: 'View missing'|t('lens'),
        } only %}
    </div>
</div>

{% if processingStats is defined and (processingStats.processing|default(0)) > 0 %}
{% js %}
(function() {
    var grid = document.querySelector('.lens-coverage__metrics');
    if (!grid || !grid.querySelector('[data-lens-target="processing-metric"]')) return;

    var timer = setInterval(function() {
        Craft.sendActionRequest('GET', 'lens/dashboard/processing-status')
            .then(function(response) {
                var data = response.data;
                if (!data.success) return;

                var textEl = grid.querySelector('[data-lens-target="processing-text"]');
                if (textEl) {
                    textEl.innerHTML = data.percentComplete + '% <span class="lens-coverage__metric-counts">(' + data.completed + ' ' + Craft.t('lens', 'of') + ' ' + data.total + ')</span>';
                }

                var fillEl = grid.querySelector('[data-lens-target="processing-fill"]');
                if (fillEl) {
                    fillEl.style.width = data.percentComplete + '%';
                }

                if (data.processing === 0) {
                    clearInterval(timer);
                    window.location.reload();
                }
            })
            .catch(function() {});
    }, 5000);
})();
{% endjs %}
{% endif %}

{% endif %}
