{# Section 3: Metadata Coverage - only shows when assets have been analyzed #}
{% if altTextCoverage.total > 0 %}
<div class="lens-dashboard-section lens-coverage pane">
    <h2 class="lens-section-header__title">{{ 'Metadata Coverage'|t('lens') }}</h2>

    <div class="lens-coverage__metrics">
        {# Alt Text Coverage #}
        {% set altColor = altTextCoverage.percentage >= 66 ? 'var(--green-500)' : (altTextCoverage.percentage >= 33 ? 'var(--amber-400)' : 'var(--red-500)') %}
        <div class="lens-coverage__metric">
            <div class="lens-coverage__metric-header">
                <span class="lens-field-label">{{ 'Alt Text'|t('lens') }}</span>
                <span class="lens-coverage__metric-stat">
                    {{ altTextCoverage.percentage }}%
                    <span class="lens-coverage__metric-counts">({{ altTextCoverage.withAltText }} {{ 'of'|t('lens') }} {{ altTextCoverage.total }})</span>
                </span>
            </div>
            <div class="lens-coverage__metric-row">
                <div class="lens-progress">
                    <div class="lens-progress-fill" style="width: {{ altTextCoverage.percentage }}%; background-color: {{ altColor }}"></div>
                </div>
                {% if altTextCoverage.total - altTextCoverage.withAltText > 0 %}
                    <a href="{{ cpUrl('lens/search', {missingAltText: 1}) }}" class="lens-link">
                        {{ 'View missing'|t('lens') }} &rarr;
                    </a>
                {% endif %}
            </div>
        </div>

        {# Tag Coverage #}
        {% set tagColor = taggedPercentage.percentage >= 66 ? 'var(--green-500)' : (taggedPercentage.percentage >= 33 ? 'var(--amber-400)' : 'var(--red-500)') %}
        <div class="lens-coverage__metric">
            <div class="lens-coverage__metric-header">
                <span class="lens-field-label">{{ 'Tags'|t('lens') }}</span>
                <span class="lens-coverage__metric-stat">
                    {{ taggedPercentage.percentage }}%
                    <span class="lens-coverage__metric-counts">({{ taggedPercentage.withTags }} {{ 'of'|t('lens') }} {{ taggedPercentage.total }})</span>
                </span>
            </div>
            <div class="lens-coverage__metric-row">
                <div class="lens-progress">
                    <div class="lens-progress-fill" style="width: {{ taggedPercentage.percentage }}%; background-color: {{ tagColor }}"></div>
                </div>
                {% if taggedPercentage.total - taggedPercentage.withTags > 0 %}
                    <a href="{{ cpUrl('lens/search', {quickFilter: 'untagged'}) }}" class="lens-link">
                        {{ 'View untagged'|t('lens') }} &rarr;
                    </a>
                {% endif %}
            </div>
        </div>

        {# Quality (70%+ passing) #}
        {% set qualityColor = highQualityPercentage.percentage >= 66 ? 'var(--green-500)' : (highQualityPercentage.percentage >= 33 ? 'var(--amber-400)' : 'var(--red-500)') %}
        <div class="lens-coverage__metric">
            <div class="lens-coverage__metric-header">
                <span class="lens-field-label">{{ 'Quality'|t('lens') }}</span>
                <span class="lens-coverage__metric-stat">
                    {{ highQualityPercentage.percentage }}%
                    <span class="lens-coverage__metric-counts">({{ highQualityPercentage.highQuality }} {{ 'of'|t('lens') }} {{ highQualityPercentage.total }})</span>
                </span>
            </div>
            <div class="lens-coverage__metric-row">
                <div class="lens-progress">
                    <div class="lens-progress-fill" style="width: {{ highQualityPercentage.percentage }}%; background-color: {{ qualityColor }}"></div>
                </div>
                {% if highQualityPercentage.total - highQualityPercentage.highQuality > 0 %}
                    <a href="{{ cpUrl('lens/search', {qualityBelow: '0.7'}) }}" class="lens-link">
                        {{ 'View low quality'|t('lens') }} &rarr;
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endif %}
