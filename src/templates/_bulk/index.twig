{% extends '_layouts/cp' %}

{% set title = 'Bulk Processing'|t('lens') %}
{% set selectedSubnavItem = 'bulk' %}

{% block content %}
    <div class="lens-bulk-page">

        {# Stats Grid - Always visible #}
        <div class="lens-stats-grid">
            <div class="lens-stat-card">
                <div class="lens-stat-value">{{ stats.totalImages }}</div>
                <div class="lens-stat-label">{{ 'Total Images'|t('lens') }}</div>
            </div>
            <div class="lens-stat-card lens-stat-success">
                <div class="lens-stat-value">{{ stats.analyzed }}</div>
                <div class="lens-stat-label">{{ 'Analyzed'|t('lens') }}</div>
            </div>
            <div class="lens-stat-card lens-stat-warning">
                <div class="lens-stat-value">{{ stats.unprocessed }}</div>
                <div class="lens-stat-label">{{ 'Unprocessed'|t('lens') }}</div>
            </div>
            <div class="lens-stat-card">
                <div class="lens-stat-value">{{ stats.pendingReview }}</div>
                <div class="lens-stat-label">{{ 'Pending Review'|t('lens') }}</div>
            </div>
            <div class="lens-stat-card lens-stat-error">
                <div class="lens-stat-value">{{ stats.failed }}</div>
                <div class="lens-stat-label">{{ 'Failed'|t('lens') }}</div>
            </div>
        </div>

        {# Render only the current state #}
        {% if state == 'processing' %}
            {% include 'lens/_bulk/_state-processing' %}
        {% elseif state == 'complete' %}
            {% include 'lens/_bulk/_state-complete' %}
        {% else %}
            {% include 'lens/_bulk/_state-ready' %}
        {% endif %}

    </div>
{% endblock %}
