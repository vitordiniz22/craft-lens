{% extends '_layouts/cp' %}

{% set title = 'Bulk Processing'|t('lens') %}
{% set selectedSubnavItem = 'bulk' %}

{% block content %}
    {% set isConfigError = state == 'complete' and failureReasons is defined and failureReasons.hasConfigError %}

    <div class="lens-bulk-page">

        {# Stats Grid - Hidden when config error caused processing to fail #}
        {% if not isConfigError %}
            {% set _analyzedUrl    = cpUrl('lens/search', {status: 'completed,approved,pending_review'}) %}
            {% set _unprocessedUrl = cpUrl('lens/search', {unprocessed: '1'}) %}
            {% set _reviewUrl      = cpUrl('lens/search', {status: 'pending_review'}) %}
            {% set _failedUrl      = cpUrl('lens/search', {status: 'failed'}) %}

            <div class="lens-stats-grid">
                <div class="lens-metric-card lens-metric-card--stacked lens-metric-card--neutral" data-lens-stat="totalImages" data-lens-count="{{ stats.totalImages }}">
                    <div class="lens-metric-card__value" data-lens-target="stat-value">{{ stats.totalImages }}</div>
                    <div class="lens-metric-card__label">{{ 'Total Images'|t('lens') }}</div>
                </div>
                <a href="{{ _analyzedUrl }}" class="lens-metric-card lens-metric-card--stacked lens-metric-card--success" data-lens-stat="analyzed" data-lens-count="{{ stats.analyzed }}">
                    <div class="lens-metric-card__value" data-lens-target="stat-value">{{ stats.analyzed }}</div>
                    <div class="lens-metric-card__label">{{ 'Analyzed'|t('lens') }}</div>
                </a>
                <a href="{{ _unprocessedUrl }}" class="lens-metric-card lens-metric-card--stacked lens-metric-card--warning" data-lens-stat="unprocessed" data-lens-count="{{ stats.unprocessed }}">
                    <div class="lens-metric-card__value" data-lens-target="stat-value">{{ stats.unprocessed }}</div>
                    <div class="lens-metric-card__label">{{ 'Unprocessed'|t('lens') }}</div>
                </a>
                <a href="{{ _reviewUrl }}" class="lens-metric-card lens-metric-card--stacked lens-metric-card--info" data-lens-stat="pendingReview" data-lens-count="{{ stats.pendingReview }}">
                    <div class="lens-metric-card__value" data-lens-target="stat-value">{{ stats.pendingReview }}</div>
                    <div class="lens-metric-card__label">{{ 'Pending Review'|t('lens') }}</div>
                </a>
                <a href="{{ _failedUrl }}" class="lens-metric-card lens-metric-card--stacked lens-metric-card--error" data-lens-stat="failed" data-lens-count="{{ stats.failed }}">
                    <div class="lens-metric-card__value" data-lens-target="stat-value">{{ stats.failed }}</div>
                    <div class="lens-metric-card__label">{{ 'Failed'|t('lens') }}</div>
                </a>
            </div>
        {% endif %}

        {# Render only the current state #}
        {% if state == 'processing' %}
            {% include 'lens/_bulk/_state-processing' %}
        {% elseif state == 'complete' %}
            {% include 'lens/_bulk/_state-complete' %}
        {% else %}
            {% include 'lens/_bulk/_state-ready' %}
        {% endif %}

    </div>
{% endblock %}
