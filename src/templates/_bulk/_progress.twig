<div class="lens-progress-section">
    <div class="lens-progress lens-progress--animated">
        <div class="lens-progress-fill" style="width: {{ progress.percentComplete ?? 0 }}%"></div>
    </div>
    <div class="lens-progress-text">
        {{ progress.completed ?? 0 }} / {{ progress.total ?? 0 }}
        ({{ progress.percentComplete ?? 0 }}%)
    </div>
</div>

<div class="lens-progress-details light">
    <p>{{ queueInfo.jobDescription ?? 'Analyzing assets'|t('lens') }}</p>
    {% if session and session.actualCost is defined %}
        <p>{{ 'Cost so far:'|t('lens') }} <strong>${{ session.actualCost|number_format(4) }}</strong></p>
    {% endif %}
</div>
