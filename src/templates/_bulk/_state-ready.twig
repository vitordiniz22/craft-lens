{% set analyzedPercent = stats.totalImages > 0 ? ((stats.analyzed / stats.totalImages) * 100)|round(1) : 0 %}

<div class="pane">

    {% if volumes|length > 1 %}
        <div class="lens-bulk-volume-filter">
            <label for="volumeId" class="lens-field-label">{{ 'Filter by volume'|t('lens') }}</label>
            <select id="volumeId" class="text" data-lens-control="bulk-volume-select">
                <option value="">{{ 'All Volumes'|t('lens') }}</option>
                {% for volume in volumes %}
                    <option value="{{ volume.id }}" {% if selectedVolumeId == volume.id %}selected{% endif %}>
                        {{ volume.name }}
                    </option>
                {% endfor %}
            </select>
        </div>
    {% endif %}

    {# Coverage bar #}
    <div class="lens-coverage-bar">
        <div class="lens-coverage-bar__header">
            <span class="lens-field-label">{{ 'Library Coverage'|t('lens') }}</span>
            <span class="lens-coverage-bar__summary">
                {{ '{analyzed} of {total} analyzed ({percent}%)'|t('lens', {
                    analyzed: stats.analyzed|number_format,
                    total: stats.totalImages|number_format,
                    percent: analyzedPercent,
                }) }}
            </span>
        </div>
        <div class="lens-progress">
            <div class="lens-progress__fill" style="width: {{ analyzedPercent }}%"></div>
        </div>
    </div>

    {% if stats.totalImages == 0 %}
        {% set selectedVolume = selectedVolumeId ? volumes|filter(v => v.id == selectedVolumeId)|first : null %}
        {% set emptyDescription = selectedVolume
            ? 'There are no images in {volume} yet. Upload images to this volume to get started.'|t('lens', {volume: selectedVolume.name})
            : 'There are no images in your library yet. Upload images to get started.'|t('lens')
        %}

        <hr>

        {% include 'lens/_components/empty-state' with {
            heading: 'No Images Found'|t('lens'),
            description: emptyDescription,
        } only %}
    {% elseif stats.unprocessed == 0 and stats.failed == 0 %}
        {% set selectedVolume = selectedVolumeId ? volumes|filter(v => v.id == selectedVolumeId)|first : null %}
        {% set doneDescription = selectedVolume
            ? 'Every image in {volume} has been analyzed.'|t('lens', {volume: selectedVolume.name})
            : 'Every image across all volumes has been analyzed.'|t('lens')
        %}
        {% if autoProcessOnUpload is defined and autoProcessOnUpload %}
            {% set doneDescription = doneDescription ~ ' ' ~ 'New uploads will be analyzed automatically.'|t('lens') %}
        {% endif %}

        <hr>

        {% include 'lens/_components/empty-state' with {
            heading: 'All Assets Analyzed'|t('lens'),
            description: doneDescription,
        } only %}
    {% else %}

        <hr>

        {# Hero number #}
        {% if stats.unprocessed > 0 %}
            <div class="lens-ready-hero">
                <span class="lens-ready-hero__value">{{ stats.unprocessed|number_format }}</span>
                <span class="lens-ready-hero__label">{{ 'images ready for analysis'|t('lens') }}</span>
            </div>
        {% elseif stats.failed > 0 %}
            <div class="lens-ready-hero">
                <span class="lens-ready-hero__value lens-ready-hero__value--warning">{{ stats.failed|number_format }}</span>
                <span class="lens-ready-hero__label">{{ 'images failed analysis'|t('lens') }}</span>
            </div>
        {% endif %}

        {# Stats row: cost + model — shown for any actionable work #}
        {% if estimatedCost is defined and estimatedCost > 0 %}
            <div class="lens-stat-strip">
                <div class="lens-stat-strip__cell">
                    <div class="lens-stat-strip__icon">{{ iconSvg('coins')|attr({width: 16, height: 16, fill: 'currentColor'}) }}</div>
                    <div class="lens-stat-strip__value">${{ estimatedCost|number_format(estimatedCost < 0.01 ? 4 : 2) }}</div>
                    <div class="lens-stat-strip__label">{{ 'estimated cost'|t('lens') }}</div>
                </div>
                {% if costPerImage is defined and costPerImage > 0 %}
                    <div class="lens-stat-strip__cell">
                        <div class="lens-stat-strip__icon">{{ iconSvg('gauge')|attr({width: 16, height: 16, fill: 'currentColor'}) }}</div>
                        <div class="lens-stat-strip__value">${{ costPerImage|number_format(costPerImage < 0.01 ? 4 : 2) }}</div>
                        <div class="lens-stat-strip__label">{{ 'per image'|t('lens') }}</div>
                    </div>
                {% endif %}
                {% if modelName is defined and modelName %}
                    <div class="lens-stat-strip__cell">
                        <div class="lens-stat-strip__icon">{{ iconSvg('microchip')|attr({width: 16, height: 16, fill: 'currentColor'}) }}</div>
                        <div class="lens-stat-strip__value">{{ modelName }}</div>
                        <div class="lens-stat-strip__label">{{ 'model'|t('lens') }}</div>
                    </div>
                {% endif %}
            </div>
        {% endif %}

        {# Action buttons #}
        <div class="lens-complete-actions">
            {% if stats.unprocessed > 0 %}
                <form method="post">
                    {{ csrfInput() }}
                    {{ actionInput('lens/bulk/process') }}
                    {% if selectedVolumeId %}
                        <input type="hidden" name="volumeId" value="{{ selectedVolumeId }}">
                    {% endif %}
                    <button type="submit" class="btn submit" data-lens-action="bulk-submit">{{ 'Start Processing'|t('lens') }}</button>
                </form>
            {% endif %}
            {% if stats.failed > 0 %}
                <form method="post" class="lens-bulk-inline-form">
                    {{ csrfInput() }}
                    {{ actionInput('lens/bulk/retry-failed') }}
                    <button type="submit" class="btn{{ stats.unprocessed == 0 ? ' submit' : '' }}" data-lens-action="bulk-submit">
                        {{ 'Retry {count} Failed'|t('lens', {count: stats.failed|number_format}) }}
                    </button>
                </form>
            {% endif %}
        </div>

    {% endif %}
</div>
