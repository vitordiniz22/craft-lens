<div class="pane">

    {% if volumes|length > 1 %}
        <div class="field">
            <div class="heading">
                <label for="volumeId">{{ 'Volume'|t('lens') }}</label>
            </div>
            <div class="input">
                <select id="volumeId" class="text" data-lens-control="bulk-volume-select">
                    <option value="">{{ 'All Volumes'|t('lens') }}</option>
                    {% for volume in volumes %}
                        <option value="{{ volume.id }}" {% if selectedVolumeId == volume.id %}selected{% endif %}>
                            {{ volume.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <hr class="lens-bulk-divider">
    {% endif %}

    {% if stats.unprocessed == 0 and stats.failed == 0 %}
        {% set selectedVolume = selectedVolumeId ? volumes|filter(v => v.id == selectedVolumeId)|first : null %}
        {% set doneDescription = selectedVolume
            ? 'Every image in {volume} has been analyzed.'|t('lens', {volume: selectedVolume.name})
            : 'Every image across all volumes has been analyzed.'|t('lens')
        %}
        {% if autoProcessOnUpload is defined and autoProcessOnUpload %}
            {% set doneDescription = doneDescription ~ ' ' ~ 'New uploads will be analyzed automatically.'|t('lens') %}
        {% endif %}

        {% include 'lens/_components/empty-state' with {
            heading: 'All Assets Analyzed'|t('lens'),
            description: doneDescription,
        } only %}
    {% else %}
        <div class="lens-section-header">
            <h2 class="lens-section-header__title">{{ 'Process Assets'|t('lens') }}</h2>
        </div>

        <div class="lens-bulk-status">
            {% if stats.unprocessed > 0 %}
                <div class="lens-bulk-status__info">
                    <span class="lens-bulk-status__count">{{ stats.unprocessed|number_format }}</span> {{ 'images ready for analysis'|t('lens') }}
                    {% if estimatedCost is defined and estimatedCost > 0 %}
                        <span class="lens-processing__separator"> · </span>
                        <span class="lens-bulk-status__cost">{{ 'Est.'|t('lens') }} ${{ estimatedCost|number_format(4) }}</span>
                    {% endif %}
                </div>
            {% endif %}

            <div class="lens-actions__grid">
                {% if stats.unprocessed > 0 %}
                    <form method="post">
                        {{ csrfInput() }}
                        {{ actionInput('lens/bulk/process') }}
                        {% if selectedVolumeId %}
                            <input type="hidden" name="volumeId" value="{{ selectedVolumeId }}">
                        {% endif %}
                        <button type="submit" class="btn submit">{{ 'Start Processing'|t('lens') }}</button>
                    </form>
                {% endif %}

                {% if stats.failed > 0 %}
                    <form method="post">
                        {{ csrfInput() }}
                        {{ actionInput('lens/bulk/retry-failed') }}
                        <button type="submit" class="btn">{{ 'Retry {count} Failed'|t('lens', {count: stats.failed}) }}</button>
                    </form>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
