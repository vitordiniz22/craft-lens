{% set isConfigError = failureReasons is defined and failureReasons.hasConfigError %}

{% if isConfigError %}
    {# Configuration error: show error with CTA to settings + retry action #}
    <div class="pane">
        {% include 'lens/_components/inline-notice' with {
            type: 'error',
            title: 'Processing failed'|t('lens'),
            message: failureReasons.configErrorMessage,
            cta: {
                label: 'Go to Settings'|t('lens'),
                url: 'lens/settings',
                small: false,
            },
        } only %}

        <div class="lens-complete-actions">
            <form method="post" class="lens-bulk-inline-form">
                {{ csrfInput() }}
                {{ actionInput('lens/bulk/retry-failed') }}
                <button type="submit" class="btn submit">
                    {{ 'Retry Failed'|t('lens') }}
                </button>
            </form>

            <a href="{{ cpUrl('lens/bulk/dismiss') }}" class="btn">
                {{ 'Start Over'|t('lens') }}
            </a>
        </div>
    </div>
{% else %}
    {# Normal completion: show summary stats and actions #}
    <div class="pane">
        <div class="lens-complete-header">
            <span class="lens-complete-icon">{{ iconSvg('check') }}</span>
            <h2>{{ 'Processing Complete'|t('lens') }}</h2>
        </div>

        <div class="lens-complete-summary">
            <div class="lens-summary-grid">
                <div class="lens-summary-item">
                    <span class="lens-summary-value">{{ stats.analyzed }}</span>
                    <span class="lens-summary-label">{{ 'Analyzed'|t('lens') }}</span>
                </div>
                <div class="lens-summary-item lens-summary-warning">
                    <span class="lens-summary-value">{{ stats.failed }}</span>
                    <span class="lens-summary-label">{{ 'Failed'|t('lens') }}</span>
                </div>
                <div class="lens-summary-item">
                    <span class="lens-summary-value">{{ stats.pendingReview }}</span>
                    <span class="lens-summary-label">{{ 'Pending Review'|t('lens') }}</span>
                </div>
            </div>

            {% if session and session.actualCost is defined %}
                <p class="lens-total-cost">
                    {{ 'Total cost for this run:'|t('lens') }} <strong>${{ session.actualCost|number_format(4) }}</strong>
                </p>
            {% endif %}

            {% if failureReasons is defined and failureReasons.groups|length > 0 %}
                {% set groups = failureReasons.groups %}

                {% if groups|length == 1 %}
                    {# Single error type: one cohesive notice box with asset list inside #}
                    {% set group = groups[0] %}

                    <div class="lens-inline-notice lens-inline-notice--warning" data-lens-target="error-groups">
                        <div class="lens-notice-header">
                            <span class="lens-notice-icon">{{ iconSvg('triangle-exclamation') }}</span>
                            <h4 class="lens-notice-title">{{ 'Attention needed'|t('lens') }}</h4>
                        </div>

                        <div class="lens-notice-content">
                            {{ group.message }}
                        </div>

                        {% if group.assets|length > 0 %}
                            <div class="lens-error-asset-list">
                                {% for asset in group.assets %}
                                    <div class="lens-error-asset">
                                        {% if asset.editUrl %}
                                            <a href="{{ asset.editUrl }}" class="lens-error-asset-link">{{ asset.filename }}</a>
                                        {% else %}
                                            <span class="lens-error-asset-deleted">{{ 'Deleted asset (ID: {id})'|t('lens', {id: asset.id}) }}</span>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                                {% if group.hasMore > 0 %}
                                    <div class="lens-error-asset-more">
                                        {{ 'and {count} more'|t('lens', {count: group.hasMore}) }}
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                {% else %}
                    {# Multiple error types: grouped with expand/collapse #}
                    <div class="lens-error-groups" data-lens-target="error-groups">
                        <div class="lens-error-groups-header">
                            <span class="lens-notice-icon">{{ iconSvg('triangle-exclamation') }}</span>
                            <h4 class="lens-notice-title">{{ '{count} errors across {groups} error types'|t('lens', {count: failureReasons.totalFailed, groups: groups|length}) }}</h4>
                        </div>

                        {% for group in groups %}
                            <div class="lens-error-group" data-lens-target="error-group">
                                <button type="button" class="lens-error-group-header" data-lens-action="toggle-error-group">
                                    <span class="lens-error-group-toggle">{{ iconSvg('chevron-right') }}</span>
                                    <span class="lens-error-group-count">{{ group.count }}</span>
                                    <span class="lens-error-group-message">{{ group.message }}</span>
                                </button>

                                <div class="lens-error-group-detail" style="display: none;" data-lens-target="error-group-detail">
                                    {% if group.assets|length > 0 %}
                                        <div class="lens-error-asset-list">
                                            {% for asset in group.assets %}
                                                <div class="lens-error-asset">
                                                    {% if asset.editUrl %}
                                                        <a href="{{ asset.editUrl }}" class="lens-error-asset-link">{{ asset.filename }}</a>
                                                    {% else %}
                                                        <span class="lens-error-asset-deleted">{{ 'Deleted asset (ID: {id})'|t('lens', {id: asset.id}) }}</span>
                                                    {% endif %}
                                                </div>
                                            {% endfor %}
                                            {% if group.hasMore > 0 %}
                                                <div class="lens-error-asset-more">
                                                    {{ 'and {count} more'|t('lens', {count: group.hasMore}) }}
                                                </div>
                                            {% endif %}
                                        </div>
                                    {% else %}
                                        <div class="lens-error-no-assets">
                                            {{ 'Asset details unavailable.'|t('lens') }}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            {% endif %}
        </div>

        <div class="lens-complete-actions">
            {% if stats.pendingReview > 0 %}
                <a href="{{ cpUrl('lens/review') }}" class="btn submit">
                    {{ 'View Review Queue'|t('lens') }}
                </a>
            {% endif %}

            {% if stats.failed > 0 %}
                <form method="post" class="lens-bulk-inline-form">
                    {{ csrfInput() }}
                    {{ actionInput('lens/bulk/retry-failed') }}
                    <button type="submit" class="btn">
                        {{ 'Retry {count} Failed'|t('lens', {count: stats.failed}) }}
                    </button>
                </form>
            {% endif %}

            <a href="{{ cpUrl('lens/bulk/dismiss') }}" class="btn">
                {{ 'Start New Batch'|t('lens') }}
            </a>

            <a href="{{ cpUrl('lens/search') }}" class="btn">
                {{ 'Browse Assets'|t('lens') }}
            </a>
        </div>
    </div>
{% endif %}
