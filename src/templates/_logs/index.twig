{% extends '_layouts/cp' %}

{% set title = 'Logs'|t('lens') %}
{% set selectedSubnavItem = 'logs' %}

{% block content %}
    {# Filters #}
    <div class="lens-log-filters">
        <form method="get" action="{{ cpUrl('lens/logs') }}">
            <div class="select">
                <select name="level">
                    <option value="">{{ 'All Levels'|t('lens') }}</option>
                    {% for lvl in levels %}
                        <option value="{{ lvl }}" {{ filters.level == lvl ? 'selected' }}>{{ lvl|capitalize }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="select">
                <select name="category">
                    <option value="">{{ 'All Categories'|t('lens') }}</option>
                    {% for cat in categories %}
                        <option value="{{ cat }}" {{ filters.category == cat ? 'selected' }}>{{ cat|replace({'_': ' '})|title }}</option>
                    {% endfor %}
                </select>
            </div>

            <input type="text" name="assetId" class="text" value="{{ filters.assetId }}" placeholder="{{ 'Asset ID'|t('lens') }}" size="10">

            <button type="submit" class="btn submit">{{ 'Filter'|t('lens') }}</button>
            <a href="{{ cpUrl('lens/logs') }}" class="btn">{{ 'Reset'|t('lens') }}</a>
        </form>

        <div class="lens-log-filters-end">
            <form method="post">
                {{ csrfInput() }}
                {{ actionInput('lens/log/delete-all') }}
                <button type="submit" class="btn" data-lens-action="delete-all-logs">
                    {{ 'Delete All'|t('lens') }}
                </button>
            </form>
        </div>
    </div>

    {# Summary #}
    <div class="lens-log-summary">
        {{ '{total} log entries'|t('lens', {total: total}) }}
        {% if filters.level or filters.category or filters.assetId %}
            <span>({{ 'filtered'|t('lens') }})</span>
        {% endif %}
    </div>

    {% if logs|length %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>{{ 'Date'|t('lens') }}</th>
                    <th>{{ 'Level'|t('lens') }}</th>
                    <th>{{ 'Category'|t('lens') }}</th>
                    <th>{{ 'Message'|t('lens') }}</th>
                    <th>{{ 'Asset'|t('lens') }}</th>
                    <th>{{ 'Actions'|t('lens') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for log in logs %}
                    <tr data-lens-log-id="{{ log.id }}">
                        <td class="lens-log-date">
                            {{ log.dateCreated|date('Y-m-d H:i:s') }}
                        </td>
                        <td class="lens-log-level--{{ log.level }}">
                            <span class="status"></span>
                            <span class="lens-log-level-text">{{ log.level }}</span>
                        </td>
                        <td>
                            <span class="lens-log-category">{{ log.category|replace({'_': ' '})|title }}</span>
                        </td>
                        <td class="lens-log-message">
                            <span class="lens-log-message-text">{{ log.message|truncate(200) }}</span>
                        </td>
                        <td>
                            {% if log.assetId %}
                                {% set asset = craft.assets.id(log.assetId).one() %}
                                {% if asset %}
                                    <a href="{{ asset.cpEditUrl }}">{{ asset.filename|truncate(20) }}</a>
                                {% else %}
                                    <span class="lens-log-missing-asset">#{{ log.assetId }}</span>
                                {% endif %}
                            {% else %}
                                <span class="lens-log-placeholder">—</span>
                            {% endif %}
                        </td>
                        <td class="lens-log-actions">
                            {% if log.stackTrace or log.context or log.requestPayload or log.responsePayload %}
                                <button type="button" class="btn small" data-lens-action="toggle-log-detail" data-lens-detail-id="lens-detail-{{ log.id }}">
                                    {{ 'Details'|t('lens') }}
                                </button>
                            {% endif %}
                            {% if log.isRetryable %}
                                <form method="post" class="lens-log-inline-form">
                                    {{ csrfInput() }}
                                    {{ actionInput('lens/log/retry') }}
                                    {{ hiddenInput('logId', log.id) }}
                                    <button type="submit" class="btn small submit">{{ 'Retry'|t('lens') }}</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                    {% if log.stackTrace or log.context or log.requestPayload or log.responsePayload %}
                        <tr data-lens-detail-id="lens-detail-{{ log.id }}" class="lens-log-detail">
                            <td colspan="6" class="lens-log-detail-cell">
                                {% if log.stackTrace %}
                                    <div class="lens-log-detail-section">
                                        <strong>{{ 'Stack Trace'|t('lens') }}</strong>
                                        <pre class="lens-log-code-block lens-log-code-block--short">{{ log.stackTrace }}</pre>
                                    </div>
                                {% endif %}
                                {% if log.requestPayload %}
                                    <div class="lens-log-detail-section">
                                        <strong>{{ 'Request Payload'|t('lens') }}</strong>
                                        <pre class="lens-log-code-block">{{ log.requestPayload|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_SLASHES')) }}</pre>
                                    </div>
                                {% endif %}
                                {% if log.responsePayload %}
                                    <div class="lens-log-detail-section">
                                        <strong>{{ 'Response Payload'|t('lens') }}</strong>
                                        <pre class="lens-log-code-block">{{ log.responsePayload|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_SLASHES')) }}</pre>
                                    </div>
                                {% endif %}
                                {% if log.context %}
                                    <div class="lens-log-detail-section">
                                        <strong>{{ 'Context'|t('lens') }}</strong>
                                        <pre class="lens-log-code-block lens-log-code-block--short">{{ log.context|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_SLASHES')) }}</pre>
                                    </div>
                                {% endif %}
                            </td>
                        </tr>
                    {% endif %}
                {% endfor %}
            </tbody>
        </table>

        {# Pagination #}
        {% if pageInfo.totalPages > 1 %}
            {% include '_includes/pagination' with {
                pageInfo: pageInfo,
                itemLabel: 'log entry'|t('lens'),
                itemsLabel: 'log entries'|t('lens'),
            } %}
        {% endif %}
    {% else %}
        {% include 'lens/_components/empty-state' with {
            heading: 'No Log Entries'|t('lens'),
            description: 'Log entries will appear here as the plugin processes assets, makes API calls, and handles jobs.'|t('lens'),
            cta: {
                label: 'Go to Dashboard'|t('lens'),
                url: 'lens/dashboard'
            }
        } %}
    {% endif %}
{% endblock %}

