{#
 # Reusable asset card component for search results and review browse/bulk grids.
 #
 # Parameters:
 #   asset     - Craft Asset element
 #   analysis  - AssetAnalysisRecord or null (pre-loaded)
 #   tags      - array of tag records (pre-loaded), optional
 #   colors    - array of color records (pre-loaded), optional
 #   dupCount  - int (pre-loaded), optional
 #   linkUrl   - string (destination URL when card is clicked)
 #   showTags     - bool (default true)
 #   showColors   - bool (default true)
 #   showMeta     - bool (show confidence badge in browse/bulk cards, default false)
 #   avgConfidence - float (for browse/bulk mode confidence badge, optional)
 #   tagCount   - int (for browse/bulk mode tag count display, optional)
 #   checkable  - bool (bulk selection mode: renders checkbox instead of link, default false)
 #   analysisId - int (required when checkable=true, used as checkbox value)
 #}

{% set showTags = showTags ?? true %}
{% set showColors = showColors ?? true %}
{% set showMeta = showMeta ?? false %}
{% set tags = tags ?? [] %}
{% set colors = colors ?? [] %}
{% set dupCount = dupCount ?? 0 %}
{% set checkable = checkable ?? false %}
{% set analysisId = analysisId ?? null %}

{% if checkable %}
<label class="card lens-asset-card lens-asset-card--checkable"
       data-lens-target="result-card"
       data-lens-asset-id="{{ asset.id }}"
       data-lens-confidence="{{ avgConfidence ?? 0 }}">
    <input type="checkbox" name="ids[]" value="{{ analysisId }}"
           data-lens-control="bulk-checkbox">
    <div class="lens-result-preview">
        <div class="lens-asset-card__check-overlay">
            <span class="lens-asset-card__checkmark">&#10003;</span>
        </div>
        {% if asset.kind == 'image' %}
            <img src="{{ craft.app.assets.getThumbUrl(asset, 200, 200) }}" alt="{{ asset.title }}" loading="lazy">
        {% else %}
            <div class="lens-result-icon">
                {{ iconSvg('file-lines')|attr({width: 32, height: 32, fill: 'currentColor'}) }}
            </div>
        {% endif %}
    </div>
    <div class="lens-result-info">
        <span class="lens-result-title">{{ (analysis.suggestedTitle ?: asset.title)|truncate(30) }}</span>
        {% if showMeta %}
            <div class="lens-browse-card__meta">
                {% if analysis and analysis.status == lens.status.pendingReview %}
                    {% set avgConfidence = avgConfidence ?? 0 %}
                    {% if avgConfidence >= 0.8 %}
                        <span class="lens-confidence-badge lens-confidence-badge--high">{{ (avgConfidence * 100)|round }}%</span>
                    {% elseif avgConfidence >= 0.5 %}
                        <span class="lens-confidence-badge lens-confidence-badge--medium">{{ (avgConfidence * 100)|round }}%</span>
                    {% else %}
                        <span class="lens-confidence-badge lens-confidence-badge--low">{{ (avgConfidence * 100)|round }}%</span>
                    {% endif %}
                {% endif %}
                <span class="lens-tag-count">{{ tagCount ?? 0 }} {{ 'tags'|t('lens') }}</span>
            </div>
        {% endif %}
    </div>
</label>
{% else %}
<div class="card lens-asset-card" data-lens-target="result-card" data-lens-asset-id="{{ asset.id }}">
    <a href="{{ linkUrl }}" class="lens-result-preview" data-lens-target="result-link">
        {% if asset.kind == 'image' %}
            <img src="{{ craft.app.assets.getThumbUrl(asset, 200, 200) }}" alt="{{ asset.title }}" loading="lazy">
        {% else %}
            <div class="lens-result-icon">
                {{ iconSvg('file-lines')|attr({width: 32, height: 32, fill: 'currentColor'}) }}
            </div>
        {% endif %}

        {% if analysis %}
            {% if dupCount > 0 %}
                <span class="lens-duplicate-badge">
                    <span class="lens-badge lens-badge--small lens-badge--duplicate" title="{{ '{count} duplicate(s)'|t('lens', {count: dupCount}) }}">
                        {{ iconSvg('copy')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                        {{ dupCount }} {{ dupCount == 1 ? 'duplicate'|t('lens') : 'duplicates'|t('lens') }}
                    </span>
                </span>
            {% endif %}
            <div class="lens-result-overlay">
                {% if analysis.status == lens.status.pendingReview %}
                    <span class="lens-badge lens-badge--small lens-badge--info" title="{{ 'Pending Review'|t('lens') }}">
                        {{ iconSvg('eye')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                        {{ 'Review'|t('lens') }}
                    </span>
                {% endif %}
                {% if analysis.status == lens.status.failed %}
                    <span class="lens-badge lens-badge--small lens-badge--error">
                        {{ iconSvg('circle-xmark')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                        {{ 'Failed'|t('lens') }}
                    </span>
                {% endif %}
            </div>
        {% else %}
            <div class="lens-result-overlay">
                <span class="lens-badge lens-badge--small lens-badge--muted" title="{{ 'Not yet analyzed'|t('lens') }}">
                    {{ iconSvg('circle-exclamation')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                    {{ 'Unprocessed'|t('lens') }}
                </span>
            </div>
        {% endif %}
    </a>

    <div class="lens-result-info">
        <a href="{{ linkUrl }}" class="lens-result-title" title="{{ asset.filename }}">
            {{ asset.title|truncate(30) }}
        </a>

        {% if not analysis and asset.alt %}
            <p class="lens-result-native-alt">{{ asset.alt|truncate(80) }}</p>
        {% endif %}

        {% if analysis %}
            {% if (showTags and tags|length) or (showColors and colors|length) %}
                <div class="lens-result-meta">
                    {% if showTags and tags|length %}
                        <span class="lens-result-tags">
                            {%- for tag in tags|slice(0, 3) -%}
                                <a href="{{ cpUrl('lens/search', {tags: tag.tag}) }}">{{ tag.tag }}</a>
                                {%- if not loop.last %}, {% endif -%}
                            {%- endfor -%}
                            {%- if tags|length > 3 %} <span class="light">+{{ tags|length - 3 }}</span>{% endif -%}
                        </span>
                    {% endif %}
                    {% if showColors and colors|length %}
                        <span class="lens-result-colors">
                            {% for color in colors|slice(0, 5) %}
                                <span class="lens-swatch lens-swatch--sm" style="background-color: {{ color.hex }}" title="{{ color.hex }}"></span>
                            {% endfor %}
                        </span>
                    {% endif %}
                </div>
            {% endif %}
        {% endif %}

        {% if showMeta %}
            <div class="lens-browse-card__meta">
                {% if analysis and analysis.status == lens.status.pendingReview %}
                    {% set avgConfidence = avgConfidence ?? 0 %}
                    {% if avgConfidence >= 0.8 %}
                        <span class="lens-confidence-badge lens-confidence-badge--high">{{ (avgConfidence * 100)|round }}%</span>
                    {% elseif avgConfidence >= 0.5 %}
                        <span class="lens-confidence-badge lens-confidence-badge--medium">{{ (avgConfidence * 100)|round }}%</span>
                    {% else %}
                        <span class="lens-confidence-badge lens-confidence-badge--low">{{ (avgConfidence * 100)|round }}%</span>
                    {% endif %}
                {% endif %}
                <span class="lens-tag-count">{{ tagCount ?? 0 }} {{ 'tags'|t('lens') }}</span>
            </div>
        {% endif %}
    </div>
</div>
{% endif %}
