{#
 # AI Analysis Panel — Interactive Asset Intelligence Hub
 # Field layout element for asset detail views.
 # Sections with inline editing, tag/color editors, and provenance tracking.
 #
 # Expected variables:
 #   asset, analysis, settings, isAutoGeneratedTitle, static,
 #   analysisTags, analysisColors, similarImages, siteContent
 #}

{% set hasSafetyFlags = analysis and (analysis.containsPeople or analysis.isFlaggedNsfw or (analysis.nsfwScore is defined and analysis.nsfwScore >= 0.2) or analysis.hasWatermark or (analysis.containsBrandLogo and analysis.detectedBrands|length)) %}

{# Editing is locked when static (Craft preview) or when asset is pending review #}
{% set readOnly = (static ?? false) or (analysis and analysis.status == lens.status.pendingReview and lens.isReviewActive) %}

{# Processing state detection #}
{% set isProcessing = analysis and analysis.status == lens.status.processing %}

{# Unified field state: readonly (no editing), unlocked (edit pencil + save/cancel), editing (review page) #}
{% set fieldState = (readOnly or isProcessing) ? 'readonly' : 'unlocked' %}
{% set hideConfidence = analysis is not null and (
    isProcessing
    or analysis.status in [lens.status.completed, lens.status.approved]
    or (not lens.isReviewActive and analysis.status == lens.status.pendingReview)
) %}
{% set hasExistingData = analysis and (
    analysis.suggestedTitle or
    analysis.altText or
    analysis.longDescription or
    analysisTags|length or
    analysisColors|length
) %}
{% set isReprocessing = isProcessing and hasExistingData %}

{% set displayStatus = analysis ? analysis.status : 'not_found' %}
{% if not lens.isReviewActive and displayStatus in [lens.status.pendingReview, lens.status.approved, lens.status.rejected] %}
    {% set displayStatus = lens.status.completed %}
{% endif %}
<div class="lens-analysis-panel{% if isProcessing %} lens-analysis-panel--processing{% endif %}" data-lens-target="analysis-panel" data-lens-asset-id="{{ asset.id }}" data-lens-analysis-status="{{ displayStatus }}">

    {% set isSecondarySite = currentSiteId != (primarySiteId ?? craft.app.sites.primarySite.id) %}

    {# Templates for dynamically inserted elements — cloned by JS #}
    {% if fieldState is defined and fieldState == 'unlocked' %}
        <template data-lens-target="lock-template">
            {% include 'lens/_components/analysis/_tooltip-lock' only %}
        </template>
        <template data-lens-target="applied-template">
            <span class="lens-applied-indicator">
                <span class="status on"></span>
                <span class="smalltext" data-lens-target="applied-label">{{ 'Applied'|t('lens') }}</span>
            </span>
        </template>
    {% endif %}

    {% include 'lens/_components/analysis/header' with {analysis: analysis, asset: asset, static: readOnly} %}

    {% if isSecondarySite and analysis %}
        {% set primarySite = craft.app.sites.getSiteById(primarySiteId) %}
        {% include 'lens/_components/inline-notice' with {
            type: 'info',
            title: 'Viewing Translations'|t('lens'),
            message: 'Showing translated title and alt text for this site. View the full analysis on the primary site ({siteName}).'|t('lens', {siteName: primarySite.name ?? 'primary'}),
        } %}
    {% endif %}

    {% if not isSecondarySite %}
        {# Processing banner — always rendered, shown/hidden via data attribute #}
        {% include 'lens/_components/analysis/processing-banner' with {
            isReprocessing: isReprocessing,
            hasExistingData: hasExistingData,
            isVisible: isProcessing
        } %}

        {# ============================================ #}
        {# ERROR DISPLAY - MOVED TO TOP FOR VISIBILITY #}
        {# ============================================ #}
        {% if analysis %}
            {% set errorMessage = analysis.analysisContent.errorMessage ?? null %}
            {% if analysis.status == lens.status.failed and errorMessage %}
                {% embed 'lens/_components/inline-notice' with {
                    type: 'error',
                    title: 'Analysis Failed'|t('lens'),
                    message: errorMessage,
                } %}
                    {% block action %}
                        <div class="lens-inline-notice__action">
                            <button type="button" class="btn small" data-lens-action="analyze" data-lens-asset-id="{{ asset.id }}" data-lens-loading-text="{{ 'Processing'|t('lens') }}">
                                <div class="spinner small"></div>
                                <span class="label" data-lens-target="button-label">{{ 'Try Again'|t('lens') }}</span>
                            </button>
                        </div>
                    {% endblock %}
                {% endembed %}
            {% elseif analysis.status != lens.status.failed and errorMessage %}
                {% embed 'lens/_components/inline-notice' with {
                    type: 'warning',
                    title: 'Re-analysis Failed'|t('lens'),
                    message: errorMessage ~ ' ' ~ ('Your previous analysis data is still available below.'|t('lens')),
                } %}
                    {% block action %}
                        <div class="lens-inline-notice__action">
                            <button type="button" class="btn small" data-lens-action="analyze" data-lens-asset-id="{{ asset.id }}" data-lens-loading-text="{{ 'Processing'|t('lens') }}">
                                <div class="spinner small"></div>
                                <span class="label" data-lens-target="button-label">{{ 'Try Again'|t('lens') }}</span>
                            </button>
                        </div>
                    {% endblock %}
                {% endembed %}
            {% endif %}
        {% endif %}
    {% endif %}

    {% if analysis %}
        {% if not isSecondarySite %}
            {# Pending review notice #}
            {% if analysis.status == lens.status.pendingReview and not (static ?? false) and lens.isReviewActive %}
                {% include 'lens/_components/inline-notice' with {
                    type: 'warning',
                    title: 'Pending Review'|t('lens'),
                    message: 'This analysis is awaiting review. All data shown is provisional and may be edited after approval or rejection.'|t('lens'),
                    cta: {
                        label: 'Review now'|t('lens'),
                        url: 'lens/review/' ~ analysis.id,
                        small: false,
                        submit: true
                    }
                } %}
            {% endif %}

            {# Similar Assets notice — shown prominently when duplicates detected #}
            {% if analysis.status not in [lens.status.failed] and (not isProcessing or isReprocessing) and (similarImages ?? [])|length %}
                {% include 'lens/_components/analysis/similar-assets-notice' with {
                    similarImages: similarImages,
                    totalSimilarCount: totalSimilarCount ?? similarImages|length,
                    asset: asset,
                    static: static ?? false,
                    isProcessing: isProcessing
                } %}
            {% endif %}
        {% endif %}

        {# Pending state — analysis queued but not yet processed #}
        {% if analysis.status == lens.status.pending %}
            {% include 'lens/_components/inline-notice' with {
                type: 'info',
                title: 'Awaiting Analysis'|t('lens'),
                message: 'This image is queued for analysis. Results will appear here once processing is complete.'|t('lens'),
            } %}
        {% endif %}

        {# Section 1: Description (title/alt — shown on all sites, description hidden on secondary) #}
        {% if analysis.status not in [lens.status.pending, lens.status.failed] and (not isProcessing or isReprocessing) %}
            <div class="lens-section" data-lens-target="section">
                {% include 'lens/_components/analysis/_section-header' with {
                    title: 'Description'|t('lens'),
                    intro: 'Ready-to-use metadata for accessibility and search.'|t('lens')
                } only %}
                <div class="lens-section-body">
                    {% include 'lens/_components/analysis/content-section' with {
                        analysis: analysis,
                        assetTitle: asset.title ?? '',
                        assetAlt: assetAlt ?? '',
                        isAutoGeneratedTitle: isAutoGeneratedTitle,
                        isAltEmpty: isAltEmpty ?? true,
                        altFieldInLayout: altFieldInLayout ?? true,
                        fieldState: fieldState,
                        siteContent: siteContent ?? [],
                        isAltTranslatable: isAltTranslatable ?? false,
                        isTitleTranslatable: isTitleTranslatable ?? false,
                        currentSiteId: currentSiteId ?? craft.app.sites.primarySite.id,
                        primarySiteId: primarySiteId ?? craft.app.sites.primarySite.id,
                        isSecondarySite: isSecondarySite
                    } %}
                </div>
            </div>
        {% endif %}

        {# Sections 2-5: primary site only #}
        {% if not isSecondarySite %}
            {# Section 2: Taxonomy #}
            {% if lens.isPro and analysis.status not in [lens.status.pending, lens.status.failed] and (not isProcessing or isReprocessing) %}
                <div class="lens-section" data-lens-target="taxonomy-section">
                    {% include 'lens/_components/analysis/_section-header' with {
                        title: 'Taxonomy'|t('lens'),
                        intro: (readOnly or isProcessing)
                            ? 'AI-generated tags and colors for categorization.'|t('lens')
                            : 'AI-generated tags and colors. Use the edit button to add or remove.'|t('lens')
                    } only %}
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/taxonomy-section' with {
                            analysis: analysis, analysisTags: analysisTags,
                            analysisColors: analysisColors,
                            fieldState: fieldState
                        } %}
                    </div>
                </div>
            {% endif %}

            {# Section 3: Image Assessment #}
            {% if analysis.status not in [lens.status.pending, lens.status.failed] and (not isProcessing or isReprocessing) %}
                {% set wrStatus = (webReadiness ?? {}).overallStatus ?? 'pass' %}
                {% set hasQualityWarning = false %}
                {% set hasQualityError = false %}
                {% for metric in (qualityMetrics ?? []) %}
                    {% if metric.status == 'error' %}{% set hasQualityError = true %}{% endif %}
                    {% if metric.status == 'warning' %}{% set hasQualityWarning = true %}{% endif %}
                {% endfor %}
                {% set qualityBadge = (wrStatus == 'error' or hasQualityError) ? 'error'
                    : ((wrStatus == 'warning' or hasQualityWarning) ? 'warning' : null) %}
                <div class="lens-section">
                    {% include 'lens/_components/analysis/_section-header' with {
                        title: 'Image Assessment'|t('lens'),
                        intro: 'Technical checks to ensure your image is web-ready.'|t('lens'),
                        badge: qualityBadge
                    } only %}
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/quality-section' with {
                            analysis: analysis, asset: asset,
                            fieldState: fieldState,
                            webReadiness: webReadiness ?? {issues: [], checks: {}},
                            qualityMetrics: qualityMetrics ?? {}
                        } %}
                    </div>
                </div>
            {% endif %}

            {# Section 4: Content Safety #}
            {% if analysis.status not in [lens.status.pending, lens.status.failed] and (not isProcessing or isReprocessing) %}
                {% set safetyBadge = analysis.isFlaggedNsfw ? 'error'
                    : ((analysis.nsfwScore is defined and analysis.nsfwScore >= 0.2) ? 'warning' : null) %}
                <div class="lens-section">
                    {% include 'lens/_components/analysis/_section-header' with {
                        title: 'Flags & Detection'|t('lens'),
                        intro: 'Safety signals to help guide editorial decisions.'|t('lens'),
                        badge: safetyBadge
                    } only %}
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/safety-section' with {
                            analysis: analysis,
                            fieldState: fieldState
                        } %}
                    </div>
                </div>
            {% endif %}

            {# Section 5: Extracted Text #}
            {% if lens.isPro and analysis.status not in [lens.status.pending, lens.status.failed] and (not isProcessing or isReprocessing) %}
                <div class="lens-section">
                    {% include 'lens/_components/analysis/_section-header' with {
                        title: 'Extracted Text'|t('lens'),
                        intro: 'Text detected within the image via OCR.'|t('lens')
                    } only %}
                    <div class="lens-section-body">
                        {% include 'lens/_components/analysis/editable-field' with {
                            fieldName: 'extractedText',
                            label: 'Extracted Text'|t('lens'),
                            value: analysis.extractedText,
                            aiValue: analysis.extractedTextAi,
                            confidence: null,
                            inputType: 'textarea',
                            featured: false,
                            analysisId: analysis.id,
                            fieldState: fieldState,
                            nullAiIsValid: true,
                            emptyText: 'No text detected'|t('lens')
                        } %}
                    </div>
                </div>
            {% endif %}
        {% endif %}


    {% else %}
        {% if lens.hasCriticalIssues() %}
            {% set criticalIssues = lens.getCriticalIssues() %}
            {% if criticalIssues|length > 0 %}
                {% include 'lens/_components/inline-notice' with {
                    type: 'error',
                    title: 'Configuration required'|t('lens'),
                    message: criticalIssues[0].message,
                    cta: {
                        label: criticalIssues[0].actionLabel,
                        url: criticalIssues[0].actionUrl
                    }
                } %}
            {% endif %}
        {% else %}
            <div class="lens-empty-analysis" data-lens-target="empty-analysis">
                <p class="light">{{ 'This image has not been analyzed yet.'|t('lens') }}</p>

                {% if not static %}
                    <button type="button" class="btn submit" data-lens-action="analyze" data-lens-asset-id="{{ asset.id }}">
                        {{ 'Analyze Now'|t('lens') }}
                    </button>
                {% endif %}
            </div>
        {% endif %}
    {% endif %}
</div>
