{#
 # AI Analysis Panel — Interactive Asset Intelligence Hub
 # Field layout element for asset detail views.
 # Sections with inline editing, tag/color editors, and provenance tracking.
 #
 # Expected variables:
 #   asset, analysis, settings, isAutoGeneratedTitle, static,
 #   analysisTags, analysisColors, exifData, similarImages
 #}

{% set hasSafetyFlags = analysis and (analysis.containsPeople or analysis.isFlaggedNsfw or analysis.hasWatermark or (analysis.containsBrandLogo and analysis.detectedBrands|length)) %}
{% set hasExif = exifData is defined and exifData %}
{% set hasSimilar = similarImages is defined and similarImages|length %}

{# Editing is locked when static (Craft preview) or when asset is pending review #}
{% set readOnly = (static ?? false) or (analysis and analysis.status == 'pending_review') %}

{# Processing state detection #}
{% set isProcessing = analysis and analysis.status == 'processing' %}
{% set hasExistingData = analysis and (
    analysis.suggestedTitle or
    analysis.altText or
    analysis.longDescription or
    analysisTags|length or
    analysisColors|length
) %}
{% set isReprocessing = isProcessing and hasExistingData %}

<div class="lens-analysis-panel" data-asset-id="{{ asset.id }}"{% if analysis %} data-analysis-id="{{ analysis.id }}" data-analysis-status="{{ analysis.status }}"{% endif %}>

    {# Header: Status + Re-analyze + Meta + Cost #}
    {% include 'lens/_components/analysis/header' with {analysis: analysis, asset: asset, static: readOnly} %}

    {# Processing banner #}
    {% if isProcessing %}
        {% include 'lens/_components/analysis/processing-banner' with {
            isReprocessing: isReprocessing,
            hasExistingData: hasExistingData
        } %}
    {% endif %}

    {# ============================================ #}
    {# ERROR DISPLAY - MOVED TO TOP FOR VISIBILITY #}
    {# ============================================ #}
    {% if analysis %}
        {% set errorMessage = analysis.analysisContent.errorMessage ?? null %}
        {% if analysis.status == 'failed' and errorMessage %}
            <div class="lens-error-notice" style="margin-top: var(--m);">
                <div class="lens-error-header">
                    <svg class="lens-error-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10 18C14.4183 18 18 14.4183 18 10C18 5.58172 14.4183 2 10 2C5.58172 2 2 5.58172 2 10C2 14.4183 5.58172 18 10 18Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M10 6V10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M10 14H10.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <strong>{{ 'Analysis Failed'|t('lens') }}</strong>
                </div>

                <p class="lens-error-message">{{ errorMessage }}</p>

                {# Provide helpful suggestions based on error type #}
                {% if 'too large' in errorMessage|lower %}
                    <div class="lens-error-suggestion">
                        <strong>{{ 'Suggestions'|t('lens') }}:</strong>
                        <ul>
                            <li>{{ 'Resize the image to a smaller resolution'|t('lens') }}</li>
                            <li>{{ 'Compress the image to reduce file size'|t('lens') }}</li>
                            {% if settings.aiProvider == 'claude' %}
                                <li>{{ 'Switch to OpenAI or Gemini (they support larger files up to 15MB)'|t('lens') }} - <a href="{{ cpUrl('lens/settings') }}">{{ 'Change provider'|t('lens') }}</a></li>
                            {% endif %}
                        </ul>
                    </div>
                {% elseif 'not configured' in errorMessage or 'is invalid' in errorMessage or 'API key' in errorMessage %}
                    <div class="lens-error-suggestion">
                        <strong>{{ 'Action Required'|t('lens') }}:</strong>
                        <p><a href="{{ cpUrl('lens/settings#provider') }}" class="btn small">{{ 'Configure API Settings'|t('lens') }}</a></p>
                    </div>
                {% endif %}

                <div class="lens-error-actions">
                    <button type="button" class="btn small" data-lens-analyze="{{ asset.id }}">
                        {{ 'Try Again'|t('lens') }}
                    </button>
                </div>
            </div>
        {% endif %}
    {% endif %}

    {% if analysis %}
        {# Pending review notice #}
        {% if analysis.status == 'pending_review' and not (static ?? false) %}
            <div class="lens-pending-notice lens-alert-section lens-alert-section--warning">
                <div class="lens-pending-notice-content">
                    <div class="flex items-center gap-s mb-xs">
                        <span class="lens-pending-icon">{{ iconSvg('circle-exclamation') }}</span>
                        <strong>{{ 'Pending Review'|t('lens') }}</strong>
                    </div>
                    <p class="smalltext" style="margin: 0">
                        {{ 'This analysis is awaiting review. All data shown is provisional and may be edited after approval or rejection.'|t('lens') }}
                        <a href="{{ cpUrl('lens/review/' ~ analysis.id) }}" class="lens-review-link">{{ 'Review now'|t('lens') }}</a>
                    </p>
                </div>
            </div>
        {% endif %}

        {# Section 1: Content Metadata #}
        {% if (analysis.suggestedTitle or analysis.altText or analysis.longDescription) and analysis.status not in ['failed', 'processing'] %}
            <div class="lens-section">
                <div class="lens-section-header">
                    <span class="lens-section-title">{{ 'Content'|t('lens') }}</span>
                </div>
                <div class="lens-section-body">
                    {% include 'lens/_components/analysis/content-section' with {
                        analysis: analysis, asset: asset,
                        isAutoGeneratedTitle: isAutoGeneratedTitle, static: readOnly,
                        isProcessing: isProcessing
                    } %}
                </div>
            </div>
        {% endif %}

        {# Section 2: Taxonomy #}
        {% if (analysisTags|length or analysisColors|length or not readOnly) and analysis.status not in ['failed', 'processing'] %}
            <div class="lens-section">
                <div class="lens-section-header">
                    <span class="lens-section-title">
                        {{ 'Taxonomy'|t('lens') }}
                        {% if analysisTags|length %}
                            <span class="badge">{{ analysisTags|length }}</span>
                        {% endif %}
                    </span>
                </div>
                <div class="lens-section-body">
                    {% include 'lens/_components/analysis/taxonomy-section' with {
                        analysis: analysis, analysisTags: analysisTags,
                        analysisColors: analysisColors, static: readOnly,
                        isProcessing: isProcessing
                    } %}
                </div>
            </div>
        {% endif %}

        {# Section 3: Focal Point & Quality #}
        {% if ((analysis.focalPointX is not null) or (analysis.overallQualityScore is not null)) and analysis.status not in ['failed', 'processing'] %}
            <div class="lens-section">
                <div class="lens-section-header">
                    <span class="lens-section-title">
                        {{ 'Visual Analysis'|t('lens') }}
                        {% if analysis.overallQualityScore is not null %}
                            <span class="lens-badge lens-badge--{{ analysis.overallQualityScore >= 0.7 ? 'success' : (analysis.overallQualityScore >= 0.4 ? 'warning' : 'error') }}">
                                {{ (analysis.overallQualityScore * 100)|round }}%
                            </span>
                        {% endif %}
                    </span>
                </div>
                <div class="lens-section-body">
                    {% include 'lens/_components/analysis/quality-section' with {
                        analysis: analysis, asset: asset, static: readOnly,
                        isProcessing: isProcessing
                    } %}
                </div>
            </div>
        {% endif %}

        {# Section 4: Content Safety #}
        {% if (hasSafetyFlags or (analysis.nsfwScore is defined and analysis.nsfwScore > 0)) and analysis.status not in ['failed', 'processing'] %}
            <div class="lens-section">
                <div class="lens-section-header">
                    <span class="lens-section-title">
                        {{ 'Content Safety'|t('lens') }}
                        {% if hasSafetyFlags %}
                            <span class="lens-badge lens-badge--error">!</span>
                        {% endif %}
                    </span>
                </div>
                <div class="lens-section-body">
                    {% include 'lens/_components/analysis/safety-section' with {
                        analysis: analysis, static: readOnly,
                        isProcessing: isProcessing
                    } %}
                </div>
            </div>
        {% endif %}

        {# Section 5: Extracted Text #}
        {% if analysis.extractedText and analysis.status not in ['failed', 'processing'] %}
            <div class="lens-section">
                <div class="lens-section-header">
                    <span class="lens-section-title">{{ 'OCR'|t('lens') }}</span>
                </div>
                <div class="lens-section-body">
                    {% include 'lens/_components/analysis/editable-field' with {
                        fieldName: 'extractedText',
                        label: 'Extracted Text'|t('lens'),
                        value: analysis.extractedText,
                        aiValue: analysis.extractedTextAi,
                        confidence: null,
                        editedBy: analysis.extractedTextEditedBy,
                        editedAt: analysis.extractedTextEditedAt,
                        inputType: 'textarea',
                        featured: false,
                        static: readOnly,
                        analysisId: analysis.id,
                        isProcessing: isProcessing
                    } %}
                </div>
            </div>
        {% endif %}

        {# Section 6: Technical Info #}
        {% if hasExif %}
            <div class="lens-section">
                <div class="lens-section-header">
                    <span class="lens-section-title">{{ 'Technical Info'|t('lens') }}</span>
                </div>
                <div class="lens-section-body">
                    {% include 'lens/_components/analysis/technical-section' with {
                        analysis: analysis, exifData: exifData
                    } %}
                </div>
            </div>
        {% endif %}

        {# Section 7: Similar Assets #}
        {% if hasSimilar %}
            <div class="lens-section">
                <div class="lens-section-header">
                    <span class="lens-section-title">{{ 'Similar Assets'|t('lens') }}</span>
                </div>
                <div class="lens-section-body">
                    {% include 'lens/_components/analysis/relationships-section' with {
                        similarImages: similarImages ?? [],
                        asset: asset, static: readOnly,
                        isProcessing: isProcessing
                    } %}
                </div>
            </div>
        {% endif %}

    {% else %}
        {# No analysis state #}
        {% if lens.hasCriticalIssues() %}
            {% set criticalIssues = lens.getCriticalIssues() %}
            {% if criticalIssues|length > 0 %}
                {% include 'lens/_components/inline-notice' with {
                    type: 'error',
                    title: 'Configuration required'|t('lens'),
                    message: criticalIssues[0].message,
                    cta: {
                        label: criticalIssues[0].actionLabel,
                        url: criticalIssues[0].actionUrl
                    }
                } %}
            {% endif %}
        {% else %}
            <p class="light">{{ 'This image has not been analyzed yet.'|t('lens') }}</p>
            {% if not static %}
                <button type="button" class="btn submit" data-lens-analyze="{{ asset.id }}">
                    {{ 'Analyze Now'|t('lens') }}
                </button>
            {% endif %}
        {% endif %}
    {% endif %}
</div>
