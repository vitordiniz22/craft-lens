{#
 # Inline Notice component - Contextual notices for warnings, errors, info, tips
 #
 # Usage (include — simple text notices):
 #   {% include 'lens/_components/inline-notice' with {type: 'warning', message: 'Text'} %}
 #
 # Usage (embed — custom body content):
 #   {% embed 'lens/_components/inline-notice' with {type: 'info', title: 'Custom'} %}
 #       {% block body %}<div>Custom HTML</div>{% endblock %}
 #   {% endembed %}
 #
 # Parameters:
 #   - type: 'error', 'warning', or 'info' (required)
 #   - title: (optional) Notice title/heading
 #   - message: Notice message text (required for include, optional for embed with body override)
 #   - icon: (optional) Override icon name, or false to hide icon entirely
 #   - cta: (optional) Object with 'label' and 'url' for call-to-action button
 #       - cta.small: (optional) Whether button is small, defaults to true
 #       - cta.submit: (optional) Whether button uses submit (red) style, defaults to true for error type
 #   - docsUrl: (optional) External documentation URL. Renders a secondary "Learn more" text link after the CTA; opens in a new tab.
 #   - docsLabel: (optional) Override text for the docs link, defaults to "Learn more"
 #   - attr: (optional) Additional HTML attributes as key/value pairs for the wrapper div
 #}

{% set iconMap = {
    'error': 'circle-exclamation',
    'warning': 'triangle-exclamation',
    'info': 'circle-info'
} %}

{% set titleMap = {
    'error': 'Configuration required'|t('lens'),
    'warning': 'Attention needed'|t('lens'),
    'info': 'Information'|t('lens')
} %}

{% set resolvedIcon = icon is defined ? icon : (iconMap[type] ?? false) %}

<div class="lens-inline-notice lens-inline-notice--{{ type }}"
     {% for key, value in (attr ?? {}) %}{{ key }}="{{ value }}"{% endfor %}>

    {% block header %}
        <div class="lens-inline-notice__header">
            {% if resolvedIcon is not same as(false) %}
                <span class="lens-inline-notice__icon">{{ iconSvg(resolvedIcon) }}</span>
            {% endif %}
            <h4 class="lens-inline-notice__title">{{ title ?? titleMap[type] }}</h4>
        </div>
    {% endblock %}

    {% block body %}
        {% if message ?? false %}
            <div class="lens-inline-notice__content">
                {{ message }}
            </div>
        {% endif %}
    {% endblock %}

    {% block action %}
        {% if (cta ?? false) or (docsUrl ?? false) %}
            <div class="lens-inline-notice__action">
                {% if docsUrl ?? false %}
                    <a href="{{ docsUrl }}" target="_blank" rel="noopener" class="lens-inline-notice__docs">
                        {{ docsLabel ?? 'Learn more'|t('lens') }}
                    </a>
                {% endif %}
                {% if cta ?? false %}
                    <a href="{{ cpUrl(cta.url) }}" class="btn{{ (cta.small ?? true) ? ' small' : '' }}{{ (cta.submit ?? (type == 'error')) ? ' submit' : '' }}">
                        {{ cta.label }}
                    </a>
                {% endif %}
            </div>
        {% endif %}
    {% endblock %}

</div>
