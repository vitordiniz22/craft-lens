<div class="lens-upgrade-banner">
    <div class="lens-upgrade-banner__content">
        <div class="lens-upgrade-banner__icon">
            {{ svg(craft.app.plugins.getPlugin('lens').basePath ~ '/icon.svg')|attr({width: 36, height: 36}) }}
        </div>
        <div class="lens-upgrade-banner__text">
            <h2 class="lens-section-header__title">{{ 'Unlock the full power of Lens'|t('lens') }}</h2>
            <p class="lens-upgrade-banner__subtitle">{{ 'Everything in Lite, plus:'|t('lens') }}</p>
        </div>
    </div>
    <ul class="lens-upgrade-banner__features">
        <li>{{ 'Every image gets semantic tags and OCR text extraction. Both are indexed for search.'|t('lens') }}</li>
        <li>{{ "Craft's asset search matches on Lens descriptions, tags, and extracted text. Same in every asset picker. Eight new condition filters too."|t('lens') }}</li>
        <li>{{ 'Run Lens analysis on every image in a volume at once. Live progress, live cost estimate, retry any failures.'|t('lens') }}</li>
        <li>{{ 'Duplicate and near-duplicate detection across your whole library.'|t('lens') }}</li>

        <li>{{ 'See what AI has cost you: by provider, by asset, by month.'|t('lens') }}</li>
    </ul>
    <a href="https://plugins.craftcms.com/lens" class="btn submit" target="_blank">
        {{ 'Upgrade to Pro'|t('lens') }}
    </a>
</div>
