{#
 # Setup Banner component - Shows setup status and configuration requirements
 # Usage: {% include 'lens/_components/setup-banner' with {checks: checks, title: title, description: description} %}
 #
 # Parameters:
 #   - checks: array of setup check objects from SetupStatusService
 #   - title: (optional) Banner title, defaults to "Setup Required"
 #   - description: (optional) Banner description
 #   - showIcon: (optional) Whether to show the header icon, defaults to true
 #}

{% set unresolvedChecks = checks|filter(c => not c.isResolved) %}
{% set hasCritical = unresolvedChecks|filter(c => c.severity == 'critical')|length > 0 %}
{% set hasWarning = unresolvedChecks|filter(c => c.severity == 'warning')|length > 0 %}
{% set hasInfo = unresolvedChecks|filter(c => c.severity == 'info')|length > 0 %}

{# Build a lookup of unresolved keys so we can resolve which steps are blocked by outstanding prerequisites. #}
{% set unresolvedKeys = [] %}
{% for c in unresolvedChecks %}
    {% set unresolvedKeys = unresolvedKeys|merge([c.key]) %}
{% endfor %}

{# Friendly labels for prerequisite keys that appear in the "Requires: ..." sub-copy. #}
{% set prereqLabels = {
    'ai_provider_api_key': 'an AI provider API key'|t('lens'),
    'volumes_enabled': 'an enabled asset volume'|t('lens'),
} %}

{% if unresolvedChecks|length > 0 %}
<div class="lens-setup-banner {{ hasCritical ? '' : (hasWarning ? 'lens-setup-banner--warning' : (hasInfo ? 'lens-setup-banner--info' : '')) }}">
    <div class="lens-setup-banner__header">
        {% if showIcon ?? true %}
            <div class="lens-setup-banner__icon">{{ iconSvg('triangle-exclamation') }}</div>
        {% endif %}
        <h3 class="lens-setup-banner__title">{{ title ?? 'Setup Required'|t('lens') }}</h3>
    </div>

    {% if description ?? false %}
        <p class="lens-setup-banner__description">{{ description }}</p>
    {% else %}
        <p class="lens-setup-banner__description">
            {{ 'A few steps to unlock all Lens features.'|t('lens') }}
        </p>
    {% endif %}

    <div class="lens-setup-banner__checklist">
        {# Show unresolved items first #}
        {% for check in unresolvedChecks %}
            {% set unmetPrereqs = (check.prerequisites ?? [])|filter(k => k in unresolvedKeys) %}
            {% set isLocked = unmetPrereqs|length > 0 %}
            {% set unmetPrereqLabels = unmetPrereqs|map(k => prereqLabels[k] ?? k) %}

            <div class="lens-setup-banner__item {{ isLocked ? 'lens-setup-banner__item--locked' }}">
                <div class="lens-setup-banner__item-content">
                    <div class="lens-setup-banner__item-status">
                        {% if isLocked %}
                            <span class="lens-setup-banner__item-lock lens-setup-banner__item-lock--{{ check.severity }}" aria-hidden="true">{{ iconSvg('lock') }}</span>
                        {% elseif check.severity == 'critical' %}
                            <span class="status off"></span>
                        {% elseif check.severity == 'warning' %}
                            <span class="status pending"></span>
                        {% elseif check.severity == 'info' %}
                            <span class="status lens-status--info"></span>
                        {% else %}
                            <span class="status"></span>
                        {% endif %}
                    </div>
                    <div class="lens-setup-banner__item-body">
                        <span class="lens-setup-banner__item-text">{{ check.message }}</span>
                        {% if isLocked %}
                            <p class="lens-setup-banner__item-requirements">
                                {{ 'Requires {list}'|t('lens', { list: unmetPrereqLabels|join(', ') }) }}
                            </p>
                        {% endif %}
                    </div>
                </div>
                <div class="lens-setup-banner__item-action">
                    {% if check.docsUrl ?? false %}
                        <a href="{{ check.docsUrl }}" target="_blank" rel="noopener" class="lens-setup-banner__item-docs">
                            {{ 'Learn more'|t('lens') }}
                        </a>
                    {% endif %}
                    {% if check.actionUrl ?? false %}
                        {% if isLocked %}
                            <button type="button" class="btn small disabled" disabled aria-disabled="true">
                                {{ check.actionLabel }}
                            </button>
                        {% else %}
                            <a href="{{ cpUrl(check.actionUrl) }}" class="btn small {{ check.severity == 'critical' ? 'submit' }}">
                                {{ check.actionLabel }}
                            </a>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endif %}
