{#
 # Focal Point Section
 # Displays AI-suggested focal point with confidence + Apply control.
 #
 # Expected variables: analysis, asset (optional), fieldState
 #}
{% from 'lens/_components/analysis/_confidence-badge' import confidenceBadge %}

{% set fieldState = fieldState ?? 'readonly' %}

{% if analysis.focalPointX is not null and analysis.focalPointY is not null %}
    {% if fieldState == 'unlocked' and asset is defined %}
        {% set currentFp = asset.getFocalPoint() %}
        {% set fpAlreadyApplied = currentFp and (currentFp.x|round(4) == analysis.focalPointX|round(4)) and (currentFp.y|round(4) == analysis.focalPointY|round(4)) %}
    {% endif %}
    {% set fpEdited = analysis.focalPointXAi is not null
        and (analysis.focalPointX|round(4) != analysis.focalPointXAi|round(4)
        or analysis.focalPointY|round(4) != analysis.focalPointYAi|round(4)) %}

    <div class="lens-accent-bar">
        <div class="lens-field-header" data-lens-target="field-header">
            {% if fpEdited %}
                {% include 'lens/_components/analysis/_tooltip-lock' only %}
            {% endif %}
            <span class="lens-field-label">{{ 'Focal Point'|t('lens') }}</span>
            {% if not fpEdited and analysis.focalPointConfidence and not (hideConfidence ?? false) %}
                {{ confidenceBadge(analysis.focalPointConfidence) }}
            {% endif %}
        </div>

        <div class="lens-ai-suggestion-inline">
            {% include 'lens/_components/analysis/_tooltip-ai' only %}
            <span data-lens-target="focal-display-text">{{ 'X: {x}, Y: {y}'|t('lens', {
                x: (analysis.focalPointX * 100)|round ~ '%',
                y: (analysis.focalPointY * 100)|round ~ '%'
            }) }}</span>
            {% if fieldState == 'unlocked' and asset is defined %}
                {% if fpAlreadyApplied %}
                    <span class="lens-applied-indicator">
                        <span class="status on"></span>
                        <span class="smalltext">{{ 'Applied'|t('lens') }}</span>
                    </span>
                {% else %}
                    <button type="button" class="lens-revert-trigger"
                            data-lens-action="apply-focal-point"
                            data-lens-asset-id="{{ asset.id }}"
                            data-lens-focal-x="{{ analysis.focalPointX }}"
                            data-lens-focal-y="{{ analysis.focalPointY }}">
                        {{ 'Apply to Asset'|t('lens') }}
                    </button>
                {% endif %}
            {% endif %}
        </div>
    </div>
{% else %}
    <div class="lens-accent-bar">
        <div class="lens-field-header" data-lens-target="field-header">
            <span class="lens-field-label">{{ 'Focal Point'|t('lens') }}</span>
        </div>
        <div class="lens-field-display">
            <p class="light">{{ 'No focal point suggested'|t('lens') }}</p>
        </div>
    </div>
{% endif %}
