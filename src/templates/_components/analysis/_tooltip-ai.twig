{#
 # AI badge icon — indicates this value was generated by AI
 #
 # Optional variables:
 #   extraClass - string|null, additional CSS class (e.g. 'lens-ai-suggestion-icon--ai')
 #   hasTarget  - bool, whether to add data-lens-target="ai-badge-icon" (default: false)
 #}
{% set extraClass = extraClass ?? null %}
{% set hasTarget = hasTarget ?? false %}
<craft-tooltip text="{{ 'AI suggested'|t('lens') }}">
    <button type="button" class="lens-ai-badge-icon{{ extraClass ? ' ' ~ extraClass : '' }}"{% if hasTarget %} data-lens-target="ai-badge-icon"{% endif %}>
        {{ iconSvg('wand-magic-sparkles')|attr({width: 12, height: 12}) }}
    </button>
</craft-tooltip>
