{#
 # Translation Summary — Compact review-page summary card
 #
 # Shows translations as scannable rows (language, truncated preview, confidence).
 # Click any row to expand and edit. Accordion behavior (one expanded at a time).
 # All [data-lens-site-id] containers remain in DOM for form serialization.
 #
 # Expected variables:
 #   siteContent         - array of per-site translation data
 #   isTitleTranslatable - bool
 #   isAltTranslatable   - bool
 #   analysisId          - int
 #   fieldState          - 'editing' (always on review page)
 #}

{% if (siteContent ?? [])|length %}
<div class="lens-translation-summary" data-lens-target="translation-summary">
    <div class="lens-translations-header" data-lens-action="toggle-translations" aria-expanded="true">
        <span class="lens-translations-chevron">{{ iconSvg('chevron-right') }}</span>
        <span class="lens-field-label">{{ 'Translations'|t('lens') }}</span>
        <span class="badge">{{ siteContent|length }}</span>
    </div>

    <div class="lens-translations-body" data-lens-target="translations-body">
        {# Summary table #}
        <div class="lens-translation-summary__table">
            {% for site in siteContent %}
                {% set minConf = null %}
                {% if site.titleConfidence and site.altTextConfidence %}
                    {% set minConf = site.titleConfidence < site.altTextConfidence ? site.titleConfidence : site.altTextConfidence %}
                {% elseif site.titleConfidence %}
                    {% set minConf = site.titleConfidence %}
                {% elseif site.altTextConfidence %}
                    {% set minConf = site.altTextConfidence %}
                {% endif %}
                {% set isLowConf = minConf and minConf < 0.8 %}
                {% set preview = site.suggestedTitle ?? site.altText ?? '' %}

                <div class="lens-translation-summary__row{{ isLowConf ? ' lens-translation-summary__row--warn' : '' }}"
                     data-lens-action="translation-expand"
                     data-lens-expand-site="{{ site.siteId }}">
                    <span class="lens-translation-lang-chip">{{ site.language }}</span>
                    <span class="lens-translation-summary__preview">{{ preview|length > 40 ? preview|slice(0, 40) ~ '…' : preview }}</span>
                    {% if minConf %}
                        <span class="lens-translation-summary__confidence{{ isLowConf ? ' lens-translation-summary__confidence--low' : '' }}">
                            {{ (minConf * 100)|round }}%{% if isLowConf %} &#9888;{% endif %}
                        </span>
                    {% endif %}
                </div>
            {% endfor %}
        </div>

        <p class="lens-translation-summary__hint light">
            {{ 'Expand any row to preview or edit. All translations saved on approval.'|t('lens') }}
        </p>

        {# Expandable detail panels (hidden by default, toggled by JS) #}
        {% for site in siteContent %}
            <div class="lens-translation-summary__expand hidden"
                 data-lens-target="translation-detail"
                 data-lens-site-id="{{ site.siteId }}">
                <div class="lens-translation-group__header">
                    <strong>{{ site.siteName }}</strong>
                    <span class="light">({{ site.language }})</span>
                </div>

                {% if isTitleTranslatable %}
                    {% include 'lens/_components/analysis/editable-field' with {
                        fieldName: 'suggestedTitle',
                        label: 'Title'|t('lens'),
                        value: site.suggestedTitle,
                        aiValue: site.suggestedTitleAi,
                        confidence: site.titleConfidence,
                        editedBy: site.suggestedTitleEditedBy ?? null,
                        editedAt: site.suggestedTitleEditedAt ?? null,
                        inputType: 'text',
                        analysisId: analysisId,
                        fieldState: fieldState,
                        siteId: site.siteId
                    } %}
                {% endif %}

                {% if isAltTranslatable %}
                    {% include 'lens/_components/analysis/editable-field' with {
                        fieldName: 'altText',
                        label: 'Alt Text'|t('lens'),
                        value: site.altText,
                        aiValue: site.altTextAi,
                        confidence: site.altTextConfidence,
                        editedBy: site.altTextEditedBy ?? null,
                        editedAt: site.altTextEditedAt ?? null,
                        inputType: 'textarea',
                        analysisId: analysisId,
                        fieldState: fieldState,
                        siteId: site.siteId
                    } %}
                {% endif %}
            </div>
        {% endfor %}
    </div>
</div>
{% endif %}
