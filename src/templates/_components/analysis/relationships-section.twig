{#
 # Similar Assets Section
 # Similar/duplicate assets thumbnail strip.
 #
 # Expected variables: similarImages, asset, static, isProcessing
 #}
{% set isProcessing = isProcessing ?? false %}

{# Similar / Duplicate Assets #}
{% if similarImages|length %}
    <div class="flex items-center gap-s mb-xs">
        <span class="lens-field-label">{{ 'Similar Assets'|t('lens') }}</span>
    </div>
    <div class="lens-similar-strip">
        {% for img in similarImages %}
            <a href="{{ img.editUrl }}" title="{{ img.filename }} ({{ (img.similarity * 100)|round }}% similar)">
                <img src="{{ img.thumbnailUrl }}" alt="{{ img.filename }}" class="lens-similar-thumb" loading="lazy">
            </a>
        {% endfor %}
    </div>
{% endif %}

{# Find Similar button #}
{% if not (static ?? false) and not isProcessing %}
    <div class="mt-m">
        <button type="button" class="btn small" data-lens-action="find-similar" data-lens-asset-id="{{ asset.id }}">
            {{ 'Find Similar Assets'|t('lens') }}
        </button>
    </div>
{% endif %}
