{#
 # Edit Meta (Provenance) — "Edited by {user} on {date}"
 #
 # Shared component for displaying field edit provenance.
 # Shows linked user name and locale-formatted date.
 #
 # Expected variables:
 #   editedBy  - int|null, user ID who edited
 #   editedAt  - DateTime|null, when edited
 #   target    - string, data-lens-target value (e.g. 'field-edit-meta')
 #   isEdited  - bool, whether the field has been edited
 #}

<div class="lens-edit-meta" data-lens-target="{{ target }}"{% if not isEdited %} hidden{% endif %}>
    {% if isEdited and editedBy %}
        {% set editor = craft.users.id(editedBy).one() %}
        {% if editor %}
            {% set userHtml %}<a href="{{ editor.cpEditUrl }}">{{ editor.friendlyName }}</a>{% endset %}
        {% else %}
            {% set userHtml %}{{ 'Unknown'|t('lens') }}{% endset %}
        {% endif %}
        {{ 'Edited by {user} on {date}'|t('lens', {
            user: userHtml,
            date: editedAt|date('short')
        })|raw }}
    {% endif %}
</div>
