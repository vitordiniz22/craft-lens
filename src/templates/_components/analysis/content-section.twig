{#
 # Content Metadata Section
 # Title, Alt Text, Long Description — all inline editable.
 #
 # Expected variables: analysis, asset, isAutoGeneratedTitle, static, isProcessing, mode
 #}
{% set isProcessing = isProcessing ?? false %}
{% set mode = mode ?? 'asset-edit' %}

{% include 'lens/_components/analysis/editable-field' with {
    fieldName: 'suggestedTitle',
    label: 'Title'|t('lens'),
    value: analysis.suggestedTitle,
    aiValue: analysis.suggestedTitleAi,
    confidence: analysis.titleConfidence,
    editedBy: analysis.suggestedTitleEditedBy,
    editedAt: analysis.suggestedTitleEditedAt ?? null,
    inputType: 'text',
    featured: true,
    static: static,
    analysisId: analysis.id,
    isProcessing: isProcessing,
    mode: mode
} %}

{# Apply to asset row - only in asset-edit mode, only when title exists #}
{% if mode != 'review' and analysis.suggestedTitle %}
    {% set titleAlreadyApplied = asset.title == analysis.suggestedTitle %}
    <div class="lens-apply-row">
        {% if titleAlreadyApplied %}
            <div class="lens-applied-indicator">
                <span class="status on"></span>
                <span class="smalltext">{{ 'Applied'|t('lens') }}</span>
            </div>
        {% elseif not static and not isProcessing %}
            <button type="button" class="btn small submit" data-lens-action="apply-title" data-lens-asset-id="{{ asset.id }}">
                {{ 'Apply to Asset'|t('lens') }}
            </button>
            {% if isAutoGeneratedTitle %}
                <span class="smalltext light">{{ 'Title was auto-generated from filename'|t('lens') }}</span>
            {% endif %}
        {% endif %}
    </div>
{% endif %}

{% include 'lens/_components/analysis/editable-field' with {
    fieldName: 'altText',
    label: 'Alt Text'|t('lens'),
    value: analysis.altText,
    aiValue: analysis.altTextAi,
    confidence: analysis.altTextConfidence,
    editedBy: analysis.altTextEditedBy,
    editedAt: analysis.altTextEditedAt ?? null,
    inputType: 'textarea',
    featured: false,
    static: static,
    analysisId: analysis.id,
    isProcessing: isProcessing,
    mode: mode
} %}

{% include 'lens/_components/analysis/editable-field' with {
    fieldName: 'longDescription',
    label: 'Description'|t('lens'),
    value: analysis.longDescription,
    aiValue: analysis.longDescriptionAi,
    confidence: analysis.longDescriptionConfidence,
    editedBy: analysis.longDescriptionEditedBy,
    editedAt: analysis.longDescriptionEditedAt ?? null,
    inputType: 'textarea',
    featured: false,
    static: static,
    analysisId: analysis.id,
    isProcessing: isProcessing,
    mode: mode
} %}
