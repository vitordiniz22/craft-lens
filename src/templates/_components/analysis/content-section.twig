{#
 # Content Metadata Section
 # Title (native bridge), Alt Text (bridge or proxy), Long Description (editable field).
 #
 # Context-aware: when viewing a secondary site, shows that site's translation
 # as the main suggestion (with Apply to Asset). Other languages go into a
 # collapsible tabbed section. On the review page, translations use a compact
 # summary card instead.
 #
 # Expected variables:
 #   analysis            - AssetAnalysisRecord (panel) or array (review page)
 #   assetTitle          - string, current $asset->title (site-specific)
 #   assetAlt            - string, current $asset->alt (site-specific)
 #   isAutoGeneratedTitle - bool
 #   isAltEmpty          - bool
 #   altFieldInLayout    - bool
 #   fieldState          - 'readonly'|'unlocked'|'editing'
 #   isAltTranslatable   - bool (optional, default true)
 #   isTitleTranslatable - bool (optional, default true)
 #   currentSiteId       - int, the site the user is currently viewing
 #   primarySiteId       - int, the Craft primary site ID
 #   siteContent         - array of per-site translation data
 #
 # Note: In the analysis panel, `analysis` is an AssetAnalysisRecord (use .id).
 #       On the review page, `analysis` is a plain array (use .analysisId).
 #}
{% set fieldState = fieldState ?? 'readonly' %}
{% set isAltTranslatable = isAltTranslatable ?? true %}
{% set isTitleTranslatable = isTitleTranslatable ?? true %}
{% set currentSiteId = currentSiteId ?? primarySiteId %}
{% set primarySiteId = primarySiteId ?? craft.app.sites.primarySite.id %}

{# Resolve IDs once — record uses .id, review array uses .analysisId #}
{% set resolvedAnalysisId = fieldState == 'editing' ? analysis.analysisId : analysis.id %}
{% set resolvedAssetId = fieldState == 'editing' ? analysis.assetId : (asset.id ?? null) %}

{# ── Context-Aware: detect if viewing a secondary site ── #}
{% set isSecondarySite = currentSiteId != primarySiteId %}
{% set currentSiteData = null %}

{% if isSecondarySite and (siteContent ?? [])|length %}
    {% for site in siteContent %}
        {% if site.siteId == currentSiteId %}
            {% set currentSiteData = site %}
        {% endif %}
    {% endfor %}
{% endif %}

{# ── Title ── #}
{% if currentSiteData and isTitleTranslatable %}
    {# Secondary site: show this site's translation as the main suggestion #}
    {% include 'lens/_components/analysis/native-field-bridge' with {
        fieldName: 'suggestedTitle',
        label: 'Title'|t('lens'),
        nativeValue: assetTitle ?? '',
        isNativeDefault: isAutoGeneratedTitle ?? false,
        suggestionValue: currentSiteData.suggestedTitle,
        aiValue: currentSiteData.suggestedTitleAi,
        confidence: currentSiteData.titleConfidence,
        editedBy: currentSiteData.suggestedTitleEditedBy ?? null,
        inputType: 'text',
        analysisId: resolvedAnalysisId,
        assetId: resolvedAssetId,
        fieldState: fieldState,
        applyAction: 'apply-title',
        siteId: currentSiteId
    } %}
{% else %}
    {# Primary site (or no translation for current site): show primary suggestion #}
    {% include 'lens/_components/analysis/native-field-bridge' with {
        fieldName: 'suggestedTitle',
        label: 'Title'|t('lens'),
        nativeValue: assetTitle ?? '',
        isNativeDefault: isAutoGeneratedTitle ?? false,
        suggestionValue: analysis.suggestedTitle,
        aiValue: analysis.suggestedTitleAi,
        confidence: analysis.titleConfidence,
        editedBy: analysis.suggestedTitleEditedBy ?? null,
        inputType: 'text',
        analysisId: resolvedAnalysisId,
        assetId: resolvedAssetId,
        fieldState: fieldState,
        applyAction: 'apply-title'
    } %}
{% endif %}

{# ── Alt Text ── #}
{% if (altFieldInLayout ?? true) %}
    {% if currentSiteData and isAltTranslatable %}
        {# Secondary site: show this site's translation #}
        {% include 'lens/_components/analysis/native-field-bridge' with {
            fieldName: 'altText',
            label: 'Alt Text'|t('lens'),
            nativeValue: assetAlt ?? '',
            isNativeDefault: isAltEmpty ?? true,
            suggestionValue: currentSiteData.altText,
            aiValue: currentSiteData.altTextAi,
            confidence: currentSiteData.altTextConfidence,
            editedBy: currentSiteData.altTextEditedBy ?? null,
            inputType: 'textarea',
            analysisId: resolvedAnalysisId,
            assetId: resolvedAssetId,
            fieldState: fieldState,
            applyAction: 'apply-alt',
            siteId: currentSiteId
        } %}
    {% else %}
        {# Primary site: show primary suggestion #}
        {% include 'lens/_components/analysis/native-field-bridge' with {
            fieldName: 'altText',
            label: 'Alt Text'|t('lens'),
            nativeValue: assetAlt ?? '',
            isNativeDefault: isAltEmpty ?? true,
            suggestionValue: analysis.altText,
            aiValue: analysis.altTextAi,
            confidence: analysis.altTextConfidence,
            editedBy: analysis.altTextEditedBy ?? null,
            inputType: 'textarea',
            analysisId: resolvedAnalysisId,
            assetId: resolvedAssetId,
            fieldState: fieldState,
            applyAction: 'apply-alt'
        } %}
    {% endif %}
{% else %}
    {% include 'lens/_components/analysis/alt-proxy-field' with {
        nativeValue: assetAlt ?? '',
        suggestionValue: analysis.altText,
        aiValue: analysis.altTextAi,
        confidence: analysis.altTextConfidence,
        analysisId: resolvedAnalysisId,
        assetId: resolvedAssetId,
        fieldState: fieldState
    } %}
{% endif %}

{# ── Other Languages / Translations ── #}
{# Build list of "other" languages (excluding current site if secondary) #}
{% set otherSiteContent = [] %}
{% if (siteContent ?? [])|length %}
    {% for site in siteContent %}
        {% if site.siteId != currentSiteId %}
            {% set otherSiteContent = otherSiteContent|merge([site]) %}
        {% endif %}
    {% endfor %}
{% endif %}

{# On the review page, use the compact translation-summary component #}
{% if fieldState == 'editing' %}
    {% include 'lens/_components/analysis/translation-summary' with {
        siteContent: siteContent,
        isTitleTranslatable: isTitleTranslatable,
        isAltTranslatable: isAltTranslatable,
        analysisId: resolvedAnalysisId,
        fieldState: fieldState
    } %}

{# On the analysis panel, use collapsible tabbed section #}
{% elseif otherSiteContent|length %}
    {% set sectionLabel = isSecondarySite ? 'Other Languages'|t('lens') : 'Translations'|t('lens') %}

    {# Compute lowest confidence across all translations for header indicator #}
    {% set minConfidence = null %}
    {% for site in otherSiteContent %}
        {% for conf in [site.titleConfidence, site.altTextConfidence] %}
            {% if conf and (minConfidence is null or conf < minConfidence) %}
                {% set minConfidence = conf %}
            {% endif %}
        {% endfor %}
    {% endfor %}

    <div class="lens-translations-section" data-lens-target="translations-section">
        <div class="lens-translations-header"
             data-lens-action="toggle-translations"
             aria-expanded="false">
            <span class="lens-translations-chevron">{{ iconSvg('chevron-right') }}</span>
            <span class="lens-field-label">{{ sectionLabel }}</span>
            <span class="badge">{{ otherSiteContent|length }}</span>
            {% if minConfidence and minConfidence < 0.8 %}
                <span class="lens-confidence-badge lens-confidence-badge--{{ (minConfidence * 100)|round >= 50 ? 'medium' : 'low' }}">
                    {{ (minConfidence * 100)|round }}%
                </span>
            {% endif %}
        </div>

        <div class="lens-translations-body hidden" data-lens-target="translations-body">
            {# Tab bar (only if more than one language) #}
            {% if otherSiteContent|length > 1 %}
                <div class="lens-translations-tabs" data-lens-target="translations-tabs">
                    {% for site in otherSiteContent %}
                        <button type="button"
                                class="lens-translations-tab{{ loop.first ? ' is-active' : '' }}"
                                data-lens-action="translation-tab"
                                data-lens-tab-site="{{ site.siteId }}">
                            {{ site.language }}
                        </button>
                    {% endfor %}
                </div>
            {% endif %}

            {# Tab panels #}
            {% for site in otherSiteContent %}
                <div class="lens-translation-group{{ not loop.first and otherSiteContent|length > 1 ? ' hidden' : '' }}"
                     data-lens-site-id="{{ site.siteId }}">
                    {% if otherSiteContent|length == 1 %}
                        <div class="lens-translation-group__header">
                            <strong>{{ site.siteName }}</strong>
                            <span class="light">({{ site.language }})</span>
                        </div>
                    {% endif %}

                    {% if isTitleTranslatable %}
                        {% include 'lens/_components/analysis/editable-field' with {
                            fieldName: 'suggestedTitle',
                            label: 'Title'|t('lens'),
                            value: site.suggestedTitle,
                            aiValue: site.suggestedTitleAi,
                            confidence: site.titleConfidence,
                            editedBy: site.suggestedTitleEditedBy ?? null,
                            editedAt: site.suggestedTitleEditedAt ?? null,
                            inputType: 'text',
                            analysisId: resolvedAnalysisId,
                            fieldState: fieldState,
                            siteId: site.siteId
                        } %}
                    {% endif %}

                    {% if isAltTranslatable %}
                        {% include 'lens/_components/analysis/editable-field' with {
                            fieldName: 'altText',
                            label: 'Alt Text'|t('lens'),
                            value: site.altText,
                            aiValue: site.altTextAi,
                            confidence: site.altTextConfidence,
                            editedBy: site.altTextEditedBy ?? null,
                            editedAt: site.altTextEditedAt ?? null,
                            inputType: 'textarea',
                            analysisId: resolvedAnalysisId,
                            fieldState: fieldState,
                            siteId: site.siteId
                        } %}
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}

{# ── Long Description (no native Craft equivalent) ── #}
{% include 'lens/_components/analysis/editable-field' with {
    fieldName: 'longDescription',
    label: 'Description'|t('lens'),
    value: analysis.longDescription,
    aiValue: analysis.longDescriptionAi,
    confidence: analysis.longDescriptionConfidence,
    editedBy: analysis.longDescriptionEditedBy,
    editedAt: analysis.longDescriptionEditedAt ?? null,
    inputType: 'textarea',
    featured: false,
    analysisId: resolvedAnalysisId,
    fieldState: fieldState
} %}
