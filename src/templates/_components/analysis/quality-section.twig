{#
 # Image Assessment Section
 # Quality verdicts (from AI scores), web readiness (local PHP), text-in-image accessibility,
 # and focal point with Apply button.
 #
 # Expected variables: analysis, asset (optional), fieldState, webReadiness, qualityMetrics
 #}
{% set fieldState = fieldState ?? 'readonly' %}
{% set webReadiness = webReadiness ?? {issues: [], checks: {}} %}
{% set qualityMetrics = qualityMetrics ?? {} %}

{# ── Quality ──────────────────────────────────────────── #}
{% if analysis.overallQualityScore is not null %}
    <div class="lens-editable-field">
        <div class="lens-field-header" data-lens-target="field-header">
            <span class="lens-field-label">{{ 'Quality'|t('lens') }}</span>
            <span class="badge badge--{{ analysis.overallQualityScore >= 0.7 ? 'success' : (analysis.overallQualityScore >= 0.4 ? 'warning' : 'error') }}">
                {{ (analysis.overallQualityScore * 100)|round }}%
            </span>
        </div>

        <div class="lens-quality-metrics">
            {% for metric in qualityMetrics %}
                <div class="lens-quality-metric">
                    <span class="lens-metric-label">{{ metric.label }}</span>
                    <div class="lens-metric-bar">
                        <div class="lens-metric-fill" style="width: {{ metric.score * 100 }}%"></div>
                    </div>
                    <span class="lens-metric-value">{{ (metric.score * 100)|round }}%</span>
                    {% if metric.verdict %}
                        <span class="lens-metric-verdict lens-metric-verdict--{{ metric.status }}">
                            {{ metric.status == 'pass' ? '✓' : '⚠' }} {{ metric.verdict }}
                        </span>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
{% else %}
    <div class="lens-editable-field lens-detection-item lens-detection-item--clear">
        <div class="lens-field-header" data-lens-target="field-header">
            <span class="lens-field-label">{{ 'Quality'|t('lens') }}</span>
        </div>
        <p class="light smalltext">{{ 'Quality metrics not available'|t('lens') }}</p>
    </div>
{% endif %}

{# ── Web Readiness ────────────────────────────────────── #}
{% if webReadiness.checks is defined and webReadiness.checks|length %}
    <div class="lens-editable-field">
        <div class="lens-field-header" data-lens-target="field-header">
            <span class="lens-field-label">{{ 'Web Readiness'|t('lens') }}</span>
            {% set issueCount = webReadiness.issues|length %}
            {% if issueCount > 0 %}
                <span class="badge badge--warning">{{ issueCount }}</span>
            {% else %}
                <span class="badge badge--success">✓</span>
            {% endif %}
        </div>

        <div class="lens-assessment-checks">
            {% for check in webReadiness.checks %}
                <div class="lens-assessment-check lens-assessment-check--{{ check.status }}">
                    <span class="lens-assessment-icon">{{ check.status == 'pass' ? '✓' : '⚠' }}</span>
                    <span class="lens-assessment-label">{{ check.label }}</span>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}

{# ── Text in Image — Accessibility (Pro only) ────────── #}
{% if lens.isPro and analysis.extractedText is defined and analysis.extractedText is not empty %}
    <div class="lens-assessment-notice lens-assessment-notice--info">
        <span class="lens-assessment-icon">⚠</span>
        <span>{{ 'This image contains embedded text. Ensure this text is also available as HTML on the page for screen reader accessibility.'|t('lens') }}</span>
    </div>
{% endif %}

{# ── Focal Point ──────────────────────────────────────── #}
{% if analysis.focalPointX is not null and analysis.focalPointY is not null %}
    {% if fieldState == 'unlocked' and asset is defined %}
        {% set currentFp = asset.getFocalPoint() %}
        {% set fpAlreadyApplied = currentFp and (currentFp.x|round(4) == analysis.focalPointX|round(4)) and (currentFp.y|round(4) == analysis.focalPointY|round(4)) %}
    {% endif %}
    {% set fpEdited = analysis.focalPointEditedBy is not null %}

    <div class="lens-accent-bar">
        <div class="lens-field-header" data-lens-target="field-header">
            {% if fpEdited %}
                {% include 'lens/_components/analysis/_tooltip-lock' only %}
            {% endif %}
            <span class="lens-field-label">{{ 'Focal Point'|t('lens') }}</span>
            {% if not fpEdited and analysis.focalPointConfidence and not (hideConfidence ?? false) %}
                <span class="badge" data-lens-target="confidence-badge">{{ (analysis.focalPointConfidence * 100)|round }}%</span>
            {% endif %}
        </div>

        <div class="lens-ai-suggestion-inline">
            {% include 'lens/_components/analysis/_tooltip-ai' only %}
            <span data-lens-target="focal-display-text">{{ 'X: {x}, Y: {y}'|t('lens', {
                x: (analysis.focalPointX * 100)|round ~ '%',
                y: (analysis.focalPointY * 100)|round ~ '%'
            }) }}</span>
            {% if fieldState == 'unlocked' and asset is defined %}
                {% if fpAlreadyApplied %}
                    <span class="lens-applied-indicator">
                        <span class="status on"></span>
                        <span class="smalltext">{{ 'Applied'|t('lens') }}</span>
                    </span>
                {% else %}
                    <button type="button" class="lens-revert-trigger"
                            data-lens-action="apply-focal-point"
                            data-lens-asset-id="{{ asset.id }}"
                            data-lens-focal-x="{{ analysis.focalPointX }}"
                            data-lens-focal-y="{{ analysis.focalPointY }}">
                        {{ 'Apply to Asset'|t('lens') }}
                    </button>
                {% endif %}
            {% endif %}
        </div>

        {# Asset FP conflict — editing mode only, when asset has a different FP #}
        {% if fieldState == 'editing' and analysis.assetHasFocalPoint is defined and analysis.assetHasFocalPoint %}
            {% set fpMatchesAsset = analysis.assetFocalPoint
                and (analysis.focalPointX|round(4) == analysis.assetFocalPoint.x|round(4))
                and (analysis.focalPointY|round(4) == analysis.assetFocalPoint.y|round(4)) %}

            <div class="lens-ai-suggestion-inline" data-lens-target="focal-asset-conflict"
                {% if fpMatchesAsset %}style="display: none;"{% endif %}>
                {% include 'lens/_components/analysis/_tooltip-ai' with {extraClass: 'lens-ai-suggestion-icon--ai'} only %}
                <span class="lens-ai-suggestion-icon lens-ai-suggestion-icon--action">{{ iconSvg('triangle-exclamation')|attr({width: 12, height: 12}) }}</span>
                <span data-lens-target="focal-asset-conflict-text">
                    {{ 'Different focal point suggested'|t('lens') }}
                </span>
                &middot;
                <button type="button" class="lens-revert-trigger"
                        data-lens-action="focal-accept">
                    {{ 'Accept'|t('lens') }}
                </button>
                <span class="lens-focal-undo-group">
                    &middot;
                    <button type="button" class="lens-revert-trigger"
                            data-lens-action="focal-use-current"
                            data-lens-asset-focal-x="{{ analysis.assetFocalPoint.x }}"
                            data-lens-asset-focal-y="{{ analysis.assetFocalPoint.y }}">
                        {{ 'Undo'|t('lens') }}
                    </button>
                </span>
            </div>
        {% endif %}

        {# AI suggestion + revert (review editing mode only) #}
        {% if fieldState == 'editing' and analysis.focalPointXAi is not null %}
            {% set fpAiDiffers = analysis.focalPointEditedBy is not null
                and (analysis.focalPointXAi|round(4) != analysis.focalPointX|round(4)
                or analysis.focalPointYAi|round(4) != analysis.focalPointY|round(4)) %}

            <div class="lens-ai-suggestion-inline" data-lens-target="focal-ai-suggestion"
                 {% if not fpAiDiffers %}style="display: none;"{% endif %}>
                {% include 'lens/_components/analysis/_tooltip-ai' only %}
                <span data-lens-target="focal-ai-text">
                    {{ 'AI suggested: X: {x}, Y: {y}'|t('lens', {
                        x: (analysis.focalPointXAi * 100)|round ~ '%',
                        y: (analysis.focalPointYAi * 100)|round ~ '%'
                    }) }}
                </span>
                &middot;
                <button type="button" class="lens-revert-trigger"
                        data-lens-action="focal-revert"
                        data-lens-focal-x-ai="{{ analysis.focalPointXAi }}"
                        data-lens-focal-y-ai="{{ analysis.focalPointYAi }}">
                    {{ 'Revert to AI'|t('lens') }}
                </button>
            </div>
        {% endif %}

    </div>
{% else %}
    <div class="lens-accent-bar">
        <div class="lens-field-header" data-lens-target="field-header">
            <span class="lens-field-label">{{ 'Focal Point'|t('lens') }}</span>
        </div>
        <div class="lens-field-display">
            <p class="light">{{ 'No focal point suggested'|t('lens') }}</p>
        </div>
    </div>
{% endif %}
