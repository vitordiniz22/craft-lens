{#
 # Focal Point & Quality Section
 # Focal point coordinates with Apply button + quality metric bars.
 #
 # Expected variables: analysis, asset (optional), fieldState
 #}
{% set fieldState = fieldState ?? 'readonly' %}

{# Focal Point #}
{% if analysis.focalPointX is not null and analysis.focalPointY is not null %}
    {% if fieldState == 'unlocked' and asset is defined %}
        {% set currentFp = asset.getFocalPoint() %}
        {% set fpAlreadyApplied = currentFp and (currentFp.x|round(4) == analysis.focalPointX|round(4)) and (currentFp.y|round(4) == analysis.focalPointY|round(4)) %}
    {% endif %}
    {% set fpEdited = analysis.focalPointEditedBy is not null %}

    <div class="lens-native-bridge">
        <div class="lens-field-header">
            {% if fpEdited %}
                <span class="lens-lock-icon" title="{{ 'Protected from reprocessing'|t('lens') }}">&#128274;</span>
            {% endif %}
            <span class="lens-field-label">{{ 'Focal Point'|t('lens') }}</span>
            {% if not fpEdited and analysis.focalPointConfidence %}
                <span class="badge">{{ (analysis.focalPointConfidence * 100)|round }}%</span>
            {% endif %}
        </div>

        <div class="lens-field-display">
            <p data-lens-target="focal-display-text">{{ 'X: {x}, Y: {y}'|t('lens', {
                x: (analysis.focalPointX * 100)|round ~ '%',
                y: (analysis.focalPointY * 100)|round ~ '%'
            }) }}</p>
        </div>

        {# AI suggestion + revert (review editing mode only) #}
        {% if fieldState == 'editing' and analysis.focalPointXAi is not null %}
            {% set fpAiDiffers = analysis.focalPointEditedBy is not null
                and (analysis.focalPointXAi|round(4) != analysis.focalPointX|round(4)
                or analysis.focalPointYAi|round(4) != analysis.focalPointY|round(4)) %}

            <div class="lens-ai-suggestion-inline" data-lens-target="focal-ai-suggestion"
                 {% if not fpAiDiffers %}style="display: none;"{% endif %}>
                <span class="lens-ai-suggestion-icon">{{ iconSvg('wand-magic-sparkles')|attr({width: 12, height: 12}) }}</span>
                <span data-lens-target="focal-ai-text">
                    {{ 'AI suggested: X: {x}, Y: {y}'|t('lens', {
                        x: (analysis.focalPointXAi * 100)|round ~ '%',
                        y: (analysis.focalPointYAi * 100)|round ~ '%'
                    }) }}
                </span>
                &mdash;
                <button type="button" class="lens-revert-trigger"
                        data-lens-action="focal-revert"
                        data-lens-focal-x-ai="{{ analysis.focalPointXAi }}"
                        data-lens-focal-y-ai="{{ analysis.focalPointYAi }}">
                    {{ 'Revert to AI'|t('lens') }}
                </button>
            </div>
        {% endif %}

        {# Apply to asset row - only in unlocked mode #}
        {% if fieldState == 'unlocked' and asset is defined %}
            <div class="lens-apply-row">
                {% if fpAlreadyApplied %}
                    <div class="lens-applied-indicator">
                        <span class="status on"></span>
                        <span class="smalltext">{{ 'Applied'|t('lens') }}</span>
                    </div>
                {% else %}
                    <button type="button" class="btn small submit"
                            data-lens-action="apply-focal-point"
                            data-lens-asset-id="{{ asset.id }}"
                            data-lens-focal-x="{{ analysis.focalPointX }}"
                            data-lens-focal-y="{{ analysis.focalPointY }}">
                        {{ 'Apply to Asset'|t('lens') }}
                    </button>
                    {% if asset.getHasFocalPoint() %}
                        <span class="smalltext light">{{ 'Will replace current focal point'|t('lens') }}</span>
                    {% endif %}
                {% endif %}
            </div>
        {% endif %}
    </div>
{% else %}
    <div class="lens-native-bridge">
        <div class="lens-field-header">
            <span class="lens-field-label">{{ 'Focal Point'|t('lens') }}</span>
        </div>
        <div class="lens-field-display">
            <p class="light">{{ 'No focal point suggested'|t('lens') }}</p>
        </div>
    </div>
{% endif %}

{# Quality Metrics — always read-only #}
{% if analysis.overallQualityScore is not null %}
    <div class="lens-editable-field">
        <div class="lens-field-header">
            <span class="lens-field-label">{{ 'Image Quality'|t('lens') }}</span>
            <span class="badge badge--{{ analysis.overallQualityScore >= 0.7 ? 'success' : (analysis.overallQualityScore >= 0.4 ? 'warning' : 'error') }}">
                {{ (analysis.overallQualityScore * 100)|round }}%
            </span>
        </div>

        <div class="lens-quality-metrics">
            {% if analysis.sharpnessScore is not null %}
                <div class="lens-quality-metric">
                    <span class="lens-metric-label">{{ 'Sharpness'|t('lens') }}</span>
                    <div class="lens-metric-bar">
                        <div class="lens-metric-fill" style="width: {{ analysis.sharpnessScore * 100 }}%"></div>
                    </div>
                    <span class="smalltext light" style="min-width:32px;text-align:right">{{ (analysis.sharpnessScore * 100)|round }}%</span>
                </div>
            {% endif %}
            {% if analysis.exposureScore is not null %}
                <div class="lens-quality-metric">
                    <span class="lens-metric-label">{{ 'Exposure'|t('lens') }}</span>
                    <div class="lens-metric-bar">
                        <div class="lens-metric-fill" style="width: {{ analysis.exposureScore * 100 }}%"></div>
                    </div>
                    <span class="smalltext light" style="min-width:32px;text-align:right">{{ (analysis.exposureScore * 100)|round }}%</span>
                </div>
            {% endif %}
            {% if analysis.noiseScore is not null %}
                <div class="lens-quality-metric">
                    <span class="lens-metric-label">{{ 'Clarity'|t('lens') }}</span>
                    <div class="lens-metric-bar">
                        <div class="lens-metric-fill" style="width: {{ analysis.noiseScore * 100 }}%"></div>
                    </div>
                    <span class="smalltext light" style="min-width:32px;text-align:right">{{ (analysis.noiseScore * 100)|round }}%</span>
                </div>
            {% endif %}
        </div>
    </div>
{% else %}
    <div class="lens-editable-field lens-detection-item lens-detection-item--clear">
        <div class="lens-field-header">
            <span class="lens-field-label">{{ 'Image Quality'|t('lens') }}</span>
        </div>
        <p class="light smalltext">{{ 'Quality metrics not available'|t('lens') }}</p>
    </div>
{% endif %}
