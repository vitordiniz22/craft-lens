{#
 # Native Field Bridge — Suggestion-to-Asset Bridge Component
 #
 # Shows the AI suggestion with apply status. Used for title and alt text
 # (when AltField is in layout). The current asset value is NOT shown here —
 # the user can see it in Craft's native field above.
 #
 # On the review page (editing state), the current asset value IS shown as
 # context since the reviewer doesn't have the asset editor open.
 #
 # Expected variables:
 #   fieldName       - string, the analysis field key (e.g. 'suggestedTitle', 'altText')
 #   label           - string, display label (e.g. 'Title', 'Alt Text')
 #   nativeValue     - string, current asset value ($asset->title or $asset->alt)
 #   isNativeDefault - bool, true if value is auto-generated/empty
 #   suggestionValue - string|null, AI suggestion (possibly user-edited)
 #   aiValue         - string|null, original AI value (before user edits)
 #   confidence      - float|null, AI confidence (0-1)
 #   editedBy        - int|null, user ID who edited the suggestion (optional)
 #   inputType       - string, 'text' or 'textarea' (default: 'text')
 #   analysisId      - int, the analysis record ID
 #   assetId         - int|null, the asset ID
 #   fieldState      - 'readonly'|'unlocked'|'editing'
 #   applyAction     - string, the data-lens-action value (e.g. 'apply-title', 'apply-alt')
 #   siteId          - int|null, optional site ID for per-site content (omit for primary site)
 #}

{% set inputType = inputType ?? 'text' %}
{% set siteId = siteId ?? null %}
{% set fieldState = fieldState ?? 'readonly' %}
{% set isEdited = (editedBy ?? null) is not null %}
{% set fieldMaxLengths = { altText: 500, suggestedTitle: 255 } %}
{% set maxlength = fieldMaxLengths[fieldName] ?? null %}

{# Determine the status of the native value relative to the suggestion #}
{% set hasSuggestion = suggestionValue is defined and suggestionValue is not empty %}
{% set valuesMatch = hasSuggestion and nativeValue == suggestionValue %}

{# ============================================================
   READONLY — Suggestion display only. No apply buttons.
   ============================================================ #}
{% if fieldState == 'readonly' %}

<div class="lens-accent-bar">
    <div class="lens-field-header" data-lens-target="field-header">
        {% if isEdited %}
            {% include 'lens/_components/analysis/_tooltip-lock' only %}
        {% endif %}
        <span class="lens-field-label">{{ label }}</span>
        {% if not isEdited and confidence and not (hideConfidence ?? false) %}
            <span class="badge" data-lens-target="confidence-badge">{{ (confidence * 100)|round }}%</span>
        {% endif %}
    </div>

    {% if hasSuggestion %}
        <div class="lens-ai-suggestion-inline">
            {% include 'lens/_components/analysis/_tooltip-ai' only %}
            <span>{{ suggestionValue }}</span>
        </div>
        {% if valuesMatch %}
            <div class="lens-applied-indicator">
                <span class="status on"></span>
                <span class="smalltext">{{ 'Applied'|t('lens') }}</span>
            </div>
        {% endif %}
    {% else %}
        <div class="lens-field-display">
            <p class="light">{{ 'No suggestion available'|t('lens') }}</p>
        </div>
    {% endif %}
</div>

{# ============================================================
   UNLOCKED / EDITING — Same component, different interaction mode.
   unlocked: asset edit page (suggestion display + apply button)
   editing:  review page (current value context + editable input)
   ============================================================ #}
{% elseif fieldState == 'unlocked' or fieldState == 'editing' %}

{% set isReview = fieldState == 'editing' %}

<div class="lens-accent-bar"
     {% if isReview %}
     data-lens-target="bridge-field"
     {% else %}
     data-lens-target="native-bridge"
     data-lens-field="{{ fieldName }}"
     data-lens-analysis-id="{{ analysisId }}"
     {% if siteId %}data-lens-site-id="{{ siteId }}"{% endif %}
     {% endif %}>

    <div class="lens-field-header" data-lens-target="field-header">
        {% if not isReview and isEdited %}
            {% include 'lens/_components/analysis/_tooltip-lock' only %}
        {% endif %}
        <span class="lens-field-label">{{ label }}</span>
        {% if isReview %}
            {% if confidence and confidence < 0.8 %}
                <span class="lens-confidence-badge lens-confidence-{{ (confidence * 100)|round >= 50 ? 'medium' : 'low' }}">
                    {{ (confidence * 100)|round }}%
                </span>
            {% endif %}
        {% else %}
            {% if not isEdited and confidence and not (hideConfidence ?? false) %}
                <span class="badge" data-lens-target="confidence-badge">{{ (confidence * 100)|round }}%</span>
            {% endif %}
        {% endif %}
    </div>

    {% if isReview %}
        {# Current asset value (static context — reviewer needs this) #}
        <div class="lens-native-current lens-native-current--context">
            <span class="lens-native-current-label">{{ 'Current asset value'|t('lens') }}:</span>
            {% if isNativeDefault %}
                <span class="light"><em>{{ nativeValue ?: 'Empty'|t('lens') }}</em></span>
                <span class="lens-native-chip lens-native-chip--auto">{{ nativeValue ? 'Auto-generated'|t('lens') : 'Empty'|t('lens') }}</span>
            {% elseif nativeValue %}
                <span>{{ nativeValue }}</span>
            {% else %}
                <span class="light"><em>{{ 'Empty'|t('lens') }}</em></span>
            {% endif %}
        </div>

        {# Editable suggestion input #}
        {% if inputType == 'textarea' %}
            <textarea class="text fullwidth" name="{{ fieldName }}" rows="2"{% if maxlength %} maxlength="{{ maxlength }}"{% endif %} data-lens-target="bridge-review-input"{% if aiValue ?? null %} data-lens-ai-value="{{ aiValue }}"{% endif %}>{{ suggestionValue }}</textarea>
        {% else %}
            <input type="text" class="text fullwidth" name="{{ fieldName }}" value="{{ suggestionValue }}"{% if maxlength %} maxlength="{{ maxlength }}"{% endif %} data-lens-target="bridge-review-input"{% if aiValue ?? null %} data-lens-ai-value="{{ aiValue }}"{% endif %}>
        {% endif %}

        {# Status line #}
        <div class="lens-native-status">
            {% if valuesMatch %}
                <span class="light">{{ 'Already applied to asset'|t('lens') }}</span>
            {% elseif hasSuggestion %}
                <span class="light">{{ 'Will be applied to the asset on approval'|t('lens') }}</span>
            {% endif %}
        </div>
    {% else %}
        {% if hasSuggestion %}
            <div class="lens-ai-suggestion-inline" data-lens-target="native-apply-row">
                {% include 'lens/_components/analysis/_tooltip-ai' only %}
                <span data-lens-target="bridge-suggestion-text">{{ suggestionValue }}</span>
                {% if valuesMatch %}
                    <span class="lens-applied-indicator">
                        <span class="status on"></span>
                        <span class="smalltext">{{ 'Applied'|t('lens') }}</span>
                    </span>
                {% else %}
                    <button type="button" class="lens-revert-trigger"
                            data-lens-target="native-apply-link"
                            data-lens-action="{{ applyAction }}"
                            data-lens-asset-id="{{ assetId }}"
                            data-lens-analysis-id="{{ analysisId }}"
                            {% if siteId %}data-lens-site-id="{{ siteId }}"{% endif %}>
                        {{ 'Apply to Asset'|t('lens') }}
                    </button>
                {% endif %}
            </div>
        {% else %}
            <div class="lens-field-display">
                <p class="light">{{ 'No suggestion available'|t('lens') }}</p>
            </div>
        {% endif %}
    {% endif %}

    {# AI suggestion inline — shows original AI value when suggestion has been edited #}
    {% if isReview %}
        {% set showBridgeAi = (aiValue ?? null) and aiValue != suggestionValue %}
        <div class="lens-ai-suggestion-inline" data-lens-target="bridge-review-ai"{% if not showBridgeAi %} hidden{% endif %}>
            {% include 'lens/_components/analysis/_tooltip-ai' only %}
            <span data-lens-target="bridge-review-ai-text">
                {% if showBridgeAi %}
                    {{ 'AI: "{value}"'|t('lens', {value: aiValue|truncate(60)}) }}
                {% endif %}
            </span>
            {% if aiValue ?? null %}
                <button type="button" class="lens-revert-trigger"
                        data-lens-action="bridge-review-revert"
                        data-lens-ai-value="{{ aiValue }}"{% if not showBridgeAi %} hidden{% endif %}>
                    {{ 'Revert to AI'|t('lens') }}
                </button>
            {% endif %}
        </div>
    {% endif %}
</div>

{% endif %}
