{#
 # Native Field Bridge — Suggestion-to-Asset Bridge Component
 #
 # Shows the AI suggestion with apply status. Used for title and alt text
 # (when AltField is in layout). The current asset value is NOT shown here —
 # the user can see it in Craft's native field above.
 #
 # Expected variables:
 #   fieldName       - string, the analysis field key (e.g. 'suggestedTitle', 'altText')
 #   label           - string, display label (e.g. 'Title', 'Alt Text')
 #   nativeValue     - string, current asset value ($asset->title or $asset->alt)
 #   isNativeDefault - bool, true if value is auto-generated/empty
 #   suggestionValue - string|null, AI suggestion (possibly user-edited)
 #   aiValue         - string|null, original AI value (before user edits)
 #   confidence      - float|null, AI confidence (0-1)
 #   inputType       - string, 'text' or 'textarea' (default: 'text')
 #   analysisId      - int, the analysis record ID
 #   assetId         - int|null, the asset ID
 #   fieldState      - 'readonly'|'unlocked'
 #   applyAction     - string, the data-lens-action value (e.g. 'apply-title', 'apply-alt')
 #   siteId          - int|null, optional site ID for per-site content (omit for primary site)
 #}

{% from 'lens/_components/analysis/_confidence-badge' import confidenceBadge %}

{% set inputType = inputType ?? 'text' %}
{% set siteId = siteId ?? null %}
{% set fieldState = fieldState ?? 'readonly' %}
{% set isEdited = (aiValue ?? null) is not null and suggestionValue != aiValue %}

{# Determine the status of the native value relative to the suggestion #}
{% set hasSuggestion = suggestionValue is defined and suggestionValue is not empty %}
{% set valuesMatch = hasSuggestion and nativeValue == suggestionValue %}

{# ============================================================
   READONLY — Suggestion display only. No apply buttons.
   ============================================================ #}
{% if fieldState == 'readonly' %}

<div class="lens-accent-bar">
    <div class="lens-field-header" data-lens-target="field-header">
        {% if isEdited %}
            {% include 'lens/_components/analysis/_tooltip-lock' only %}
        {% endif %}
        <span class="lens-field-label">{{ label }}</span>
        {% if not isEdited and confidence and not (hideConfidence ?? false) %}
            {{ confidenceBadge(confidence) }}
        {% endif %}
    </div>

    {% if hasSuggestion %}
        <div class="lens-ai-suggestion-inline">
            {% include 'lens/_components/analysis/_tooltip-ai' only %}
            <span>{{ suggestionValue }}</span>
            {% if valuesMatch %}
                <span class="lens-applied-indicator">
                    <span class="status on"></span>
                    <span class="smalltext">{{ 'Applied'|t('lens') }}</span>
                </span>
            {% endif %}
        </div>
    {% else %}
        <div class="lens-field-display">
            <p class="light">{{ 'No suggestion available'|t('lens') }}</p>
        </div>
    {% endif %}
</div>

{# ============================================================
   UNLOCKED — Asset edit page (suggestion display + apply button)
   ============================================================ #}
{% elseif fieldState == 'unlocked' %}

<div class="lens-accent-bar"
     data-lens-target="native-bridge"
     data-lens-field="{{ fieldName }}"
     data-lens-analysis-id="{{ analysisId }}"
     {% if siteId %}data-lens-site-id="{{ siteId }}"{% endif %}>

    <div class="lens-field-header" data-lens-target="field-header">
        {% if isEdited %}
            {% include 'lens/_components/analysis/_tooltip-lock' only %}
        {% endif %}
        <span class="lens-field-label">{{ label }}</span>
        {% if not isEdited and confidence and not (hideConfidence ?? false) %}
            {{ confidenceBadge(confidence) }}
        {% endif %}
    </div>

    {% if hasSuggestion %}
        <div class="lens-ai-suggestion-inline" data-lens-target="native-apply-row">
            {% include 'lens/_components/analysis/_tooltip-ai' only %}
            <span data-lens-target="bridge-suggestion-text">{{ suggestionValue }}</span>
            {% if valuesMatch %}
                <span class="lens-applied-indicator">
                    <span class="status on"></span>
                    <span class="smalltext">{{ 'Applied'|t('lens') }}</span>
                </span>
            {% else %}
                <button type="button" class="lens-revert-trigger"
                        data-lens-target="native-apply-link"
                        data-lens-action="{{ applyAction }}"
                        data-lens-asset-id="{{ assetId }}"
                        data-lens-analysis-id="{{ analysisId }}"
                        {% if siteId %}data-lens-site-id="{{ siteId }}"{% endif %}>
                    {{ 'Apply to Asset'|t('lens') }}
                </button>
            {% endif %}
        </div>
    {% else %}
        <div class="lens-field-display">
            <p class="light">{{ 'No suggestion available'|t('lens') }}</p>
        </div>
    {% endif %}
</div>

{% endif %}
