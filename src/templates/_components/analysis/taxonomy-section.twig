{#
 # Taxonomy Section
 # Tags (chip editor) with add/remove capability.
 # Auto-saves on each add/remove when fieldState == 'unlocked' (asset edit page).
 #
 # Expected variables: analysis, analysisTags, fieldState
 #}
{% set fieldState = fieldState ?? 'readonly' %}
{% set isInteractive = fieldState == 'unlocked' %}
{% set showTaxonomy = analysis.status not in [lens.status.pending, lens.status.processing, lens.status.failed] %}

{% if showTaxonomy %}
    {# Tags #}
    <div class="lens-editable-field" data-lens-target="tag-editor" data-lens-analysis-id="{{ analysis.id }}"{{ isInteractive ? ' data-lens-auto-save="1" data-lens-edit-mode="toggle"' }}>
        <div class="lens-field-header" data-lens-target="field-header">
            <span class="lens-field-label" data-lens-target="field-label">{{ 'Tags'|t('lens') }} ({{ analysisTags|length }})</span>
            {% if isInteractive %}
                {% include 'lens/_components/analysis/_tooltip-edit' with {editAction: 'taxonomy-edit'} only %}
            {% endif %}
        </div>

        <div class="lens-tag-chips" data-lens-target="tag-chips">
            {% for tag in analysisTags %}
                <a href="{{ cpUrl('assets', {source: 'lens:all', lensTag: tag.tag}) }}" class="chip" data-lens-tag="{{ tag.tag }}" data-lens-is-ai="{{ tag.isAi ? '1' : '0' }}" data-lens-confidence="{{ tag.confidence }}">
                    <div class="chip-content">
                        <span class="chip-label" data-lens-target="chip-label">{{ tag.tag }}</span>
                        {% if tag.confidence and not (hideConfidence ?? false) %}
                            <craft-tooltip text="{{ 'AI confidence for this tag'|t('lens') }}"><button type="button" class="badge">{{ (tag.confidence * 100)|round }}%</button></craft-tooltip>
                        {% endif %}
                        {% if isInteractive %}
                            <craft-tooltip text="{{ 'Remove'|t('lens') }}"><button type="button" class="lens-tag-remove" data-lens-action="tag-remove">&times;</button></craft-tooltip>
                        {% endif %}
                    </div>
                </a>
            {% endfor %}
        </div>

        {% if isInteractive %}
            <div class="lens-taxonomy-add-field" data-lens-target="tag-input-wrapper">
                <div class="lens-taxonomy-input-wrapper">
                    <input type="text" class="text small fullwidth" data-lens-control="tag-input" placeholder="{{ 'Add tag...'|t('lens') }}" maxlength="255">
                    <div class="lens-tag-suggestions" data-lens-target="tag-suggestions"></div>
                </div>
                <div class="lens-field-actions">
                    <button type="button" class="btn small submit" data-lens-action="tag-add">{{ 'Add'|t('lens') }}</button>
                    <button type="button" class="btn small" data-lens-action="taxonomy-done">{{ 'Done'|t('lens') }}</button>
                </div>
            </div>

            <template data-lens-target="tag-chip-template">
                <a href="" class="chip" data-lens-tag="" data-lens-is-ai="0" data-lens-confidence="">
                    <div class="chip-content">
                        <span class="chip-label" data-lens-target="chip-label"></span>
                        <craft-tooltip text="{{ 'Remove'|t('lens') }}"><button type="button" class="lens-tag-remove" data-lens-action="tag-remove">&times;</button></craft-tooltip>
                    </div>
                </a>
            </template>
        {% endif %}
    </div>

{% endif %}
