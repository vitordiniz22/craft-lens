{#
 # Taxonomy Section
 # Tags (chip editor) and Colors (swatch editor) with add/remove capability.
 #
 # Expected variables: analysis, analysisTags, analysisColors, static, isProcessing
 #}
{% set isProcessing = isProcessing ?? false %}
{% set showTaxonomy = analysis.status not in ['pending', 'processing', 'failed'] %}

{% if showTaxonomy %}
    {# Tags #}
    <div class="lens-tag-editor" data-lens-target="tag-editor" data-lens-analysis-id="{{ analysis.id }}">
        <div class="flex items-center gap-s mb-xs">
            <span class="lens-field-label">{{ 'Tags'|t('lens') }} ({{ analysisTags|length }})</span>
        </div>

        {% if analysisTags|length %}
            <div class="lens-tag-chips" data-lens-target="tag-chips">
                {% for tag in analysisTags %}
                    <a href="{{ cpUrl('lens/search', {tags: tag.tag}) }}" class="chip" data-lens-tag="{{ tag.tag }}" data-lens-is-ai="{{ tag.isAi ? '1' : '0' }}" data-lens-confidence="{{ tag.confidence }}">
                        <div class="chip-content">
                            <span class="chip-label">{{ tag.tag }}</span>
                            {% if tag.confidence %}
                                <span class="badge">{{ (tag.confidence * 100)|round }}%</span>
                            {% endif %}
                            {% if not static and not isProcessing %}
                                <button type="button" class="lens-tag-remove" data-lens-action="tag-remove" title="{{ 'Remove'|t('lens') }}">&times;</button>
                            {% endif %}
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}

        {% if not static and not isProcessing %}
            <div class="lens-tag-input-row">
                <input type="text" class="text small lens-tag-input" data-lens-control="tag-input" placeholder="{{ 'Add tag'|t('lens') }}">
                <button type="button" class="btn small lens-tag-add" data-lens-action="tag-add">{{ 'Add'|t('lens') }}</button>
                <div class="lens-tag-suggestions" data-lens-target="tag-suggestions"></div>
            </div>

            <template data-lens-target="tag-chip-template">
                <a href="" class="chip" data-lens-tag="" data-lens-is-ai="0" data-lens-confidence="">
                    <div class="chip-content">
                        <span class="chip-label"></span>
                        <button type="button" class="lens-tag-remove" data-lens-action="tag-remove" title="{{ 'Remove'|t('lens') }}">&times;</button>
                    </div>
                </a>
            </template>
        {% endif %}
    </div>

    {# Colors #}
    <div class="lens-color-editor mt-m" data-lens-target="color-editor" data-lens-analysis-id="{{ analysis.id }}">
        <div class="flex items-center gap-s mb-xs">
            <span class="lens-field-label">{{ 'Colors'|t('lens') }}</span>
        </div>

        {% if analysisColors|length %}
            <div class="lens-color-swatches" data-lens-target="color-swatches">
                {% for color in analysisColors %}
                    <div class="lens-color-item" data-lens-target="color-item" data-lens-hex="{{ color.hex }}" data-lens-is-ai="{{ color.isAi ? '1' : '0' }}" data-lens-percentage="{{ color.percentage }}">
                        <span class="lens-swatch lens-swatch--sm" style="background-color: {{ color.hex }}"></span>
                        <a href="{{ cpUrl('lens/search', {color: color.hex}) }}" data-lens-target="color-link">{{ color.hex }}</a>
                        {% if color.percentage %}
                            <span class="badge">{{ (color.percentage * 100)|round }}%</span>
                        {% endif %}
                        {% if not static and not isProcessing %}
                            <button type="button" class="lens-color-remove" data-lens-action="color-remove" title="{{ 'Remove'|t('lens') }}">&times;</button>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {% if not static and not isProcessing %}
            <div class="lens-color-add-row">
                <input type="color" class="lens-color-picker" data-lens-control="color-picker" value="#000000" title="{{ 'Pick color'|t('lens') }}">
                <button type="button" class="btn small lens-color-add" data-lens-action="color-add">{{ 'Add'|t('lens') }}</button>
            </div>

            <template data-lens-target="color-item-template">
                <div class="lens-color-item" data-lens-target="color-item" data-lens-hex="" data-lens-is-ai="0" data-lens-percentage="">
                    <span class="lens-swatch lens-swatch--sm" style=""></span>
                    <a href="" data-lens-target="color-link"></a>
                    <button type="button" class="lens-color-remove" data-lens-action="color-remove" title="{{ 'Remove'|t('lens') }}">&times;</button>
                </div>
            </template>
        {% endif %}
    </div>

    {# Save changes button (tags + colors) #}
    {% if not static and not isProcessing %}
        <div class="lens-taxonomy-save">
            <button type="button" class="btn small submit lens-taxonomy-save-btn" data-lens-action="taxonomy-save" data-lens-analysis-id="{{ analysis.id }}" disabled>
                {{ 'Save Changes'|t('lens') }}
            </button>
            <span class="lens-taxonomy-status smalltext light" data-lens-target="taxonomy-status" style="margin-left: 8px"></span>
        </div>
    {% endif %}
{% endif %}
