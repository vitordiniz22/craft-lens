{#
 # Taxonomy Section
 # Tags (chip editor) and Colors (swatch editor) with add/remove capability.
 #
 # Expected variables: analysis, analysisTags, analysisColors, static, isProcessing
 #}
{% set isProcessing = isProcessing ?? false %}

{# Tags #}
<div class="lens-tag-editor" data-analysis-id="{{ analysis.id }}">
    <div class="flex items-center gap-s mb-xs">
        <span class="lens-field-label">{{ 'Tags'|t('lens') }} ({{ analysisTags|length }})</span>
    </div>

    {% if analysisTags|length %}
        <div class="lens-tag-chips">
            {% for tag in analysisTags %}
                <div class="chip{% if tag.isAi %} chip--ai{% endif %}" data-tag="{{ tag.tag }}" data-is-ai="{{ tag.isAi ? '1' : '0' }}" data-confidence="{{ tag.confidence }}">
                    <div class="chip-content">
                        <a href="{{ cpUrl('lens/search', {tags: tag.tag}) }}" class="chip-label">{{ tag.tag }}</a>
                        {% if tag.confidence %}
                            <span class="badge">{{ (tag.confidence * 100)|round }}%</span>
                        {% endif %}
                        {% if not static and not isProcessing %}
                            <button type="button" class="lens-tag-remove" title="{{ 'Remove'|t('lens') }}">&times;</button>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p class="light smalltext mb-xs">{{ 'No tags detected'|t('lens') }}</p>
    {% endif %}

    {% if not static and not isProcessing %}
        <div class="lens-tag-input-row">
            <input type="text" class="text small lens-tag-input" placeholder="{{ 'Add tag...'|t('lens') }}">
            <button type="button" class="btn small lens-tag-add">{{ 'Add'|t('lens') }}</button>
            <div class="lens-tag-suggestions"></div>
        </div>
    {% endif %}
</div>

{# Colors #}
<div class="lens-color-editor mt-m" data-analysis-id="{{ analysis.id }}">
    <div class="flex items-center gap-s mb-xs">
        <span class="lens-field-label">{{ 'Colors'|t('lens') }}</span>
    </div>

    {% if analysisColors|length %}
        <div class="lens-color-swatches">
            {% for color in analysisColors %}
                <div class="lens-color-item{% if color.isAi %} lens-color-item--ai{% endif %}" data-hex="{{ color.hex }}" data-is-ai="{{ color.isAi ? '1' : '0' }}" data-percentage="{{ color.percentage }}">
                    <span class="lens-swatch lens-swatch--sm" style="background-color: {{ color.hex }}"></span>
                    <a href="{{ cpUrl('lens/search', {colorFamily: color.hex}) }}">{{ color.hex }}</a>
                    {% if color.percentage %}
                        <span class="badge">{{ (color.percentage * 100)|round }}%</span>
                    {% endif %}
                    {% if not static and not isProcessing %}
                        <button type="button" class="lens-color-remove" title="{{ 'Remove'|t('lens') }}">&times;</button>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p class="light smalltext mb-xs">{{ 'No colors detected'|t('lens') }}</p>
    {% endif %}

    {% if not static and not isProcessing %}
        <div class="lens-color-add-row">
            <input type="color" class="lens-color-picker" value="#000000" title="{{ 'Pick color'|t('lens') }}">
            <button type="button" class="btn small lens-color-add">{{ 'Add'|t('lens') }}</button>
        </div>
    {% endif %}
</div>

{# Save changes button (tags + colors) #}
{% if not static and not isProcessing %}
    <div class="lens-taxonomy-save">
        <button type="button" class="btn small submit lens-taxonomy-save-btn" data-analysis-id="{{ analysis.id }}" disabled>
            {{ 'Save Changes'|t('lens') }}
        </button>
        <span class="lens-taxonomy-status smalltext light" style="margin-left: 8px"></span>
    </div>
{% endif %}
