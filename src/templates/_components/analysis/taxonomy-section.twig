{#
 # Taxonomy Section
 # Tags (chip editor) and Colors (swatch editor) with add/remove capability.
 #
 # Expected variables: analysis, analysisTags, analysisColors, fieldState
 #}
{% set fieldState = fieldState ?? 'readonly' %}
{% set isInteractive = fieldState in ['unlocked', 'editing'] %}
{% set showTaxonomy = analysis.status not in ['pending', 'processing', 'failed'] %}

{% if showTaxonomy %}
    {# Tags #}
    <div class="lens-editable-field" data-lens-target="tag-editor" data-lens-analysis-id="{{ analysis.id }}">
        <div class="lens-field-header" data-lens-target="field-header">
            <span class="lens-field-label">{{ 'Tags'|t('lens') }} ({{ analysisTags|length }})</span>
        </div>

        {% if analysisTags|length %}
            <div class="lens-tag-chips" data-lens-target="tag-chips">
                {% for tag in analysisTags %}
                    <a href="{{ cpUrl('lens/search', {tags: tag.tag}) }}" class="chip" data-lens-tag="{{ tag.tag }}" data-lens-is-ai="{{ tag.isAi ? '1' : '0' }}" data-lens-confidence="{{ tag.confidence }}">
                        <div class="chip-content">
                            <span class="chip-label" data-lens-target="chip-label">{{ tag.tag }}</span>
                            {% if tag.confidence %}
                                <span class="badge">{{ (tag.confidence * 100)|round }}%</span>
                            {% endif %}
                            {% if isInteractive %}
                                <button type="button" class="lens-tag-remove" data-lens-action="tag-remove" title="{{ 'Remove'|t('lens') }}">&times;</button>
                            {% endif %}
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}

        {% if isInteractive %}
            <div class="lens-tag-input-row">
                <input type="text" class="text small lens-tag-input" data-lens-control="tag-input" placeholder="{{ 'Add tag'|t('lens') }}">
                <button type="button" class="btn small" data-lens-action="tag-add">{{ 'Add'|t('lens') }}</button>
                <div class="lens-tag-suggestions" data-lens-target="tag-suggestions"></div>
            </div>

            <template data-lens-target="tag-chip-template">
                <a href="" class="chip" data-lens-tag="" data-lens-is-ai="0" data-lens-confidence="">
                    <div class="chip-content">
                        <span class="chip-label" data-lens-target="chip-label"></span>
                        <button type="button" class="lens-tag-remove" data-lens-action="tag-remove" title="{{ 'Remove'|t('lens') }}">&times;</button>
                    </div>
                </a>
            </template>
        {% endif %}
    </div>

    {# Colors #}
    <div class="lens-editable-field" data-lens-target="color-editor" data-lens-analysis-id="{{ analysis.id }}">
        <div class="lens-field-header" data-lens-target="field-header">
            <span class="lens-field-label">{{ 'Colors'|t('lens') }} ({{ analysisColors|length }})</span>
        </div>

        {% if analysisColors|length %}
            <div class="lens-tag-chips" data-lens-target="color-swatches">
                {% for color in analysisColors %}
                    <a href="{{ cpUrl('lens/search', {color: color.hex}) }}" class="chip" data-lens-target="color-item" data-lens-hex="{{ color.hex }}" data-lens-is-ai="{{ color.isAi ? '1' : '0' }}" data-lens-percentage="{{ color.percentage }}">
                        <div class="chip-content">
                            <span class="lens-swatch lens-swatch--sm" data-lens-target="color-swatch" style="background-color: {{ color.hex }}"></span>
                            <span class="chip-label lens-color-hex" data-lens-target="chip-label">{{ color.hex }}</span>
                            {% if color.percentage %}
                                <span class="badge">{{ (color.percentage * 100)|round }}%</span>
                            {% endif %}
                            {% if isInteractive %}
                                <button type="button" class="lens-tag-remove" data-lens-action="color-remove" title="{{ 'Remove'|t('lens') }}">&times;</button>
                            {% endif %}
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}

        {% if isInteractive %}
            <div class="lens-color-add-row">
                <input type="color" class="lens-color-picker" data-lens-control="color-picker" value="#000000" title="{{ 'Pick color'|t('lens') }}">
                <button type="button" class="btn small" data-lens-action="color-add">{{ 'Add'|t('lens') }}</button>
            </div>

            <template data-lens-target="color-item-template">
                <a href="" class="chip" data-lens-target="color-item" data-lens-hex="" data-lens-is-ai="0" data-lens-percentage="">
                    <div class="chip-content">
                        <span class="lens-swatch lens-swatch--sm" data-lens-target="color-swatch"></span>
                        <span class="chip-label lens-color-hex" data-lens-target="chip-label"></span>
                        <button type="button" class="lens-tag-remove" data-lens-action="color-remove" title="{{ 'Remove'|t('lens') }}">&times;</button>
                    </div>
                </a>
            </template>
        {% endif %}
    </div>

    {# Save changes button (tags + colors) - only in unlocked mode #}
    {% if fieldState == 'unlocked' %}
        <div class="lens-taxonomy-save">
            <button type="button" class="btn small submit" data-lens-action="taxonomy-save" data-lens-analysis-id="{{ analysis.id }}" disabled>
                {{ 'Save Changes'|t('lens') }}
            </button>
            <span class="smalltext light" data-lens-target="taxonomy-status"></span>
        </div>
    {% endif %}
{% endif %}
