{#
 # Reusable Inline Editable Field — 3-State Pattern
 #
 # Expected variables:
 #   fieldName    - string, the field key (e.g. 'suggestedTitle')
 #   label        - string|null (optional), display label
 #   value        - string|null, current value
 #   aiValue      - string|null, original AI value
 #   confidence   - float|null, AI confidence (0-1)
 #   editedBy     - int|null, user ID who edited
 #   editedAt     - DateTime|null, when edited
 #   inputType    - string, 'text' or 'textarea' (default: 'text')
 #   featured     - bool, use featured styling (default: false)
 #   analysisId   - int, the analysis record ID
 #   fieldState   - 'readonly'|'unlocked'|'editing'
 #}

{% set isEdited = editedBy is not null %}
{% set inputType = inputType ?? 'text' %}
{% set featured = featured ?? false %}
{% set fieldState = fieldState ?? 'readonly' %}
{% set siteId = siteId ?? null %}
{% set fieldMaxLengths = { altText: 500, suggestedTitle: 255, longDescription: 5000, extractedText: 50000 } %}
{% set maxlength = fieldMaxLengths[fieldName] ?? null %}

{# ============================================================
   READONLY — Display only. No edit buttons. No JS hooks.
   ============================================================ #}
{% if fieldState == 'readonly' %}

<div class="lens-editable-field{% if featured %} lens-panel-featured{% endif %}">
    <div class="lens-field-header" data-lens-target="field-header">
        {% if isEdited %}
            {% include 'lens/_components/analysis/_tooltip-lock' only %}
        {% endif %}
        {% if label is defined and label %}
            <span class="lens-field-label">{{ label }}</span>
        {% endif %}
        {% if not isEdited and confidence and not (hideConfidence ?? false) %}
            <span class="badge" data-lens-target="confidence-badge">{{ (confidence * 100)|round }}%</span>
        {% endif %}
    </div>

    <div class="lens-field-display">
        {% if value %}
            {% if inputType == 'text' and featured %}
                <p class="lens-panel-title">{{ value }}</p>
            {% else %}
                <p>{{ value }}</p>
            {% endif %}
        {% else %}
            <p class="light">{{ 'Not available'|t('lens') }}</p>
        {% endif %}
    </div>
</div>

{# ============================================================
   UNLOCKED / EDITING — Same component, different interaction mode.
   unlocked: asset edit page (click-to-edit, auto-save via AJAX)
   editing:  review page (always editable, form-based submission)
   ============================================================ #}
{% elseif fieldState == 'unlocked' or fieldState == 'editing' %}

{% set isReview = fieldState == 'editing' %}

<div class="lens-editable-field{% if featured %} lens-panel-featured{% endif %}"
     {% if not isReview %}
     data-lens-target="editable-field"
     data-lens-field="{{ fieldName }}"
     data-lens-analysis-id="{{ analysisId }}"
     {% if siteId %}data-lens-site-id="{{ siteId }}"{% endif %}
     {% endif %}>

    <div class="lens-field-header" data-lens-target="field-header">
        {% if not isReview and isEdited %}
            {% include 'lens/_components/analysis/_tooltip-lock' only %}
        {% endif %}
        {% if label is defined and label %}
            <span class="lens-field-label">{{ label }}</span>
        {% endif %}
        {% if isReview %}
            {% if confidence and confidence < 0.8 %}
                <span class="lens-confidence-badge lens-confidence-{{ (confidence * 100)|round >= 50 ? 'medium' : 'low' }}">
                    {{ (confidence * 100)|round }}%
                </span>
            {% endif %}
        {% else %}
            {% if not isEdited and confidence and not (hideConfidence ?? false) %}
                <span class="badge" data-lens-target="confidence-badge">{{ (confidence * 100)|round }}%</span>
            {% endif %}
            {% include 'lens/_components/analysis/_tooltip-edit' with {editAction: 'field-edit'} only %}
        {% endif %}
    </div>

    {% if isReview %}
        {# Review: direct inputs with name attributes for form submit #}
        {% if inputType == 'textarea' %}
            <textarea class="text fullwidth" name="{{ fieldName }}" data-lens-control="field-{{ fieldName }}" rows="{{ fieldName == 'longDescription' ? 6 : 2 }}"{% if maxlength %} maxlength="{{ maxlength }}"{% endif %}>{{ value }}</textarea>
        {% else %}
            <input type="text" class="text fullwidth" name="{{ fieldName }}" data-lens-control="field-{{ fieldName }}" value="{{ value }}"{% if maxlength %} maxlength="{{ maxlength }}"{% endif %}>
        {% endif %}
    {% else %}
        {# Display mode #}
        <div class="lens-field-display" data-lens-target="field-display">
            {% if value %}
                {% if inputType == 'text' and featured %}
                    <p class="lens-panel-title">{{ value }}</p>
                {% else %}
                    <p>{{ value }}</p>
                {% endif %}
            {% else %}
                <p class="light">{{ 'Not available'|t('lens') }}</p>
            {% endif %}
        </div>

        {# Edit mode (hidden by default) #}
        <div class="lens-field-edit" data-lens-target="field-edit" hidden>
            {% if inputType == 'textarea' %}
                <textarea class="text fullwidth" rows="6"{% if maxlength %} maxlength="{{ maxlength }}"{% endif %}>{{ value }}</textarea>
            {% else %}
                <input type="text" class="text fullwidth" value="{{ value }}"{% if maxlength %} maxlength="{{ maxlength }}"{% endif %}>
            {% endif %}
            <div class="lens-field-actions">
                <button type="button" class="btn small submit" data-lens-action="field-save">{{ 'Save'|t('lens') }}</button>
                <button type="button" class="btn small" data-lens-action="field-cancel">{{ 'Cancel'|t('lens') }}</button>
            </div>
        </div>

        {# Provenance meta (always rendered, hidden when not edited) #}
        {% include 'lens/_components/analysis/edit-meta' with {
            editedBy: editedBy,
            editedAt: editedAt,
            target: 'field-edit-meta',
            isEdited: isEdited,
        } only %}
    {% endif %}

    {# AI suggestion #}
    {% if isReview %}
        {% if aiValue and aiValue != value %}
            <div class="lens-ai-suggestion-inline">
                {% include 'lens/_components/analysis/_tooltip-ai' only %}
                {{ 'AI: "{value}"'|t('lens', {value: aiValue|truncate(60)}) }}
            </div>
        {% endif %}
    {% else %}
        {% set showAiSuggestion = isEdited and aiValue and aiValue != value %}
        <div class="lens-ai-suggestion-inline" data-lens-target="field-ai-suggestion"{% if not showAiSuggestion %} hidden{% endif %}>
            {% include 'lens/_components/analysis/_tooltip-ai' only %}
            <span data-lens-target="ai-suggestion-text">
                {% if showAiSuggestion %}
                    {{ 'AI suggested: "{value}"'|t('lens', {value: aiValue|truncate(100)}) }}
                {% endif %}
            </span>
            <button type="button" class="lens-revert-trigger" data-lens-action="field-revert" data-lens-field="{{ fieldName }}" data-lens-analysis-id="{{ analysisId }}"{% if siteId %} data-lens-site-id="{{ siteId }}"{% endif %}{% if not showAiSuggestion %} hidden{% endif %}>
                {{ 'Revert to AI'|t('lens') }}
            </button>
        </div>
    {% endif %}
</div>

{% endif %}
