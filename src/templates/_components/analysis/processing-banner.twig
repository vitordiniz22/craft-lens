{#
 # Processing Banner
 # Shows processing state with appropriate messaging for initial vs. reprocessing.
 #
 # Expected variables:
 # - isReprocessing: boolean - true if existing data is being reprocessed
 # - hasExistingData: boolean - true if analysis has existing content
 #}

<div class="lens-processing-banner">
    <div class="lens-processing-banner-content">
        <div class="lens-processing-spinner">
            <svg class="lens-spinner-icon" width="16" height="16" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="37.7" stroke-dashoffset="9.4" stroke-linecap="round"/>
            </svg>
        </div>
        <div class="lens-processing-text">
            {% if isReprocessing %}
                <strong>{{ 'Re-analyzing asset'|t('lens') }}</strong>
                <p class="smalltext">{{ 'Current data is visible but locked during processing. The page will refresh when complete.'|t('lens') }}</p>
            {% else %}
                <strong>{{ 'Analyzing asset'|t('lens') }}</strong>
                <p class="smalltext">{{ 'AI analysis in progress. The page will refresh when complete.'|t('lens') }}</p>
            {% endif %}
        </div>
    </div>
</div>
