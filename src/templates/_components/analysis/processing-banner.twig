{#
 # Processing Banner
 # Shows processing state with appropriate messaging for initial vs. reprocessing.
 # Always rendered in DOM; visibility controlled by isVisible flag.
 #
 # Expected variables:
 # - isReprocessing: boolean - true if existing data is being reprocessed
 # - hasExistingData: boolean - true if analysis has existing content
 # - isVisible: boolean - whether the banner is currently shown
 #}

{% set isVisible = isVisible ?? false %}

<div data-lens-target="processing-banner"{% if not isVisible %} hidden{% endif %}>
    {% if isReprocessing or hasExistingData %}
        {% embed 'lens/_components/inline-notice' with {
            type: 'info',
            title: 'Re-analyzing asset'|t('lens'),
            message: 'Generating fresh AI suggestions for alt text, title, quality scores, and detection flags. Your manual edits will be preserved. Editing is locked until the analysis completes.'|t('lens'),
        } %}
            {% block action %}
                <div class="lens-inline-notice__action">
                    <button type="button" class="btn small submit"
                        data-lens-action="cancel-analysis"
                        data-lens-asset-id="{{ assetId }}">
                        {{ 'Cancel'|t('lens') }}
                    </button>
                </div>
            {% endblock %}
        {% endembed %}
    {% else %}
        {% embed 'lens/_components/inline-notice' with {
            type: 'info',
            title: 'Analyzing asset'|t('lens'),
            message: 'Generating alt text, title suggestions, quality scores, and detection flags using AI. This page will refresh automatically when the analysis is ready.'|t('lens'),
        } %}
            {% block action %}
                <div class="lens-inline-notice__action">
                    <button type="button" class="btn small submit"
                        data-lens-action="cancel-analysis"
                        data-lens-asset-id="{{ assetId }}">
                        {{ 'Cancel'|t('lens') }}
                    </button>
                </div>
            {% endblock %}
        {% endembed %}
    {% endif %}
</div>
