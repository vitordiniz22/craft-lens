{#
 # Processing Banner
 # Shows processing state with appropriate messaging for initial vs. reprocessing.
 # Always rendered in DOM; visibility controlled by isVisible flag.
 #
 # Expected variables:
 # - isReprocessing: boolean - true if existing data is being reprocessed
 # - hasExistingData: boolean - true if analysis has existing content
 # - isVisible: boolean - whether the banner is currently shown
 #}

{% set isVisible = isVisible ?? false %}

<div data-lens-target="processing-banner"{% if not isVisible %} hidden{% endif %}>
    {% if isReprocessing or hasExistingData %}
        {% include 'lens/_components/inline-notice' with {
            type: 'info',
            title: 'Re-analyzing asset'|t('lens'),
            message: 'Current data is visible but locked during processing. The page will refresh when complete.'|t('lens'),
        } %}
    {% else %}
        {% include 'lens/_components/inline-notice' with {
            type: 'info',
            title: 'Analyzing asset'|t('lens'),
            message: 'AI analysis in progress. The page will refresh when complete.'|t('lens'),
        } %}
    {% endif %}
</div>
