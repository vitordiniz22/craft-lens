{#
 # Analysis Panel Header
 #
 # Expected variables: analysis, asset, static
 #}

<div class="lens-panel-heading flex flex-justify items-center pb-s">
    <div class="field">
        <div class="heading">
            <label class="alt-label">{{ svg(craft.app.plugins.getPlugin('lens').basePath ~ '/icon.svg')|attr({width: 16, height: 16}) }} {{ 'Lens Analysis'|t('lens') }}</label>
        </div>
    </div>
    <div class="flex items-center gap-s">
        {% if analysis %}
            {% set showStatus = lens.isReviewActive or analysis.status in [lens.status.pending, lens.status.processing, lens.status.failed] %}
            {% if showStatus %}
                <div class="flex items-center gap-2xs">
                    {% switch analysis.status %}
                        {% case lens.status.pending %}
                            <span class="status"></span>{{ 'Pending'|t('lens') }}
                        {% case lens.status.processing %}
                            <span class="status pending"></span>{{ 'Processing'|t('lens') }}
                        {% case lens.status.completed %}
                            <span class="status on"></span>{{ 'Analyzed'|t('lens') }}
                        {% case lens.status.failed %}
                            <span class="status off"></span>{{ 'Failed'|t('lens') }}
                        {% case lens.status.pendingReview %}
                            <span class="status pending"></span>{{ 'Pending Review'|t('lens') }}
                        {% case lens.status.approved %}
                            <span class="status on"></span>{{ 'Approved'|t('lens') }}
                        {% case lens.status.rejected %}
                            <span class="status off"></span>{{ 'Rejected'|t('lens') }}
                    {% endswitch %}
                </div>
            {% endif %}
        {% endif %}
        {% if analysis and not static and analysis.status not in [lens.status.processing, lens.status.failed] %}
            <button type="button" class="btn small" data-lens-action="reprocess" data-lens-asset-id="{{ asset.id }}" data-lens-loading-text="{{ 'Processing'|t('lens') }}">
                <div class="spinner small"></div>
                <span class="label" data-lens-target="button-label">{{ 'Re-analyze'|t('lens') }}</span>
            </button>
        {% endif %}
    </div>
</div>

{% if analysis and analysis.processedAt %}
    <div class="lens-panel-meta">
        {% set providerNames = {
            'openai': 'OpenAI',
            'gemini': 'Gemini',
            'claude': 'Claude'
        } %}
        {% if analysis.status == lens.status.failed %}
            {{ 'Failed {time}'|t('lens', {time: analysis.processedAt|date('short')}) }}
        {% else %}
            {{ 'Analyzed {time}'|t('lens', {time: analysis.processedAt|date('short')}) }}
        {% endif %}
        {% if analysis.provider %}
            &middot; {{ providerNames[analysis.provider] ?? analysis.provider|capitalize }}
            {%- if analysis.providerModel %} ({{ analysis.providerModel }}){% endif %}
        {% endif %}
        {% if lens.isPro and analysis.actualCost %}
            &middot; ${{ analysis.actualCost|number_format(4) }}
        {% endif %}
    </div>
{% endif %}
