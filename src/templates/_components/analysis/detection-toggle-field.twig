{#
 # Detection Toggle Field — 3-State Pattern
 # Binary detection toggle with icon, status badge, and segmented control.
 #
 # Expected variables:
 #   icon           - string (iconSvg name, e.g., 'shield-halved')
 #   fieldName      - string (e.g., 'nsfwScore', 'hasWatermark', 'containsBrandLogo')
 #   label          - string
 #   detected       - bool, current detection value
 #   detectedAi     - bool, AI detection value
 #   editedBy       - int|null
 #   editedAt       - DateTime|null
 #   analysisId     - int
 #   fieldState     - 'readonly'|'unlocked'|'editing'
 #   detectedLabel  - string (e.g., 'NSFW content present')
 #   clearedLabel   - string (e.g., 'No NSFW content')
 #   trueValue      - mixed (value to send when "detected", e.g., 1.0 for nsfwScore, 1 for bools)
 #   falseValue     - mixed (value to send when "not detected", e.g., 0)
 #   confidence     - float|null (optional, 0.0-1.0 AI confidence score)
 #   details        - string[] (optional, contextual labels shown inside accent bar when flagged)
 #   detailClass    - string (optional, CSS class for detail chips, default 'lens-detail-chip')
 #}

{% set fieldState = fieldState ?? 'readonly' %}
{% set icon = icon ?? 'circle-question' %}
{% set isEdited = editedBy is not null %}

{# ============================================================
   READONLY — Icon + label + badge. No interactions.
   ============================================================ #}
{% if fieldState == 'readonly' %}

<div class="lens-editable-field lens-detection-row{{ detected ? ' lens-accent-bar lens-accent-bar--red' : '' }}">
    <div class="lens-field-header" data-lens-target="field-header">
        <span class="lens-detection-icon{{ detected ? ' lens-detection-icon--flagged' : '' }}" data-lens-target="detection-icon">
            {{ iconSvg(icon)|attr({width: 12, height: 12, fill: 'currentColor'}) }}
        </span>
        {% if isEdited %}
            <span class="lens-lock-icon" data-lens-target="lock-icon" title="{{ 'Protected from reprocessing'|t('lens') }}">&#128274;</span>
        {% endif %}
        <span class="lens-field-label">{{ label }}</span>
        {% if not isEdited and (confidence ?? null) and not (hideConfidence ?? false) %}
            <span class="badge">{{ (confidence * 100)|round }}%</span>
        {% endif %}
        <span class="lens-detection-badge {{ detected ? 'lens-detection-badge--flagged' : 'lens-detection-badge--clear' }}">
            {% if detected %}
                {{ iconSvg('triangle-exclamation')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                {{ 'Flagged'|t('lens') }}
            {% else %}
                {{ iconSvg('check')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                {{ 'Clear'|t('lens') }}
            {% endif %}
        </span>
    </div>

    {% if (details ?? [])|length %}
        <div class="lens-detection-detail">
            {% for detail in details %}
                <span class="{{ detailClass ?? 'lens-detail-chip' }}">{{ detail }}</span>
            {% endfor %}
        </div>
    {% endif %}
</div>

{# ============================================================
   UNLOCKED / EDITING — Same component, different interaction mode.
   unlocked: asset edit page (click-to-edit, auto-save via AJAX)
   editing:  review page (always editable, form-based submission)
   ============================================================ #}
{% elseif fieldState == 'unlocked' or fieldState == 'editing' %}

{% set isReview = fieldState == 'editing' %}

<div class="lens-editable-field lens-detection-row{{ detected ? ' lens-accent-bar lens-accent-bar--red' : '' }}"
     data-lens-target="detection-toggle"
     data-lens-field="{{ fieldName }}"
     {% if not isReview %}data-lens-analysis-id="{{ analysisId }}"{% endif %}
     {% if not isReview %}data-lens-detected="{{ detected ? '1' : '0' }}"{% endif %}
     data-lens-detected-ai="{{ detectedAi ? '1' : '0' }}"
     {% if not isReview %}data-lens-true-value="{{ trueValue }}"{% endif %}
     {% if not isReview %}data-lens-false-value="{{ falseValue }}"{% endif %}>

    <div class="lens-field-header" data-lens-target="field-header">
        <span class="lens-detection-icon{{ detected ? ' lens-detection-icon--flagged' : '' }}" data-lens-target="detection-icon">
            {{ iconSvg(icon)|attr({width: 12, height: 12, fill: 'currentColor'}) }}
        </span>
        {% if not isReview and isEdited %}
            <span class="lens-lock-icon" data-lens-target="lock-icon" title="{{ 'Protected from reprocessing'|t('lens') }}">&#128274;</span>
        {% endif %}
        <span class="lens-field-label">{{ label }}</span>
        {% if (isReview or not isEdited) and (confidence ?? null) and not (hideConfidence ?? false) %}
            <span class="badge"{% if not isReview %} data-lens-target="confidence-badge"{% endif %}>{{ (confidence * 100)|round }}%</span>
        {% endif %}
        {% if not isReview %}
            <button type="button" class="lens-edit-trigger" data-lens-action="detection-edit" title="{{ 'Edit'|t('lens') }}">&#9998;</button>
        {% endif %}
        <span class="lens-detection-badge {{ detected ? 'lens-detection-badge--flagged' : 'lens-detection-badge--clear' }}" data-lens-target="detection-badge">
            {% if detected %}
                {{ iconSvg('triangle-exclamation')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                {{ 'Flagged'|t('lens') }}
            {% else %}
                {{ iconSvg('check')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                {{ 'Clear'|t('lens') }}
            {% endif %}
        </span>
    </div>

    {# Segmented control — hidden by default in unlocked, always visible in review #}
    <div{% if not isReview %} class="lens-field-edit" data-lens-target="detection-edit-panel" hidden{% endif %}>
        <div class="lens-segmented-control">
            <label class="lens-segmented-control__option">
                <input type="radio" name="detection-{{ fieldName }}{% if not isReview %}-{{ analysisId }}{% endif %}" value="{{ trueValue }}"
                       data-lens-control="{{ isReview ? 'detection-radio-review' : 'detection-radio' }}"
                       {% if isReview %}data-lens-field="{{ fieldName }}"{% endif %}
                       {% if detected %}checked{% endif %}>
                <span class="lens-segmented-control__icon lens-segmented-control__icon--flagged">
                    {{ iconSvg('triangle-exclamation')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                </span>
                <span>{{ 'Flagged'|t('lens') }}</span>
            </label>
            <label class="lens-segmented-control__option">
                <input type="radio" name="detection-{{ fieldName }}{% if not isReview %}-{{ analysisId }}{% endif %}" value="{{ falseValue }}"
                       data-lens-control="{{ isReview ? 'detection-radio-review' : 'detection-radio' }}"
                       {% if isReview %}data-lens-field="{{ fieldName }}"{% endif %}
                       {% if not detected %}checked{% endif %}>
                <span class="lens-segmented-control__icon lens-segmented-control__icon--clear">
                    {{ iconSvg('check')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                </span>
                <span>{{ 'Clear'|t('lens') }}</span>
            </label>
        </div>

        {% if not isReview %}
            {# Hidden input to hold selected value #}
            <input type="hidden" data-lens-target="detection-value" value="{{ detected ? trueValue : falseValue }}">

            {# Cancel link to close without saving #}
            <div class="lens-field-actions">
                <button type="button" class="btn small" data-lens-action="detection-cancel">{{ 'Cancel'|t('lens') }}</button>
            </div>
        {% endif %}
    </div>

    {# AI suggestion — purple bar, shown when value differs from AI #}
    {% set aiDiffers = isReview ? (detectedAi != detected) : (isEdited and (detectedAi != detected)) %}
    <div class="lens-ai-suggestion-inline" data-lens-target="detection-ai-suggestion"{% if not aiDiffers %} hidden{% endif %}>
        <span class="lens-ai-suggestion-icon">{{ iconSvg('wand-magic-sparkles')|attr({width: 12, height: 12}) }}</span>
        <span data-lens-target="detection-ai-text">
            {{ 'AI suggested: "{value}"'|t('lens', {value: detectedAi ? detectedLabel : clearedLabel}) }}
        </span>
        {% if not isReview %}
            <button type="button" class="lens-revert-trigger" data-lens-action="detection-revert" data-lens-field="{{ fieldName }}" data-lens-analysis-id="{{ analysisId }}"{% if not aiDiffers %} hidden{% endif %}>
                {{ 'Revert to AI'|t('lens') }}
            </button>
        {% endif %}
    </div>

    {% if not isReview %}
        {# Provenance meta (always rendered, hidden when not edited) #}
        {% include 'lens/_components/analysis/edit-meta' with {
            editedBy: editedBy,
            editedAt: editedAt,
            target: 'detection-edit-meta',
            isEdited: isEdited,
        } only %}
    {% endif %}

    {% if (details ?? [])|length %}
        <div class="lens-detection-detail">
            {% for detail in details %}
                <span class="{{ detailClass ?? 'lens-detail-chip' }}">{{ detail }}</span>
            {% endfor %}
        </div>
    {% endif %}
</div>

{% endif %}
