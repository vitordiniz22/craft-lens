{#
 # Similar Assets Notice
 # Inline notice with thumbnail strip for duplicate/similar asset alerts.
 # Embeds the shared inline-notice component with a custom body block.
 #
 # Expected variables: similarImages, totalSimilarCount, asset, static, isProcessing, variant (optional: 'review')
 #}
{% set isReview = (variant ?? '') == 'review' %}
{% set totalCount = totalSimilarCount ?? similarImages|length %}
{% set extraCount = totalCount - similarImages|length %}

{% if similarImages|length %}
    {% embed 'lens/_components/inline-notice' with {
        type: 'info',
        icon: 'clone',
        title: totalCount ~ ' ' ~ (totalCount == 1 ? 'Similar Asset'|t('lens') : 'Similar Assets'|t('lens')),
        attr: {'data-lens-target': 'similar-assets-notice'}
    } %}
        {% block body %}
            <div class="lens-inline-notice__thumbnails">
                {% for img in similarImages %}
                    <a href="{{ img.editUrl }}"
                       class="lens-inline-notice__thumb"
                       title="{{ img.filename }}">
                        <img src="{{ img.thumbnailUrl }}"
                             alt="{{ img.filename }}"
                             loading="lazy">
                        <span class="lens-inline-notice__thumb-label">
                            {{ (img.similarity * 100)|round }}%
                        </span>
                    </a>
                {% endfor %}
                {% if extraCount > 0 %}
                    <span class="lens-inline-notice__thumb-more"
                          title="{{ '+{count} more similar assets'|t('lens', {count: extraCount}) }}">
                        +{{ extraCount }}
                    </span>
                {% endif %}
            </div>
        {% endblock %}
    {% endembed %}
{% endif %}
