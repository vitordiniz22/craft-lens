{#
 # Similar Assets Notice
 # Inline notice with thumbnail strip for duplicate/similar asset alerts.
 # Embeds the shared inline-notice component with a custom body block.
 #
 # Expected variables: similarImages, asset, static, isProcessing, variant (optional: 'review')
 #}
{% set isReview = (variant ?? '') == 'review' %}

{% if similarImages|length %}
    {% embed 'lens/_components/inline-notice' with {
        type: isReview ? 'neutral' : 'info',
        icon: 'clone',
        title: similarImages|length ~ ' ' ~ (similarImages|length == 1 ? 'Similar Asset Found'|t('lens') : 'Similar Assets Found'|t('lens')),
        attr: {'data-lens-target': 'similar-assets-notice'}
    } %}
        {% block body %}
            <div class="lens-notice-thumbnails">
                {% for img in similarImages %}
                    <a href="{{ img.editUrl }}"
                       class="lens-notice-thumb"
                       title="{{ img.filename }}">
                        <img src="{{ img.thumbnailUrl }}"
                             alt="{{ img.filename }}"
                             loading="lazy">
                        <span class="lens-notice-thumb-label">
                            {{ (img.similarity * 100)|round }}%
                        </span>
                    </a>
                {% endfor %}
            </div>
        {% endblock %}

        {% block action %}
            {% if not isReview and not (static ?? false) and not (isProcessing ?? false) %}
                <div class="lens-notice-action">
                    <button type="button" class="btn small" data-lens-action="find-similar" data-lens-asset-id="{{ asset.id }}">
                        {{ 'Find Similar Assets'|t('lens') }}
                    </button>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
{% endif %}
