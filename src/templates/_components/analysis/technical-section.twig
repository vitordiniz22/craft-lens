{#
 # Technical Info Section
 # EXIF/Camera metadata in compact key-value layout.
 #
 # Expected variables: analysis, exifData
 #}

{% if exifData %}
    <div class="lens-exif-grid">
        {% if exifData.cameraMake or exifData.cameraModel %}
            <span class="lens-exif-label">{{ 'Camera'|t('lens') }}</span>
            <span class="lens-exif-value">{{ [exifData.cameraMake, exifData.cameraModel]|filter|join(' ') }}</span>
        {% endif %}
        {% if exifData.lens %}
            <span class="lens-exif-label">{{ 'Lens'|t('lens') }}</span>
            <span class="lens-exif-value">{{ exifData.lens }}</span>
        {% endif %}
        {% if exifData.focalLength %}
            <span class="lens-exif-label">{{ 'Focal Length'|t('lens') }}</span>
            <span class="lens-exif-value">{{ exifData.focalLength }}</span>
        {% endif %}
        {% if exifData.aperture %}
            <span class="lens-exif-label">{{ 'Aperture'|t('lens') }}</span>
            <span class="lens-exif-value">{{ exifData.aperture }}</span>
        {% endif %}
        {% if exifData.shutterSpeed %}
            <span class="lens-exif-label">{{ 'Shutter'|t('lens') }}</span>
            <span class="lens-exif-value">{{ exifData.shutterSpeed }}</span>
        {% endif %}
        {% if exifData.iso %}
            <span class="lens-exif-label">{{ 'ISO'|t('lens') }}</span>
            <span class="lens-exif-value">{{ exifData.iso }}</span>
        {% endif %}
        {% if exifData.dateTaken %}
            <span class="lens-exif-label">{{ 'Date Taken'|t('lens') }}</span>
            <span class="lens-exif-value">{{ exifData.dateTaken|datetime('short') }}</span>
        {% endif %}
        {% if exifData.latitude and exifData.longitude %}
            <span class="lens-exif-label">{{ 'Location'|t('lens') }}</span>
            <span class="lens-exif-value">
                <a href="https://www.openstreetmap.org/?mlat={{ exifData.latitude }}&mlon={{ exifData.longitude }}#map=15/{{ exifData.latitude }}/{{ exifData.longitude }}" target="_blank" rel="noopener">
                    {{ exifData.latitude|round(4) }}, {{ exifData.longitude|round(4) }}
                </a>
            </span>
        {% endif %}
    </div>
{% else %}
    <p class="light smalltext">{{ 'No EXIF metadata available'|t('lens') }}</p>
{% endif %}
