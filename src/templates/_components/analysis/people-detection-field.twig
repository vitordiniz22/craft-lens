{#
 # People Detection Inline Editor — 2-State Pattern
 # Icon + badge display, native radios with auto-save
 #
 # Expected variables:
 #   analysis     - AssetAnalysisRecord
 #   fieldState   - 'readonly'|'unlocked'
 #}

{# Macro for consistent text generation (matches JS utility: Lens.utils.formatPeopleDetectionText) #}
{% macro peopleDetectionText(containsPeople, faceCount) %}
    {%- if not containsPeople -%}
        {{ 'No people'|t('lens') }}
    {%- elseif faceCount == 0 -%}
        {{ 'People, no visible faces'|t('lens') }}
    {%- elseif faceCount == 1 -%}
        {{ '1 person'|t('lens') }}
    {%- elseif faceCount == 2 -%}
        {{ '2 people'|t('lens') }}
    {%- elseif faceCount >= 3 and faceCount <= 5 -%}
        {{ '3-5 people'|t('lens') }}
    {%- elseif faceCount >= 6 -%}
        {{ '6+ people'|t('lens') }}
    {%- endif -%}
{% endmacro %}

{# Macro for help text below people detection (shared by readonly + unlocked states) #}
{% macro peopleHelpText(hasPeople, faceCount) %}
    {%- if hasPeople and faceCount > 0 -%}
        {{ 'Identifiable faces detected. Model releases may be required for commercial use.'|t('lens') }}
    {%- elseif hasPeople -%}
        {{ 'People visible, but no faces identifiable. Usually safe to use without a release.'|t('lens') }}
    {%- endif -%}
{% endmacro %}

{# Macro for radio options — native radios (compact) #}
{% macro radioOptions(analysis, controlName) %}
    <label class="lens-radio-option">
        <input type="radio" name="people-{{ analysis.id }}" value="none" data-lens-control="{{ controlName }}"
               {% if not analysis.containsPeople %}checked{% endif %}>
        <span>{{ 'No people'|t('lens') }}</span>
    </label>

    <label class="lens-radio-option">
        <input type="radio" name="people-{{ analysis.id }}" value="no-faces" data-lens-control="{{ controlName }}"
               {% if analysis.containsPeople and analysis.faceCount == 0 %}checked{% endif %}>
        <span>{{ 'People, no visible faces'|t('lens') }}</span>
    </label>

    <label class="lens-radio-option">
        <input type="radio" name="people-{{ analysis.id }}" value="1" data-lens-control="{{ controlName }}"
               {% if analysis.containsPeople and analysis.faceCount == 1 %}checked{% endif %}>
        <span>{{ '1 person'|t('lens') }}</span>
    </label>

    <label class="lens-radio-option">
        <input type="radio" name="people-{{ analysis.id }}" value="2" data-lens-control="{{ controlName }}"
               {% if analysis.containsPeople and analysis.faceCount == 2 %}checked{% endif %}>
        <span>{{ '2 people'|t('lens') }}</span>
    </label>

    <label class="lens-radio-option">
        <input type="radio" name="people-{{ analysis.id }}" value="3-5" data-lens-control="{{ controlName }}"
               {% if analysis.containsPeople and analysis.faceCount >= 3 and analysis.faceCount <= 5 %}checked{% endif %}>
        <span>{{ '3-5 people'|t('lens') }}</span>
    </label>

    <label class="lens-radio-option">
        <input type="radio" name="people-{{ analysis.id }}" value="6+" data-lens-control="{{ controlName }}"
               {% if analysis.containsPeople and analysis.faceCount >= 6 %}checked{% endif %}>
        <span>{{ '6+ people'|t('lens') }}</span>
    </label>
{% endmacro %}

{% from 'lens/_components/analysis/_confidence-badge' import confidenceBadge %}

{% set fieldState = fieldState ?? 'readonly' %}
{% set isEdited = (analysis.containsPeopleAi is defined and analysis.containsPeople != analysis.containsPeopleAi)
    or (analysis.faceCountAi is defined and analysis.faceCount != analysis.faceCountAi) %}
{% set hasPeople = analysis.containsPeople %}

{# ============================================================
   READONLY — Icon + label + badge. No interactions.
   ============================================================ #}
{% if fieldState == 'readonly' %}

<div class="lens-editable-field lens-editable-field--detection">
    <div class="lens-field-header" data-lens-target="field-header">
        <span class="lens-detection-icon" data-lens-target="detection-icon">
            {{ iconSvg('user')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
        </span>
        {% if isEdited %}
            {% include 'lens/_components/analysis/_tooltip-lock' only %}
        {% endif %}
        <span class="lens-field-label">{{ 'People Detection'|t('lens') }}</span>
        {% if not isEdited and analysis.containsPeopleConfidence is defined and analysis.containsPeopleConfidence and not (hideConfidence ?? false) %}
            {{ confidenceBadge(analysis.containsPeopleConfidence, 'simple') }}
        {% endif %}
        {% if hasPeople %}
            <span class="lens-detection-badge lens-detection-badge--info">
                {{ iconSvg('user')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                {{ _self.peopleDetectionText(analysis.containsPeople, analysis.faceCount) }}
            </span>
        {% else %}
            <span class="lens-detection-badge lens-detection-badge--clear">
                {{ iconSvg('check')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                {{ 'No people'|t('lens') }}
            </span>
        {% endif %}
    </div>

    {% if hasPeople %}
        <p class="lens-detection-help">
            <span class="lens-detection-help__icon">{{ iconSvg('lightbulb')|attr({width: 12, height: 12, fill: 'currentColor'}) }}</span>
            {{ _self.peopleHelpText(hasPeople, analysis.faceCount) }}
        </p>
    {% endif %}
</div>

{# ============================================================
   UNLOCKED — Asset edit page (click pencil to edit, AJAX save)
   ============================================================ #}
{% elseif fieldState == 'unlocked' %}

<div class="lens-editable-field lens-editable-field--detection"
     data-lens-target="people-detection"
     data-lens-analysis-id="{{ analysis.id }}"
     data-lens-contains-people="{{ analysis.containsPeople ? '1' : '0' }}"
     data-lens-face-count="{{ analysis.faceCount }}"
     data-lens-contains-people-ai="{{ analysis.containsPeopleAi ? '1' : '0' }}"
     data-lens-face-count-ai="{{ analysis.faceCountAi }}">

    <div class="lens-field-header" data-lens-target="field-header">
        <span class="lens-detection-icon" data-lens-target="detection-icon">
            {{ iconSvg('user')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
        </span>
        {% if isEdited %}
            {% include 'lens/_components/analysis/_tooltip-lock' only %}
        {% endif %}
        <span class="lens-field-label">{{ 'People Detection'|t('lens') }}</span>
        {% if not isEdited and analysis.containsPeopleConfidence is defined and analysis.containsPeopleConfidence and not (hideConfidence ?? false) %}
            {{ confidenceBadge(analysis.containsPeopleConfidence) }}
        {% endif %}
        {% include 'lens/_components/analysis/_tooltip-edit' with {editAction: 'people-edit'} only %}
        <span class="lens-detection-badge {{ hasPeople ? 'lens-detection-badge--info' : 'lens-detection-badge--clear' }}" data-lens-target="people-badge">
            {% if hasPeople %}
                {{ iconSvg('user')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                <span data-lens-target="people-display-text">{{ _self.peopleDetectionText(analysis.containsPeople, analysis.faceCount) }}</span>
            {% else %}
                {{ iconSvg('check')|attr({width: 12, height: 12, fill: 'currentColor'}) }}
                <span data-lens-target="people-display-text">{{ 'No people'|t('lens') }}</span>
            {% endif %}
        </span>
    </div>

    {# Display mode — help text #}
    <div data-lens-target="field-display">
        <div data-lens-target="people-present"{% if not hasPeople %} hidden{% endif %}>
            <p class="lens-detection-help" data-lens-target="people-help-text">
                <span class="lens-detection-help__icon">{{ iconSvg('lightbulb')|attr({width: 12, height: 12, fill: 'currentColor'}) }}</span>
                {{ _self.peopleHelpText(hasPeople, analysis.faceCount) }}
            </p>
        </div>
        <div data-lens-target="people-absent"{% if hasPeople %} hidden{% endif %}></div>
    </div>

    {# Radios (hidden by default; revealed on edit click) #}
    <div class="lens-field-edit" data-lens-target="people-edit-panel" hidden>
        <div class="lens-radio-list">
            {{ _self.radioOptions(analysis, 'people-mode') }}
        </div>
        <div class="lens-field-actions">
            <button type="button" class="btn small" data-lens-action="people-cancel">{{ 'Close'|t('lens') }}</button>
        </div>
    </div>

    {# AI suggestion — purple bar, shown when value differs from AI #}
    {% set aiDiffers = (analysis.containsPeopleAi != analysis.containsPeople) or (analysis.faceCountAi != analysis.faceCount) %}
    <div class="lens-ai-suggestion-inline" data-lens-target="people-ai-suggestion"{% if not aiDiffers %} hidden{% endif %}>
        {% include 'lens/_components/analysis/_tooltip-ai' only %}
        <span data-lens-target="people-ai-text">
            "{{ _self.peopleDetectionText(analysis.containsPeopleAi, analysis.faceCountAi) }}"
        </span>
        <button type="button" class="lens-revert-trigger" data-lens-action="people-revert" data-lens-analysis-id="{{ analysis.id }}"{% if not aiDiffers %} hidden{% endif %}>
            {{ 'Revert to AI'|t('lens') }}
        </button>
    </div>

</div>

{% endif %}
