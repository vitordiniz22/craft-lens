{#
 # People Detection Inline Editor
 # Custom component for editing containsPeople + faceCount together
 #
 # Expected variables:
 #   analysis          - AssetAnalysisRecord
 #   static            - bool, disable editing (Craft preview or locked state)
 #   isProcessing      - bool, disable during reprocessing
 #
 # NOTE: Review area uses JS rendering (lens-review.js), this template is only for asset edit page
 #}

{# Macro for consistent text generation (matches JS utility: Lens.utils.formatPeopleDetectionText) #}
{% macro peopleDetectionText(containsPeople, faceCount) %}
    {%- if not containsPeople -%}
        {{ 'No people present'|t('lens') }}
    {%- elseif faceCount == 0 -%}
        {{ 'People present, no visible faces'|t('lens') }}
    {%- elseif faceCount == 1 -%}
        {{ 'Individual (1 person)'|t('lens') }}
    {%- elseif faceCount == 2 -%}
        {{ 'Duo (2 people)'|t('lens') }}
    {%- elseif faceCount >= 3 and faceCount <= 5 -%}
        {{ 'Small group (3-5 people)'|t('lens') }}
    {%- elseif faceCount >= 6 -%}
        {{ 'Large group (6+ people)'|t('lens') }}
    {%- endif -%}
{% endmacro %}

{% set isProcessing = isProcessing ?? false %}
{% set readOnly = (static ?? false) or (analysis.status == 'pending_review') or isProcessing %}
{% set isPeopleEdited = analysis.containsPeopleEditedBy is not null %}
{% set isFaceCountEdited = analysis.faceCountEditedBy is not null %}
{% set isEdited = isPeopleEdited or isFaceCountEdited %}

{# Always show component - allows correcting AI false negatives #}
<div class="lens-people-detection lens-editable-field"
     data-analysis-id="{{ analysis.id }}"
     data-contains-people="{{ analysis.containsPeople ? '1' : '0' }}"
     data-face-count="{{ analysis.faceCount }}"
     data-contains-people-ai="{{ analysis.containsPeopleAi ? '1' : '0' }}"
     data-face-count-ai="{{ analysis.faceCountAi }}"
     data-context="asset-edit">

    <div class="lens-field-header">
        {% if isEdited %}
            <span class="lens-lock-icon" title="{{ 'Protected from reprocessing'|t('lens') }}">&#128274;</span>
        {% endif %}

        <span class="lens-field-label">{{ 'People Detection'|t('lens') }}</span>

        {% if not readOnly %}
            <button type="button" class="lens-edit-trigger" data-action="people-edit" title="{{ 'Edit'|t('lens') }}">&#9998;</button>
        {% endif %}
    </div>

    {# Display mode - always visible #}
    <div class="lens-field-display">
        {% if analysis.containsPeople %}
            {# People detected - show tier #}
            <div class="lens-detection-item">
                <div>
                    <div class="flex items-center gap-s">
                        <span class="status on"></span>
                        <strong class="lens-people-display-text">
                            {{ _self.peopleDetectionText(analysis.containsPeople, analysis.faceCount) }}
                        </strong>
                    </div>
                    <p class="smalltext light lens-people-help-text" style="margin: 4px 0 0">
                        {% if analysis.faceCount > 0 %}
                            {{ 'May require model releases for commercial use'|t('lens') }}
                        {% else %}
                            {{ 'People visible but faces obscured. May still require releases for commercial use.'|t('lens') }}
                        {% endif %}
                    </p>
                </div>
            </div>
        {% else %}
            {# No people detected - show empty state #}
            <div class="lens-detection-item lens-detection-empty">
                <div class="flex items-center gap-s">
                    <span class="status off"></span>
                    <span class="lens-people-display-text">{{ _self.peopleDetectionText(false, 0) }}</span>
                </div>
            </div>
        {% endif %}
    </div>

    {# Edit mode (hidden by default) - only if NOT locked #}
    {% if not readOnly %}
        <div class="lens-field-edit lens-people-edit-panel" hidden>
            <div class="lens-people-edit-options">
                {# Option 1: No people #}
                <label class="lens-people-option">
                    <input type="radio" name="people-mode-{{ analysis.id }}" value="none" data-control="people-mode">
                    <span>{{ 'No people present'|t('lens') }}</span>
                </label>

                {# Option 2: People without faces #}
                <label class="lens-people-option">
                    <input type="radio" name="people-mode-{{ analysis.id }}" value="no-faces" data-control="people-mode">
                    <span>{{ 'People present, no visible faces'|t('lens') }}</span>
                </label>

                {# Option 3: Individual (1 person) #}
                <label class="lens-people-option">
                    <input type="radio" name="people-mode-{{ analysis.id }}" value="1" data-control="people-mode">
                    <span>{{ 'Individual (1 person)'|t('lens') }}</span>
                </label>

                {# Option 4: Duo (2 people) #}
                <label class="lens-people-option">
                    <input type="radio" name="people-mode-{{ analysis.id }}" value="2" data-control="people-mode">
                    <span>{{ 'Duo (2 people)'|t('lens') }}</span>
                </label>

                {# Option 5: Small group (3-5 people) #}
                <label class="lens-people-option">
                    <input type="radio" name="people-mode-{{ analysis.id }}" value="3-5" data-control="people-mode">
                    <span>{{ 'Small group (3-5 people)'|t('lens') }}</span>
                </label>

                {# Option 6: Large group (6+ people) #}
                <label class="lens-people-option">
                    <input type="radio" name="people-mode-{{ analysis.id }}" value="6+" data-control="people-mode">
                    <span>{{ 'Large group (6+ people)'|t('lens') }}</span>
                </label>
            </div>

            {# Save/Cancel buttons #}
            <div class="lens-field-actions">
                <button type="button" class="btn small submit" data-action="people-save">{{ 'Save'|t('lens') }}</button>
                <button type="button" class="btn small" data-action="people-cancel">{{ 'Cancel'|t('lens') }}</button>
            </div>
        </div>
    {% endif %}

    {# Pending review notice - only when locked due to pending_review #}
    {% if analysis.status == 'pending_review' and not static %}
        <div class="lens-pending-notice">
            <span class="lens-info-icon">&#9432;</span>
            {{ 'This analysis is in review. Editing will be available after review completion.'|t('lens') }}
        </div>
    {% endif %}

    {# Provenance meta (show most recent edit) #}
    {% if isEdited %}
        <div class="lens-edit-meta">
            {% if isFaceCountEdited %}
                {% set editor = craft.users.id(analysis.faceCountEditedBy).one() %}
                {% set formattedDate = analysis.faceCountEditedAt|date('M j, Y') %}
                {{ 'Edited by {user} on {date}'|t('lens', {
                    user: editor ? editor.friendlyName : 'Unknown',
                    date: formattedDate
                }) }}
            {% elseif isPeopleEdited %}
                {% set editor = craft.users.id(analysis.containsPeopleEditedBy).one() %}
                {% set formattedDate = analysis.containsPeopleEditedAt|date('M j, Y') %}
                {{ 'Edited by {user} on {date}'|t('lens', {
                    user: editor ? editor.friendlyName : 'Unknown',
                    date: formattedDate
                }) }}
            {% endif %}
        </div>

        {# Show revert option if AI values differ and not locked #}
        {% set aiDiffers = (analysis.containsPeopleAi != analysis.containsPeople) or (analysis.faceCountAi != analysis.faceCount) %}
        {% if aiDiffers and not readOnly %}
            <div class="lens-ai-suggestion">
                {{ 'AI suggested: "{text}"'|t('lens', {
                    text: _self.peopleDetectionText(analysis.containsPeopleAi, analysis.faceCountAi)
                }) }}
                <button type="button" data-action="people-revert" data-analysis-id="{{ analysis.id }}">
                    {{ 'Revert to AI'|t('lens') }}
                </button>
            </div>
        {% endif %}
    {% endif %}
</div>
