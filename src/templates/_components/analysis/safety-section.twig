{#
 # Content Safety Section
 # NSFW, watermark, brands, people detection — all using the 3-state pattern.
 #
 # Expected variables: analysis, fieldState
 #}
{% set fieldState = fieldState ?? 'readonly' %}

{# People Detection — Editable inline component #}
{% include 'lens/_components/analysis/people-detection-field' with {
    analysis: analysis,
    fieldState: fieldState,
    hideConfidence: hideConfidence ?? false
} only %}

{# NSFW Detection Toggle #}
{% set nsfwCats = analysis.nsfwCategories|default([])|map(c => c.category|capitalize) %}
{% set nsfwFlaggedLabel = nsfwCats|length
    ? (nsfwCats|slice(0, 2)|join(', ') ~ (nsfwCats|length > 2 ? ' +' ~ (nsfwCats|length - 2) : ''))
    : null %}
{% include 'lens/_components/analysis/detection-toggle-field' with {
    icon: 'shield-halved',
    fieldName: 'nsfwScore',
    label: 'NSFW Detection'|t('lens'),
    detected: analysis.nsfwScore is defined and analysis.nsfwScore >= 0.5,
    detectedAi: analysis.nsfwScoreAi is defined and analysis.nsfwScoreAi >= 0.5,
    analysisId: analysis.id,
    fieldState: fieldState,
    detectedLabel: 'NSFW content detected'|t('lens'),
    clearedLabel: 'No NSFW content'|t('lens'),
    trueValue: 1,
    falseValue: 0,
    confidence: analysis.nsfwConfidence ?? null,
    hideConfidence: hideConfidence ?? false,
    flaggedLabel: nsfwFlaggedLabel,
    flaggedHelp: 'Content may be unsuitable for general audiences. Review before publishing.'|t('lens')
} only %}

{# Watermark Detection Toggle #}
{% set wmDetails = analysis.watermarkDetails is iterable ? analysis.watermarkDetails : {} %}
{% set wmTypeLabel = null %}

{% if analysis.watermarkType and analysis.watermarkType != 'unknown' %}
    {% set wmTypeLabels = { 'stock': 'Stock Photo'|t('lens'), 'logo': 'Logo'|t('lens'), 'text': 'Text'|t('lens'), 'copyright': 'Copyright'|t('lens') } %}
    {% set wmTypeLabel = wmTypeLabels[analysis.watermarkType] ?? null %}
{% endif %}

{% set wmChips = [] %}

{% if analysis.watermarkType == 'stock' and wmDetails.stockProvider is defined and wmDetails.stockProvider %}
    {% set wmChips = wmChips|merge([wmDetails.stockProvider]) %}
{% endif %}

{% set wmHelp = {
    'stock': 'Stock photo watermark detected. Licensing likely required before publishing.'|t('lens'),
    'logo': 'Logo watermark detected. Verify usage rights before publishing.'|t('lens'),
    'text': 'Text watermark detected. Verify the source and rights before publishing.'|t('lens'),
    'copyright': 'Copyright watermark detected. Verify permission before commercial use.'|t('lens')
}[analysis.watermarkType] ?? 'Watermark detected. Verify usage rights before publishing.'|t('lens') %}

{% include 'lens/_components/analysis/detection-toggle-field' with {
    icon: 'droplet',
    fieldName: 'hasWatermark',
    label: 'Watermark Detection'|t('lens'),
    detected: analysis.hasWatermark,
    detectedAi: analysis.hasWatermarkAi ?? false,
    analysisId: analysis.id,
    fieldState: fieldState,
    detectedLabel: 'Watermark detected'|t('lens'),
    clearedLabel: 'No watermark detected'|t('lens'),
    trueValue: 1,
    falseValue: 0,
    confidence: analysis.watermarkConfidence ?? null,
    hideConfidence: hideConfidence ?? false,
    details: wmChips,
    flaggedLabel: wmTypeLabel,
    flaggedHelp: wmHelp
} only %}

{# Brand Detection Toggle #}
{% set brandNames = (analysis.containsBrandLogo and analysis.detectedBrands|length) ? analysis.detectedBrands|map(b => b.brand) : [] %}
{% set brandFlaggedLabel = brandNames|length
    ? (brandNames|slice(0, 2)|join(', ') ~ (brandNames|length > 2 ? ' +' ~ (brandNames|length - 2) : ''))
    : null %}
{% include 'lens/_components/analysis/detection-toggle-field' with {
    icon: 'tag',
    fieldName: 'containsBrandLogo',
    label: 'Brand Detection'|t('lens'),
    detected: analysis.containsBrandLogo and analysis.detectedBrands|length,
    detectedAi: analysis.containsBrandLogoAi ?? false,
    analysisId: analysis.id,
    fieldState: fieldState,
    detectedLabel: 'Brands detected'|t('lens'),
    clearedLabel: 'No brands detected'|t('lens'),
    trueValue: 1,
    falseValue: 0,
    confidence: analysis.containsBrandLogoConfidence ?? null,
    hideConfidence: hideConfidence ?? false,
    flaggedLabel: brandFlaggedLabel,
    flaggedHelp: 'Identifiable brand logos detected. Verify trademark and usage rights for commercial use.'|t('lens')
} only %}
