{#
 # Content Safety Section
 # NSFW, watermark, brands, people detection — all using the 3-state pattern.
 #
 # Expected variables: analysis, fieldState
 #}
{% set fieldState = fieldState ?? 'readonly' %}

{# People Detection — Editable inline component #}
{% include 'lens/_components/analysis/people-detection-field' with {
    analysis: analysis,
    fieldState: fieldState
} only %}

{# NSFW Detection Toggle #}
{% include 'lens/_components/analysis/detection-toggle-field' with {
    fieldName: 'nsfwScore',
    label: 'NSFW Detection'|t('lens'),
    detected: analysis.isFlaggedNsfw or (analysis.nsfwScore is defined and analysis.nsfwScore >= 0.2),
    detectedAi: analysis.nsfwScoreAi is defined and analysis.nsfwScoreAi >= 0.2,
    editedBy: analysis.nsfwScoreEditedBy ?? null,
    editedAt: analysis.nsfwScoreEditedAt ?? null,
    analysisId: analysis.id,
    fieldState: fieldState,
    detectedLabel: 'NSFW content detected'|t('lens'),
    clearedLabel: 'No NSFW content'|t('lens'),
    trueValue: 1,
    falseValue: 0
} only %}

{# NSFW contextual info — always displayed when data exists (read-only) #}
{% if analysis.isFlaggedNsfw or (analysis.nsfwScore is defined and analysis.nsfwScore >= 0.2) %}
    <div class="lens-detection-item lens-detection-item--nested">
        <div>
            <span class="lens-badge lens-badge--{{ analysis.isFlaggedNsfw ? 'error-solid' : 'amber' }}">{{ (analysis.nsfwScore * 100)|round }}%</span>
            {% if analysis.nsfwCategories|length %}
                <div class="chips">
                    {% for cat in analysis.nsfwCategories %}
                        <div class="chip small lens-nsfw-chip{% if not analysis.isFlaggedNsfw %} lens-nsfw-chip--caution{% endif %}">
                            <div class="chip-content">
                                <span class="chip-label">{{ cat.category }}</span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
{% endif %}

{# Watermark Detection Toggle #}
{% include 'lens/_components/analysis/detection-toggle-field' with {
    fieldName: 'hasWatermark',
    label: 'Watermark Detection'|t('lens'),
    detected: analysis.hasWatermark,
    detectedAi: analysis.hasWatermarkAi ?? false,
    editedBy: analysis.hasWatermarkEditedBy ?? null,
    editedAt: analysis.hasWatermarkEditedAt ?? null,
    analysisId: analysis.id,
    fieldState: fieldState,
    detectedLabel: 'Watermark detected'|t('lens'),
    clearedLabel: 'No watermark detected'|t('lens'),
    trueValue: 1,
    falseValue: 0
} only %}

{# Watermark contextual info — always displayed when data exists (read-only) #}
{% if analysis.hasWatermark %}
    <div class="lens-detection-item lens-detection-item--nested">
        <div class="lens-watermark-info">
            {% set watermarkTypes = {
                'stock': 'Stock Photo'|t('lens'),
                'logo': 'Logo'|t('lens'),
                'text': 'Text'|t('lens'),
                'copyright': 'Copyright'|t('lens'),
                'unknown': 'Unknown'|t('lens')
            } %}
            <span class="lens-watermark-type">{{ watermarkTypes[analysis.watermarkType] ?? analysis.watermarkType|capitalize }}</span>
            {% if analysis.watermarkConfidence %}
                <span class="badge">{{ (analysis.watermarkConfidence * 100)|round }}%</span>
            {% endif %}
            {% if analysis.watermarkType == 'stock' and analysis.watermarkDetails.stockProvider is defined %}
                <span class="lens-badge lens-badge--amber">{{ analysis.watermarkDetails.stockProvider }}</span>
            {% endif %}
        </div>
    </div>
{% endif %}

{# Brand Detection Toggle #}
{% include 'lens/_components/analysis/detection-toggle-field' with {
    fieldName: 'containsBrandLogo',
    label: 'Brand Detection'|t('lens'),
    detected: analysis.containsBrandLogo and analysis.detectedBrands|length,
    detectedAi: analysis.containsBrandLogoAi ?? false,
    editedBy: analysis.containsBrandLogoEditedBy ?? null,
    editedAt: analysis.containsBrandLogoEditedAt ?? null,
    analysisId: analysis.id,
    fieldState: fieldState,
    detectedLabel: 'Brands detected'|t('lens'),
    clearedLabel: 'No brands detected'|t('lens'),
    trueValue: 1,
    falseValue: 0
} only %}

{# Brand contextual info — always displayed when data exists (read-only) #}
{% if analysis.containsBrandLogo and analysis.detectedBrands|length %}
    <div class="lens-detection-item lens-detection-item--nested">
        <div class="chips">
            {% for brand in analysis.detectedBrands %}
                <div class="chip" title="{{ (brand.confidence * 100)|round }}% confidence">
                    <div class="chip-content">
                        <span class="chip-label">{{ brand.brand }}</span>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
