{#
 # Asset Sidebar - Plugin setup guidance
 # Shows only when UI component (LensAnalysisElement) is NOT added to field layout
 # Rendered inside metadata section via EVENT_DEFINE_METADATA
 #}

<div class="lens-asset-sidebar">
    {% include 'lens/_components/inline-notice' with {
        type: 'info',
        title: 'Lens Analysis Available'|t('lens'),
        message: 'Add the Lens Analysis panel to this volume to see AI-generated descriptions, tags, and more right here.'|t('lens'),
        cta: {
            label: 'Add to Volume'|t('lens'),
            url: 'settings/assets/volumes/' ~ asset.volume.id
        },
        docsUrl: 'https://github.com/vitordiniz22/craft-lens/wiki/Getting-Started#adding-the-analysis-panel'
    } %}
</div>
