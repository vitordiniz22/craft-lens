{% extends '_layouts/cp' %}

{% set title = 'Asset Browser'|t('lens') %}
{% set selectedSubnavItem = 'search' %}

{% block content %}
<div class="lens-search-page">
    {# Search Header #}
    <form method="get" action="{{ cpUrl('lens/search') }}" class="lens-search-form" data-lens-target="search-form">
        {% if filters.similarTo is defined and filters.similarTo %}
            <input type="hidden" name="similarTo" value="{{ filters.similarTo }}">
        {% endif %}

        {# Search Toolbar #}
        <div class="lens-search-toolbar">
            <div class="flex-grow">
                <div class="lens-search-input-wrap">
                    <span class="lens-search-icon">
                        {{ iconSvg('magnifying-glass')|attr({width: 16, height: 16}) }}
                    </span>
                    <input type="text"
                           name="q"
                           data-lens-control="search-query"
                           class="text fullwidth"
                           placeholder="{{ 'Search by alt text, title, extracted text, or tags...'|t('lens') }}"
                           value="{{ filters.query ?? '' }}"
                           autocomplete="off">
                    {% if filters.query ?? false %}
                        <button type="button" class="lens-clear-search" data-lens-action="clear-search"
                                title="{{ 'Clear search'|t('lens') }}">
                            {{ iconSvg('xmark')|attr({width: 12, height: 12}) }}
                        </button>
                    {% endif %}
                </div>
            </div>
            <button type="submit" class="btn submit">{{ 'Search'|t('lens') }}</button>
            <button type="button" class="btn" data-lens-action="toggle-filters">
                {{ iconSvg('filter')|attr({width: 14, height: 14, class: 'lens-btn-icon'}) }}
                {{ 'Filters'|t('lens') }}
                {% if hasActiveFilters %}
                    <span class="lens-badge lens-badge--small lens-badge--info">{{ 'active'|t('lens') }}</span>
                {% endif %}
            </button>
        </div>

        {# Quick Filters #}
        {% if quickFilters|length %}
            <div class="btngroup">
                {% for filter in quickFilters %}
                    <a href="{{ cpUrl('lens/search', filter.active ? {} : filter.params) }}"
                       class="btn small{% if filter.active %} active{% endif %}"
                       aria-pressed="{{ filter.active ? 'true' : 'false' }}">
                        {{ filter.label }}
                    </a>
                {% endfor %}
            </div>
        {% endif %}

        {# Active Filters Chips Bar #}
        {% if hasActiveFilters %}
            <div class="lens-filter-chips-bar" data-lens-target="filter-chips-bar">
                <span class="lens-filter-chips-label light">{{ 'Filtered by'|t('lens') }}:</span>
                <div class="lens-filter-chips">
                    {% if filters.query is defined and filters.query %}
                        <span class="lens-filter-chip" data-lens-filter-param="q">
                            {{ lens.filterLabel('query') }}: <strong>{{ filters.query }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="q" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.containsPeople is defined and filters.containsPeople is not null %}
                        <span class="lens-filter-chip" data-lens-filter-param="containsPeople">
                            {{ lens.filterLabel('containsPeople') }}: <strong>{{ filters.containsPeople ? 'Yes'|t('lens') : 'No'|t('lens') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="containsPeople" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if (filters.faceCountPreset ?? '') != '' %}
                        <span class="lens-filter-chip" data-lens-filter-param="faceCountPreset">
                            {{ lens.filterLabel('faceCountPreset') }}: <strong>{{ filters.faceCountPreset }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="faceCountPreset" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if (filters.qualityIssues ?? [])|length %}
                        {% set qualityIssueLabels = {
                            blurry: 'Blurry'|t('lens'),
                            tooDark: 'Too Dark'|t('lens'),
                            tooBright: 'Too Bright'|t('lens'),
                            lowContrast: 'Low Contrast'|t('lens'),
                        } %}
                        <span class="lens-filter-chip" data-lens-filter-param="qualityIssues[]">
                            {{ lens.filterLabel('qualityIssues') }}: <strong>{{ filters.qualityIssues|map(v => qualityIssueLabels[v] ?? v)|join(', ') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="qualityIssues[]" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.isTooLarge is defined and filters.isTooLarge %}
                        <span class="lens-filter-chip" data-lens-filter-param="isTooLarge">
                            <strong>{{ lens.filterLabel('isTooLarge') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="isTooLarge" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.isBlurry is defined and filters.isBlurry %}
                        <span class="lens-filter-chip" data-lens-filter-param="isBlurry">
                            <strong>{{ lens.filterLabel('isBlurry') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="isBlurry" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.isTooDark is defined and filters.isTooDark %}
                        <span class="lens-filter-chip" data-lens-filter-param="isTooDark">
                            <strong>{{ lens.filterLabel('isTooDark') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="isTooDark" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.hasTextInImage is defined and filters.hasTextInImage is not null %}
                        <span class="lens-filter-chip" data-lens-filter-param="hasTextInImage">
                            {{ lens.filterLabel('hasTextInImage') }}: <strong>{{ filters.hasTextInImage ? 'Yes'|t('lens') : 'No'|t('lens') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="hasTextInImage" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.hasWatermark is defined and filters.hasWatermark is not null %}
                        <span class="lens-filter-chip" data-lens-filter-param="hasWatermark">
                            {{ lens.filterLabel('hasWatermark') }}: <strong>{{ filters.hasWatermark ? 'Yes'|t('lens') : 'No'|t('lens') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="hasWatermark" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.containsBrandLogo is defined and filters.containsBrandLogo is not null %}
                        <span class="lens-filter-chip" data-lens-filter-param="containsBrandLogo">
                            {{ lens.filterLabel('containsBrandLogo') }}: <strong>{{ filters.containsBrandLogo ? 'Yes'|t('lens') : 'No'|t('lens') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="containsBrandLogo" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.color is defined and filters.color %}
                        {% set toleranceLabels = {10: 'exact'|t('lens'), 30: 'close'|t('lens'), 55: 'broad'|t('lens'), 80: 'any'|t('lens')} %}
                        {% set chipTolerance = filters.colorTolerance ?? 30 %}
                        <span class="lens-filter-chip" data-lens-filter-param="color,colorTolerance">
                            <span class="lens-filter-chip-swatch" style="background:{{ filters.color }}"></span>
                            {{ lens.filterLabel('color') }}: <strong>{{ filters.color }}{% if chipTolerance != 30 %} ({{ toleranceLabels[chipTolerance] ?? chipTolerance ~ '%' }}){% endif %}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="color,colorTolerance" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.status is defined and filters.status|length %}
                        <span class="lens-filter-chip" data-lens-filter-param="status">
                            {{ lens.filterLabel('status') }}: <strong>{{ filters.status|map(s => lens.statusLabel(s))|join(', ') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="status" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.confidenceMax is defined %}
                        <span class="lens-filter-chip" data-lens-filter-param="confidenceMax">
                            {{ lens.filterLabel('confidenceMax') }}: <strong>&le; {{ (filters.confidenceMax * 100)|round }}%</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="confidenceMax" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.nsfwScoreMin is defined %}
                        <span class="lens-filter-chip" data-lens-filter-param="nsfwScoreMin">
                            {{ lens.filterLabel('nsfwScoreMin') }}: <strong>&ge; {{ (filters.nsfwScoreMin * 100)|round }}%</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="nsfwScoreMin" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.processedFrom is defined or filters.processedTo is defined %}
                        <span class="lens-filter-chip" data-lens-filter-param="processedFrom,processedTo">
                            {{ lens.filterLabel('processedDate') }}: <strong>{% if filters.processedFrom is defined %}{{ filters.processedFrom|date('Y-m-d') }}{% endif %} {{ 'to'|t('lens') }} {% if filters.processedTo is defined %}{{ filters.processedTo|date('Y-m-d') }}{% endif %}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="processedFrom,processedTo" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.hasDuplicates is defined and filters.hasDuplicates is not null %}
                        <span class="lens-filter-chip" data-lens-filter-param="hasDuplicates">
                            {{ lens.filterLabel('hasDuplicates') }}: <strong>{{ filters.hasDuplicates ? 'Yes'|t('lens') : 'No'|t('lens') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="hasDuplicates" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.similarTo is defined and filters.similarTo and (similarToAsset ?? null) %}
                        <span class="lens-filter-chip" data-lens-filter-param="similarTo">
                            {{ lens.filterLabel('similarTo') }}: <strong>{{ similarToAsset.title }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="similarTo" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.hasFocalPoint is defined and filters.hasFocalPoint is not null %}
                        <span class="lens-filter-chip" data-lens-filter-param="hasFocalPoint">
                            {{ lens.filterLabel('hasFocalPoint') }}: <strong>{{ filters.hasFocalPoint ? 'Present'|t('lens') : 'Missing'|t('lens') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="hasFocalPoint" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.missingAltText is defined and filters.missingAltText is not null %}
                        <span class="lens-filter-chip" data-lens-filter-param="missingAltText">
                            {{ lens.filterLabel('missingAltText') }}: <strong>{{ filters.missingAltText ? 'Missing'|t('lens') : 'Present'|t('lens') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="missingAltText" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                    {% if filters.unprocessed is defined and filters.unprocessed %}
                        <span class="lens-filter-chip" data-lens-filter-param="unprocessed">
                            <strong>{{ lens.filterLabel('unprocessed') }}</strong>
                            <button type="button" data-lens-action="remove-filter-chip" data-lens-filter-param="unprocessed" title="{{ 'Remove filter'|t('lens') }}">&times;</button>
                        </span>
                    {% endif %}
                </div>
                <a href="{{ cpUrl('lens/search') }}" class="lens-filter-chips-clear" data-lens-action="clear-all-filters">{{ 'Clear all'|t('lens') }}</a>
            </div>
        {% endif %}

        {# Filter Panel #}
        {% include 'lens/_search/_filters' %}
    </form>

    {# Results Section #}
    <div class="lens-search-results">
        {% include 'lens/_search/_results' %}
    </div>
</div>
{% endblock %}
