{% extends '_layouts/cp' %}

{% set title = 'Asset Browser'|t('lens') %}
{% set selectedSubnavItem = 'search' %}

{# ─── chip rendering macro ──────────────────────────────────────────────── #}
{# An editable chip: body opens the filter-picker for `filterId`,           #}
{# × removes the listed params. A read-only chip uses `filterId = null`.    #}
{% macro chip(filterId, removeParams, label, value, swatch) %}
    <span class="lens-filter-chip" data-lens-filter-param="{{ removeParams }}">
        {% if swatch ?? false %}
            <span class="lens-filter-chip-swatch" style="background:{{ swatch }}"></span>
        {% endif %}
        {% if filterId %}
            <button type="button"
                    class="lens-filter-chip__body"
                    data-lens-action="edit-filter"
                    data-lens-filter-id="{{ filterId }}">
                {% if label %}<span class="lens-filter-chip__label">{{ label }}</span>{% endif %}
                {% if value is defined and value is not null %}<strong>{{ value|raw }}</strong>{% endif %}
            </button>
        {% else %}
            <span class="lens-filter-chip__body">
                {% if label %}<span class="lens-filter-chip__label">{{ label }}</span>{% endif %}
                {% if value is defined and value is not null %}<strong>{{ value|raw }}</strong>{% endif %}
            </span>
        {% endif %}
        <button type="button"
                class="lens-filter-chip__remove"
                data-lens-action="remove-filter-chip"
                data-lens-filter-param="{{ removeParams }}"
                title="{{ 'Remove filter'|t('lens') }}">&times;</button>
    </span>
{% endmacro %}

{% block content %}
<div class="lens-search-page">
    {# Search Header #}
    <form method="get"
          action="{{ cpUrl('lens/search') }}"
          class="lens-search-form"
          data-lens-target="search-form"
          data-lens-filter-registry="{{ filterRegistry|json_encode|e('html_attr') }}"
          data-lens-filter-sections="{{ filterSectionLabels|json_encode|e('html_attr') }}"
          data-lens-active-filters="{{ activeFilterSnapshot|json_encode|e('html_attr') }}">
        {% if filters.similarTo is defined and filters.similarTo %}
            <input type="hidden" name="similarTo" value="{{ filters.similarTo }}">
        {% endif %}

        {# Search Toolbar #}
        <div class="lens-search-toolbar">
            <div class="flex-grow">
                <div class="lens-search-input-wrap">
                    <span class="lens-search-icon">
                        {{ iconSvg('magnifying-glass')|attr({width: 16, height: 16}) }}
                    </span>
                    <input type="text"
                           name="q"
                           data-lens-control="search-query"
                           class="text fullwidth"
                           placeholder="{{ 'Search by alt text, title, extracted text, or tags...'|t('lens') }}"
                           value="{{ filters.query ?? '' }}"
                           autocomplete="off">
                    {% if filters.query ?? false %}
                        <button type="button" class="lens-clear-search" data-lens-action="clear-search"
                                title="{{ 'Clear search'|t('lens') }}">
                            {{ iconSvg('xmark')|attr({width: 12, height: 12}) }}
                        </button>
                    {% endif %}
                </div>
            </div>
            <button type="submit" class="btn submit">{{ 'Search'|t('lens') }}</button>
        </div>

        {# Add filter + Quick Filters #}
        <div class="lens-quickfilter-row">
            <button type="button"
                    class="btn small lens-filter-add"
                    data-lens-action="open-filter-picker"
                    aria-haspopup="dialog"
                    aria-expanded="false">
                <span class="lens-filter-add__icon" aria-hidden="true">+</span>
                {{ 'Add filter'|t('lens') }}
            </button>
            {% if quickFilters|length %}
                <div class="btngroup">
                    {% for filter in quickFilters %}
                        <a href="{{ cpUrl('lens/search', filter.hrefParams) }}"
                           class="btn small{% if filter.active %} active{% endif %}"
                           aria-pressed="{{ filter.active ? 'true' : 'false' }}">
                            {{ filter.label }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {# Chip toolbar — only when at least one filter is active #}
        {% if hasActiveFilters %}
        <div class="lens-filter-toolbar" data-lens-target="filter-toolbar">
            {% import _self as chipMacro %}
            <div class="lens-filter-chips">
                {% if filters.query is defined and filters.query %}
                    {{ chipMacro.chip(null, 'q', lens.filterLabel('query') ~ ':', filters.query) }}
                {% endif %}
                {% if (filters.tags ?? [])|length %}
                    {% set joinedTags = filters.tags|join((filters.tagOperator ?? 'or') == 'and' ? ' + ' : ', ') %}
                    {{ chipMacro.chip('tags', 'tags,tagOperator', lens.filterLabel('tags') ~ ':', joinedTags) }}
                {% endif %}
                {% if filters.containsPeople is defined and filters.containsPeople is not null %}
                    {{ chipMacro.chip('containsPeople', 'containsPeople', lens.filterLabel('containsPeople') ~ ':', filters.containsPeople ? 'Yes'|t('lens') : 'No'|t('lens')) }}
                {% endif %}
                {% if (filters.faceCountPreset ?? '') != '' %}
                    {{ chipMacro.chip('faceCountPreset', 'faceCountPreset', lens.filterLabel('faceCountPreset') ~ ':', filters.faceCountPreset) }}
                {% endif %}
                {% if (filters.qualityIssue ?? '') != '' %}
                    {% set qualityIssueLabels = {
                        blurry: 'Blurry'|t('lens'),
                        tooDark: 'Too dark'|t('lens'),
                        tooBright: 'Too bright'|t('lens'),
                        lowContrast: 'Low contrast'|t('lens'),
                    } %}
                    {{ chipMacro.chip('qualityIssue', 'qualityIssue', lens.filterLabel('qualityIssue') ~ ':', qualityIssueLabels[filters.qualityIssue] ?? filters.qualityIssue) }}
                {% endif %}
                {% if (filters.fileSizePreset ?? '') != '' %}
                    {{ chipMacro.chip('fileSizePreset', 'fileSizePreset', lens.filterLabel('fileSizePreset') ~ ':', '&gt; ' ~ filters.fileSizePreset ~ ' MB') }}
                {% endif %}
                {% if filters.hasTextInImage is defined and filters.hasTextInImage is not null %}
                    {{ chipMacro.chip('hasTextInImage', 'hasTextInImage', lens.filterLabel('hasTextInImage') ~ ':', filters.hasTextInImage ? 'Yes'|t('lens') : 'No'|t('lens')) }}
                {% endif %}
                {% if filters.hasWatermark is defined and filters.hasWatermark is not null %}
                    {{ chipMacro.chip('hasWatermark', 'hasWatermark', lens.filterLabel('hasWatermark') ~ ':', filters.hasWatermark ? 'Yes'|t('lens') : 'No'|t('lens')) }}
                {% endif %}
                {% set watermarkTypeChip = filters.watermarkType ?? null %}
                {% if watermarkTypeChip %}
                    {% set watermarkTypes = watermarkTypeChip is iterable ? watermarkTypeChip : [watermarkTypeChip] %}
                    {% if watermarkTypes|length %}
                        {{ chipMacro.chip('watermarkType', 'watermarkType', lens.filterLabel('watermarkType') ~ ':', watermarkTypes|join(', ')) }}
                    {% endif %}
                {% endif %}
                {% if filters.containsBrandLogo is defined and filters.containsBrandLogo is not null %}
                    {{ chipMacro.chip('containsBrandLogo', 'containsBrandLogo', lens.filterLabel('containsBrandLogo') ~ ':', filters.containsBrandLogo ? 'Yes'|t('lens') : 'No'|t('lens')) }}
                {% endif %}
                {% if filters.color is defined and filters.color %}
                    {% set toleranceLabels = {10: 'exact'|t('lens'), 30: 'close'|t('lens'), 55: 'broad'|t('lens'), 80: 'any'|t('lens')} %}
                    {% set chipTolerance = filters.colorTolerance ?? 30 %}
                    {% set colorValue = filters.color ~ (chipTolerance != 30 ? ' (' ~ (toleranceLabels[chipTolerance] ?? chipTolerance ~ '%') ~ ')' : '') %}
                    {{ chipMacro.chip('color', 'color,colorTolerance', lens.filterLabel('color') ~ ':', colorValue, filters.color) }}
                {% endif %}
                {% if filters.status is defined and filters.status|length %}
                    {% set statusLabels = filters.status|map(s => lens.statusLabel(s))|join(', ') %}
                    {{ chipMacro.chip('status', 'status', lens.filterLabel('status') ~ ':', statusLabels) }}
                {% endif %}
                {% if (filters.provider is defined and filters.provider) or (filters.providerModel is defined and filters.providerModel) %}
                    {% set providerOptions = (filterRegistry.provider.options ?? []) %}
                    {% set providerMatch = providerOptions|filter(o => o.value == (filters.provider ?? ''))|first %}
                    {% set providerDisplay = providerMatch.label ?? filters.provider ?? '' %}
                    {% set providerValue = providerDisplay ~ ((filters.providerModel ?? '') ? ' / ' ~ filters.providerModel : '') %}
                    {{ chipMacro.chip('provider', 'provider,providerModel', lens.filterLabel('provider') ~ ':', providerValue|trim(' /')) }}
                {% endif %}
                {% if filters.nsfwScoreMin is defined or filters.nsfwScoreMax is defined %}
                    {% set nsfwValue %}
                        {%- if filters.nsfwScoreMin is defined %}&ge; {{ (filters.nsfwScoreMin * 100)|round }}%{% endif -%}
                        {%- if filters.nsfwScoreMin is defined and filters.nsfwScoreMax is defined %} &nbsp;{% endif -%}
                        {%- if filters.nsfwScoreMax is defined %}&le; {{ (filters.nsfwScoreMax * 100)|round }}%{% endif -%}
                    {% endset %}
                    {{ chipMacro.chip('nsfwScore', 'nsfwScoreMin,nsfwScoreMax,nsfwFlagged', 'NSFW'|t('lens') ~ ':', nsfwValue) }}
                {% endif %}
                {% if filters.processedFrom is defined or filters.processedTo is defined %}
                    {% set dateValue %}
                        {%- if filters.processedFrom is defined %}{{ filters.processedFrom|date('Y-m-d') }}{% endif -%}
                        {{ ' ' ~ 'to'|t('lens') ~ ' ' }}
                        {%- if filters.processedTo is defined %}{{ filters.processedTo|date('Y-m-d') }}{% endif -%}
                    {% endset %}
                    {{ chipMacro.chip('processedDate', 'processedFrom,processedTo', lens.filterLabel('processedDate') ~ ':', dateValue) }}
                {% endif %}
                {% if filters.hasDuplicates is defined and filters.hasDuplicates is not null %}
                    {{ chipMacro.chip('hasDuplicates', 'hasDuplicates', lens.filterLabel('hasDuplicates') ~ ':', filters.hasDuplicates ? 'Yes'|t('lens') : 'No'|t('lens')) }}
                {% endif %}
                {% if filters.similarTo is defined and filters.similarTo and (similarToAsset ?? null) %}
                    {{ chipMacro.chip(null, 'similarTo', lens.filterLabel('similarTo') ~ ':', similarToAsset.title) }}
                {% endif %}
                {% if filters.hasFocalPoint is defined and filters.hasFocalPoint is not null %}
                    {{ chipMacro.chip('hasFocalPoint', 'hasFocalPoint', lens.filterLabel('hasFocalPoint') ~ ':', filters.hasFocalPoint ? 'Present'|t('lens') : 'Missing'|t('lens')) }}
                {% endif %}
                {% if filters.missingAltText is defined and filters.missingAltText is not null %}
                    {{ chipMacro.chip(null, 'missingAltText', lens.filterLabel('missingAltText') ~ ':', filters.missingAltText ? 'Missing'|t('lens') : 'Present'|t('lens')) }}
                {% endif %}
                {% if filters.unprocessed is defined and filters.unprocessed %}
                    {{ chipMacro.chip(null, 'unprocessed', lens.filterLabel('unprocessed')) }}
                {% endif %}
            </div>
            {% if (activeFilterCount ?? 0) >= 2 %}
                <a href="{{ cpUrl('lens/search') }}"
                   class="lens-filter-clear-chip"
                   data-lens-action="clear-all-filters">
                    {{ 'Clear all'|t('lens') }}
                </a>
            {% endif %}
        </div>
        {% endif %}
    </form>

    {# Results Section #}
    <div class="lens-search-results">
        {% include 'lens/_search/_results' %}
    </div>
</div>

{% endblock %}
