{% extends '_layouts/cp' %}
{% import '_includes/forms.twig' as forms %}

{% set title = 'Asset Browser'|t('lens') %}
{% set selectedSubnavItem = 'search' %}

{% block content %}
<div class="lens-search-page">
    {# Search Header #}
    <form method="get" action="{{ cpUrl('lens/search') }}" id="lens-search-form">
        <div class="flex" style="gap: var(--m); margin-bottom: var(--m);">
            <div class="flex-grow">
                <div class="lens-search-input-wrap">
                    <span class="lens-search-icon">
                        <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>
                        </svg>
                    </span>
                    <input type="text"
                           name="q"
                           id="lens-search-query"
                           class="text fullwidth"
                           placeholder="{{ 'Search by alt text, title, extracted text, or tags...'|t('lens') }}"
                           value="{{ filters.query ?? '' }}"
                           autocomplete="off">
                    {% if filters.query ?? false %}
                        <button type="button" class="lens-clear-search" onclick="document.getElementById('lens-search-query').value=''; this.form.submit();">
                            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
                                <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
                            </svg>
                        </button>
                    {% endif %}
                </div>
            </div>
            <button type="submit" class="btn submit">{{ 'Search'|t('lens') }}</button>
        </div>

        {# Filters Toggle #}
        <div style="margin-bottom: var(--m);">
            <button type="button" class="btn" id="lens-toggle-filters">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" style="margin-right: 4px;">
                    <path fill-rule="evenodd" d="M2.628 1.601C5.028 1.206 7.49 1 10 1s4.973.206 7.372.601a.75.75 0 01.628.74v2.288a2.25 2.25 0 01-.659 1.59l-4.682 4.683a2.25 2.25 0 00-.659 1.59v3.037c0 .684-.31 1.33-.844 1.757l-1.937 1.55A.75.75 0 018 18.25v-5.757a2.25 2.25 0 00-.659-1.591L2.659 6.22A2.25 2.25 0 012 4.629V2.34a.75.75 0 01.628-.74z" clip-rule="evenodd"/>
                </svg>
                {{ 'Filters'|t('lens') }}
                {% if hasFilters %}
                    <span class="lens-badge lens-badge--info">{{ 'active'|t('lens') }}</span>
                {% endif %}
            </button>
        </div>

        {# Quick Filters #}
        {% if quickFilters|length %}
            <div class="btngroup" style="margin-bottom: var(--m);">
                {% for key, filter in quickFilters %}
                    <a href="{{ cpUrl('lens/search', {quickFilter: key}) }}"
                       class="btn small{% if (filters.quickFilter ?? '') == key %} active{% endif %}"
                       aria-pressed="{{ (filters.quickFilter ?? '') == key ? 'true' : 'false' }}">
                        {{ filter.label }}
                    </a>
                {% endfor %}
            </div>
        {% endif %}

        {# Filter Panel #}
        <div class="pane {% if not hasFilters %}hidden{% endif %}" id="lens-filters-panel">
            <div class="flex flex-wrap" style="gap: var(--xl);">
                {# Tags Filter #}
                <div class="field">
                    <div class="heading"><label>{{ 'Tags'|t('lens') }}</label></div>
                    <div class="input">
                        <select name="tags[]" id="lens-tag-select" multiple style="min-width: 200px;">
                            {% for tag in allTags %}
                                <option value="{{ tag }}" {% if tag in (filters.tags ?? []) %}selected{% endif %}>
                                    {{ tag }}
                                </option>
                            {% endfor %}
                        </select>
                        <div class="flex" style="gap: var(--s); margin-top: var(--xs);">
                            <label class="light" style="font-size: 12px;">
                                <input type="radio" name="tagOperator" value="or" {% if (filters.tagOperator ?? 'or') == 'or' %}checked{% endif %}>
                                {{ 'Any tag'|t('lens') }}
                            </label>
                            <label class="light" style="font-size: 12px;">
                                <input type="radio" name="tagOperator" value="and" {% if (filters.tagOperator ?? 'or') == 'and' %}checked{% endif %}>
                                {{ 'All tags'|t('lens') }}
                            </label>
                        </div>
                    </div>
                </div>

                {# Status Filter #}
                <div class="field">
                    <div class="heading"><label>{{ 'Status'|t('lens') }}</label></div>
                    <div class="input">
                        <select name="status[]" multiple style="min-width: 160px;">
                            {% for option in statusOptions %}
                                <option value="{{ option.value }}" {% if option.value in (filters.status ?? []) %}selected{% endif %}>
                                    {{ option.label }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                {# Contains People #}
                {{ forms.selectField({
                    label: 'Contains People'|t('lens'),
                    name: 'containsPeople',
                    options: [
                        {value: '', label: 'Any'|t('lens')},
                        {value: '1', label: 'Yes'|t('lens')},
                        {value: '0', label: 'No'|t('lens')},
                    ],
                    value: (filters.containsPeople ?? null) is same as(true) ? '1' : ((filters.containsPeople ?? null) is same as(false) ? '0' : ''),
                }) }}

                {# Face Count - Preset Buttons #}
                <div class="field">
                    <div class="heading"><label>{{ 'Face Count'|t('lens') }}</label></div>
                    <div class="input">
                        <div class="btngroup" data-lens-preset="faceCountPreset">
                            {% set facePresets = [
                                {value: '0', label: '0'},
                                {value: '1', label: '1'},
                                {value: '2-5', label: '2-5'},
                                {value: '6+', label: '6+'},
                            ] %}
                            {% for preset in facePresets %}
                                <button type="button"
                                        class="btn{% if (filters.faceCountPreset ?? '') == preset.value %} active{% endif %}"
                                        data-value="{{ preset.value }}"
                                        aria-pressed="{{ (filters.faceCountPreset ?? '') == preset.value ? 'true' : 'false' }}">
                                    {{ preset.label }}
                                </button>
                            {% endfor %}
                        </div>
                        <input type="hidden" name="faceCountPreset" value="{{ filters.faceCountPreset ?? '' }}">
                    </div>
                </div>

                {# Confidence Range #}
                <div class="field">
                    <div class="heading"><label>{{ 'Confidence'|t('lens') }}</label></div>
                    <div class="input">
                        <div class="flex" style="gap: var(--s); align-items: center;">
                            <input type="number" name="confidenceMin" placeholder="{{ 'Min %'|t('lens') }}" min="0" max="100" step="5" class="text" style="width: 80px;" value="{{ (filters.confidenceMin ?? null) ? ((filters.confidenceMin * 100)|round) : '' }}">
                            <span class="light">-</span>
                            <input type="number" name="confidenceMax" placeholder="{{ 'Max %'|t('lens') }}" min="0" max="100" step="5" class="text" style="width: 80px;" value="{{ (filters.confidenceMax ?? null) ? ((filters.confidenceMax * 100)|round) : '' }}">
                        </div>
                    </div>
                </div>

                {# NSFW Score Range #}
                <div class="field">
                    <div class="heading"><label>{{ 'NSFW Score'|t('lens') }}</label></div>
                    <div class="input">
                        <div class="flex" style="gap: var(--s); align-items: center;">
                            <input type="number" name="nsfwScoreMin" placeholder="{{ 'Min %'|t('lens') }}" min="0" max="100" step="5" class="text" style="width: 80px;" value="{{ (filters.nsfwScoreMin ?? null) ? ((filters.nsfwScoreMin * 100)|round) : '' }}">
                            <span class="light">-</span>
                            <input type="number" name="nsfwScoreMax" placeholder="{{ 'Max %'|t('lens') }}" min="0" max="100" step="5" class="text" style="width: 80px;" value="{{ (filters.nsfwScoreMax ?? null) ? ((filters.nsfwScoreMax * 100)|round) : '' }}">
                        </div>
                    </div>
                </div>

                {# Has Watermark #}
                {{ forms.selectField({
                    label: 'Watermark'|t('lens'),
                    name: 'hasWatermark',
                    options: [
                        {value: '', label: 'Any'|t('lens')},
                        {value: '1', label: 'Has Watermark'|t('lens')},
                        {value: '0', label: 'No Watermark'|t('lens')},
                    ],
                    value: (filters.hasWatermark ?? null) is same as(true) ? '1' : ((filters.hasWatermark ?? null) is same as(false) ? '0' : ''),
                }) }}

                {# Watermark Type #}
                {{ forms.selectField({
                    label: 'Watermark Type'|t('lens'),
                    name: 'watermarkType',
                    options: [
                        {value: '', label: 'Any'|t('lens')},
                        {value: 'stock', label: 'Stock'|t('lens')},
                        {value: 'logo', label: 'Logo'|t('lens')},
                        {value: 'text', label: 'Text'|t('lens')},
                        {value: 'copyright', label: 'Copyright'|t('lens')},
                    ],
                    value: filters.watermarkType ?? '',
                }) }}

                {# Contains Brand Logo #}
                {{ forms.selectField({
                    label: 'Brand Logo'|t('lens'),
                    name: 'containsBrandLogo',
                    options: [
                        {value: '', label: 'Any'|t('lens')},
                        {value: '1', label: 'Has Brand Logo'|t('lens')},
                        {value: '0', label: 'No Brand Logo'|t('lens')},
                    ],
                    value: (filters.containsBrandLogo ?? null) is same as(true) ? '1' : ((filters.containsBrandLogo ?? null) is same as(false) ? '0' : ''),
                }) }}

                {# Quality Preset #}
                <div class="field">
                    <div class="heading"><label>{{ 'Quality'|t('lens') }}</label></div>
                    <div class="input">
                        <div class="btngroup" data-lens-preset="qualityPreset">
                            {% set qualityPresets = [
                                {value: 'high', label: 'High'|t('lens')},
                                {value: 'medium', label: 'Medium'|t('lens')},
                                {value: 'low', label: 'Low'|t('lens')},
                            ] %}
                            {% for preset in qualityPresets %}
                                <button type="button"
                                        class="btn{% if (filters.qualityPreset ?? '') == preset.value %} active{% endif %}"
                                        data-value="{{ preset.value }}"
                                        aria-pressed="{{ (filters.qualityPreset ?? '') == preset.value ? 'true' : 'false' }}">
                                    {{ preset.label }}
                                </button>
                            {% endfor %}
                        </div>
                        <input type="hidden" name="qualityPreset" value="{{ filters.qualityPreset ?? '' }}">
                    </div>
                </div>

                {# Has GPS #}
                {{ forms.selectField({
                    label: 'GPS Data'|t('lens'),
                    name: 'hasGps',
                    options: [
                        {value: '', label: 'Any'|t('lens')},
                        {value: '1', label: 'Has GPS'|t('lens')},
                        {value: '0', label: 'No GPS'|t('lens')},
                    ],
                    value: (filters.hasGps ?? null) is same as(true) ? '1' : ((filters.hasGps ?? null) is same as(false) ? '0' : ''),
                }) }}

                {# Has Focal Point #}
                {{ forms.selectField({
                    label: 'Focal Point'|t('lens'),
                    name: 'hasFocalPoint',
                    options: [
                        {value: '', label: 'Any'|t('lens')},
                        {value: '1', label: 'Has Focal Point'|t('lens')},
                        {value: '0', label: 'No Focal Point'|t('lens')},
                    ],
                    value: (filters.hasFocalPoint ?? null) is same as(true) ? '1' : ((filters.hasFocalPoint ?? null) is same as(false) ? '0' : ''),
                }) }}

                {# Date Analyzed Range #}
                <div class="field" style="min-width: 280px;">
                    <div class="heading"><label>{{ 'Date Analyzed'|t('lens') }}</label></div>
                    <div class="input">
                        <div class="flex" style="gap: var(--s); align-items: center;">
                            <div class="datewrapper">
                                <input type="text"
                                       class="text"
                                       name="processedFrom"
                                       id="lens-processed-from"
                                       placeholder="{{ 'From'|t('lens') }}"
                                       value="{{ (filters.processedFrom ?? null) ? filters.processedFrom|date('Y-m-d') : '' }}"
                                       autocomplete="off">
                            </div>
                            <span class="light">{{ 'to'|t('lens') }}</span>
                            <div class="datewrapper">
                                <input type="text"
                                       class="text"
                                       name="processedTo"
                                       id="lens-processed-to"
                                       placeholder="{{ 'To'|t('lens') }}"
                                       value="{{ (filters.processedTo ?? null) ? filters.processedTo|date('Y-m-d') : '' }}"
                                       autocomplete="off">
                            </div>
                        </div>
                    </div>
                </div>

                {# Duplicates Filter #}
                {{ forms.selectField({
                    label: 'Duplicates'|t('lens'),
                    name: 'hasDuplicates',
                    options: [
                        {value: '', label: 'Any'|t('lens')},
                        {value: '1', label: 'Has Duplicates'|t('lens')},
                        {value: '0', label: 'No Duplicates'|t('lens')},
                    ],
                    value: (filters.hasDuplicates ?? '') == '1' ? '1' : ((filters.hasDuplicates ?? '') == '0' ? '0' : ''),
                }) }}

                {# Color Family Filter #}
                <div class="field" style="min-width: 280px;">
                    <div class="heading"><label>{{ 'Color'|t('lens') }}</label></div>
                    <div class="input">
                        <div class="btngroup" data-lens-preset="colorFamily" style="flex-wrap: wrap; gap: 4px;">
                            {% for color in colorFamilies %}
                                <button type="button"
                                        class="btn{% if (filters.colorFamily ?? '') == color.id %} active{% endif %}"
                                        data-value="{{ color.id }}"
                                        style="background-color: {{ color.hex }}; min-width: 28px; min-height: 28px; padding: 4px;{% if color.id == 'white' %} border: 1px solid var(--hairline-color);{% endif %}"
                                        title="{{ color.name|t('lens') }}"
                                        aria-pressed="{{ (filters.colorFamily ?? '') == color.id ? 'true' : 'false' }}">
                                </button>
                            {% endfor %}
                        </div>
                        <input type="hidden" name="colorFamily" value="{{ filters.colorFamily ?? '' }}">
                        {% if filters.colorFamily ?? false %}
                            <div style="margin-top: var(--s);">
                                <label class="light" style="font-size: 11px;">
                                    {{ 'Tolerance'|t('lens') }}: <span id="lens-tolerance-value">{{ filters.colorTolerance ?? 30 }}</span>%
                                </label>
                                <input type="range"
                                       name="colorTolerance"
                                       id="lens-color-tolerance"
                                       min="0"
                                       max="100"
                                       step="5"
                                       value="{{ filters.colorTolerance ?? 30 }}"
                                       style="width: 100%;">
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <hr>
            <div class="flex" style="gap: var(--s);">
                <button type="submit" class="btn submit">{{ 'Apply Filters'|t('lens') }}</button>
                <a href="{{ cpUrl('lens/search') }}" class="btn">{{ 'Clear All'|t('lens') }}</a>
            </div>
        </div>
    </form>

    {# Results Section #}
    <div class="lens-search-results">
        {% include 'lens/_search/_results' %}
    </div>
</div>
{% endblock %}
