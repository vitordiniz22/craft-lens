{# Search Results #}
{% if total > 0 %}
    <div class="lens-results-bar">
        <p class="light lens-results-count" aria-live="polite" aria-atomic="true">
            {{ 'Showing {from}-{to} of {total} assets'|t('lens', {
                from: offset + 1,
                to: min(offset + limit, total),
                total: total
            }) }}
        </p>
        <a href="{{ cpUrl('lens/search/export', filters ?? {}) }}" class="btn small" data-lens-action="export-csv">
            {{ iconSvg('download')|attr({width: 14, height: 14, class: 'lens-btn-icon'}) }}
            {{ 'Export CSV'|t('lens') }}
        </a>
    </div>

    {% set isDuplicateView = (clusterMap is defined and clusterMap|length) %}

    {% if isDuplicateView %}
        {# Group assets by duplicate cluster for visual grouping #}
        {% set clusters = {} %}
        {% for asset in assets %}
            {% set key = 'c' ~ (clusterMap[asset.id] ?? 0) %}
            {% set existing = clusters[key] ?? [] %}
            {% set clusters = clusters|merge({ (key): existing|merge([asset]) }) %}
        {% endfor %}

        {% for groupKey, clusterAssets in clusters %}
            <div class="lens-duplicate-cluster">
                <div class="lens-duplicate-cluster__header">
                    {{ iconSvg('copy')|attr({width: 14, height: 14, class: 'lens-duplicate-cluster__icon'}) }}
                    <span class="lens-duplicate-cluster__label">
                        {{ '{count} similar assets'|t('lens', {count: clusterAssets|length}) }}
                    </span>
                </div>
                <div class="lens-results-grid">
                    {% for asset in clusterAssets %}
                        {% set analysis = analysisMap[asset.id] ?? null %}

                        {% include 'lens/_components/asset-card' with {
                            asset: asset,
                            analysis: analysis,
                            tags: tagsMap[analysis.id ?? 0] ?? [],
                            colors: colorsMap[analysis.id ?? 0] ?? [],
                            dupCount: dupCountsMap[asset.id] ?? 0,
                            linkUrl: asset.cpEditUrl,
                            showTags: true,
                            showColors: true,
                        } only %}
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
    {% else %}
        <div class="lens-results-grid">
            {% for asset in assets %}
                {% set analysis = analysisMap[asset.id] ?? null %}

                {% include 'lens/_components/asset-card' with {
                    asset: asset,
                    analysis: analysis,
                    tags: tagsMap[analysis.id ?? 0] ?? [],
                    colors: colorsMap[analysis.id ?? 0] ?? [],
                    dupCount: (similarityMap is defined and similarityMap|length) ? 0 : (dupCountsMap[asset.id] ?? 0),
                    similarity: (similarityMap is defined) ? (similarityMap[asset.id] ?? null) : null,
                    linkUrl: asset.cpEditUrl,
                    showTags: true,
                    showColors: true,
                } only %}
            {% endfor %}
        </div>
    {% endif %}

    {% include 'lens/_components/pagination' with {
        total: total,
        limit: limit,
        offset: offset,
        baseUrl: 'lens/search',
        urlParams: filters,
    } only %}

{% elseif hasFilters is defined and hasFilters %}
    {% if similarToAsset ?? null %}
        {% include 'lens/_components/empty-state' with {
            heading: 'No Similar Assets Found'|t('lens'),
            description: 'No duplicate or similar assets were detected for this image.'|t('lens'),
            cta: {label: 'Back to Asset'|t('lens'), url: similarToAsset.cpEditUrl, style: ''},
            secondaryCta: {label: 'Browse All Assets'|t('lens'), url: 'lens/search'},
        } only %}
    {% else %}
        {% include 'lens/_components/empty-state' with {
            heading: 'No Results Found'|t('lens'),
            description: 'No assets found matching your filters.'|t('lens'),
            cta: {label: 'Clear Filters'|t('lens'), url: 'lens/search', style: ''},
        } only %}
    {% endif %}

{% else %}
    {% include 'lens/_components/empty-state' with {
        heading: 'Search Your Assets'|t('lens'),
        description: 'Search by alt text, title, extracted text, or tags. Use filters to narrow down results.'|t('lens'),
    } only %}
{% endif %}
