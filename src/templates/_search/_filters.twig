{# Filter Panel — included within the search form context in index.twig #}
{% import '_includes/forms.twig' as forms %}

{% macro presetButtonGroup(label, presetName, presets, currentValue) %}
    <div class="field">
        <div class="heading"><label>{{ label }}</label></div>
        <div class="input">
            <div class="btngroup" data-lens-preset="{{ presetName }}">
                {% for preset in presets %}
                    <button type="button"
                            class="btn{% if currentValue == preset.value %} active{% endif %}"
                            data-lens-value="{{ preset.value }}"
                            aria-pressed="{{ currentValue == preset.value ? 'true' : 'false' }}">
                        {{ preset.label }}
                    </button>
                {% endfor %}
            </div>
            <input type="hidden" name="{{ presetName }}" value="{{ currentValue }}">
        </div>
    </div>
{% endmacro %}

{% macro checkboxGroup(label, inputName, options, activeValues) %}
    <div class="field">
        <div class="heading"><label>{{ label }}</label></div>
        <div class="input">
            {% for option in options %}
                <div>
                    <label>
                        <input type="checkbox" name="{{ inputName }}" value="{{ option.value }}"
                               {% if option.value in activeValues %}checked{% endif %}>
                        {{ option.label }}
                    </label>
                </div>
            {% endfor %}
        </div>
    </div>
{% endmacro %}

<div class="pane{% if not showFilterPanel %} hidden{% endif %}" data-lens-target="filters-panel">
    <div class="lens-filter-grid">

        {# — Row 1: Content Detection — #}

        {# Contains People #}
        {{ forms.selectField({
            label: 'Contains People'|t('lens'),
            name: 'containsPeople',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Yes'|t('lens')},
                {value: '0', label: 'No'|t('lens')},
            ],
            value: (filters.containsPeople ?? null) is same as(true) ? '1' : ((filters.containsPeople ?? null) is same as(false) ? '0' : ''),
        }) }}

        {# Face Count - Preset Buttons #}
        {{ _self.presetButtonGroup('Face Count'|t('lens'), 'faceCountPreset', [
            {value: '0', label: '0'},
            {value: '1', label: '1'},
            {value: '2-5', label: '2-5'},
            {value: '6+', label: '6+'},
        ], filters.faceCountPreset ?? '') }}

        {# Quality Preset #}
        {{ _self.presetButtonGroup('Quality'|t('lens'), 'qualityPreset', [
            {value: 'high', label: 'High'|t('lens')},
            {value: 'medium', label: 'Medium'|t('lens')},
            {value: 'low', label: 'Low'|t('lens')},
        ], filters.qualityPreset ?? '') }}

        {# Quality Issues #}
        {{ _self.checkboxGroup('Quality Issues'|t('lens'), 'qualityIssues[]', [
            {value: 'blurry', label: 'Blurry'|t('lens')},
            {value: 'tooDark', label: 'Too Dark'|t('lens')},
            {value: 'tooBright', label: 'Too Bright'|t('lens')},
            {value: 'lowContrast', label: 'Low Contrast'|t('lens')},
            {value: 'lowOverall', label: 'Low Overall Quality'|t('lens')},
        ], filters.qualityIssues ?? []) }}

        {# Too Large #}
        {{ forms.selectField({
            label: 'File Too Large'|t('lens'),
            name: 'isTooLarge',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Yes'|t('lens')},
            ],
            value: (filters.isTooLarge ?? null) is same as(true) ? '1' : '',
        }) }}

        {# Blurry #}
        {{ forms.selectField({
            label: 'Blurry'|t('lens'),
            name: 'isBlurry',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Yes'|t('lens')},
            ],
            value: (filters.isBlurry ?? null) is same as(true) ? '1' : '',
        }) }}

        {# Too Dark #}
        {{ forms.selectField({
            label: 'Too Dark'|t('lens'),
            name: 'isTooDark',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Yes'|t('lens')},
            ],
            value: (filters.isTooDark ?? null) is same as(true) ? '1' : '',
        }) }}

        {# Has Text in Image #}
        {{ forms.selectField({
            label: 'Text in Image'|t('lens'),
            name: 'hasTextInImage',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Has Text'|t('lens')},
                {value: '0', label: 'No Text'|t('lens')},
            ],
            value: (filters.hasTextInImage ?? null) is same as(true) ? '1' : ((filters.hasTextInImage ?? null) is same as(false) ? '0' : ''),
        }) }}

        {# — Row 2: Image Marks — #}

        {# Has Watermark #}
        {{ forms.selectField({
            label: 'Watermark'|t('lens'),
            name: 'hasWatermark',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Has Watermark'|t('lens')},
                {value: '0', label: 'No Watermark'|t('lens')},
            ],
            value: (filters.hasWatermark ?? null) is same as(true) ? '1' : ((filters.hasWatermark ?? null) is same as(false) ? '0' : ''),
        }) }}

        {# Contains Brand Logo #}
        {{ forms.selectField({
            label: 'Brand Logo'|t('lens'),
            name: 'containsBrandLogo',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Has Brand Logo'|t('lens')},
                {value: '0', label: 'No Brand Logo'|t('lens')},
            ],
            value: (filters.containsBrandLogo ?? null) is same as(true) ? '1' : ((filters.containsBrandLogo ?? null) is same as(false) ? '0' : ''),
        }) }}

        {# — Row 3: Color — #}

        {# Color Filter #}
        <div class="field">
            <div class="heading"><label>{{ 'Color'|t('lens') }}</label></div>
            <div class="input">
                {{ forms.color({
                    name: 'color',
                    value: filters.color ?? '',
                    small: true,
                }) }}
                {% set toleranceValue = filters.colorTolerance ?? 30 %}
                {% set tolerancePreset = toleranceValue <= 15 ? '10' : (toleranceValue <= 40 ? '30' : (toleranceValue <= 65 ? '55' : '80')) %}
                <div class="lens-filter-tolerance{% if not (filters.color ?? false) %} hidden{% endif %}" data-lens-target="color-tolerance-wrap">
                    <label class="light">{{ 'Color match'|t('lens') }}</label>
                    <div class="btngroup" data-lens-preset="colorTolerance">
                        {% for preset in [{value: '10', label: 'Exact match'|t('lens')}, {value: '30', label: 'Close shades'|t('lens')}, {value: '55', label: 'Broad range'|t('lens')}, {value: '80', label: 'Any resemblance'|t('lens')}] %}
                            <button type="button"
                                    class="btn small{% if tolerancePreset == preset.value %} active{% endif %}"
                                    data-lens-value="{{ preset.value }}"
                                    aria-pressed="{{ tolerancePreset == preset.value ? 'true' : 'false' }}">
                                {{ preset.label }}
                            </button>
                        {% endfor %}
                    </div>
                    <input type="hidden" name="colorTolerance" value="{{ tolerancePreset }}">
                </div>
            </div>
        </div>

        {# — Row 4: Metadata — #}

        {# Status Filter #}
        {{ forms.selectizeField({
            label: 'Status'|t('lens'),
            name: 'status',
            options: statusOptions,
            values: filters.status ?? [],
            multi: true,
            selectizeOptions: {
                placeholder: 'Any'|t('lens'),
            },
        }) }}

        {# Date Analyzed Range #}
        <div class="field">
            <div class="heading"><label>{{ 'Date Analyzed'|t('lens') }}</label></div>
            <div class="input">
                <div class="lens-filter-display">
                    <div class="datewrapper">
                        <input type="text"
                               class="text"
                               name="processedFrom"
                               data-lens-control="date-from"
                               placeholder="{{ 'From'|t('lens') }}"
                               value="{{ (filters.processedFrom ?? null) ? filters.processedFrom|date('Y-m-d') : '' }}"
                               autocomplete="off">
                    </div>
                    <span class="light">{{ 'to'|t('lens') }}</span>
                    <div class="datewrapper">
                        <input type="text"
                               class="text"
                               name="processedTo"
                               data-lens-control="date-to"
                               placeholder="{{ 'To'|t('lens') }}"
                               value="{{ (filters.processedTo ?? null) ? filters.processedTo|date('Y-m-d') : '' }}"
                               autocomplete="off">
                    </div>
                </div>
            </div>
        </div>

        {# Duplicates Filter #}
        {{ forms.selectField({
            label: 'Duplicates'|t('lens'),
            name: 'hasDuplicates',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Has Duplicates'|t('lens')},
                {value: '0', label: 'No Duplicates'|t('lens')},
            ],
            value: (filters.hasDuplicates ?? '') == '1' ? '1' : ((filters.hasDuplicates ?? '') == '0' ? '0' : ''),
        }) }}
    </div>

    {# Actions #}
    <div class="lens-filter-actions">
        <button type="submit" class="btn submit">{{ 'Apply Filters'|t('lens') }}</button>
        {% if hasActiveFilters %}
            <a href="{{ cpUrl('lens/search') }}" class="btn">{{ 'Clear All'|t('lens') }}</a>
        {% endif %}
    </div>
</div>
