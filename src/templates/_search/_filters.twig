{# Filter Panel — included within the search form context in index.twig #}
{% import '_includes/forms.twig' as forms %}

<div class="pane lens-search-filters{% if not showFilterPanel %} hidden{% endif %}" data-lens-target="filters-panel">
    <div class="lens-filter-grid">

        {# — Row 1: Content Detection — #}

        {# Contains People #}
        {{ forms.selectField({
            label: 'Contains People'|t('lens'),
            name: 'containsPeople',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Yes'|t('lens')},
                {value: '0', label: 'No'|t('lens')},
            ],
            value: (filters.containsPeople ?? null) is same as(true) ? '1' : ((filters.containsPeople ?? null) is same as(false) ? '0' : ''),
        }) }}

        {# Face Count - Preset Buttons #}
        <div class="field">
            <div class="heading"><label>{{ 'Face Count'|t('lens') }}</label></div>
            <div class="input">
                <div class="btngroup" data-lens-preset="faceCountPreset">
                    {% set facePresets = [
                        {value: '0', label: '0'},
                        {value: '1', label: '1'},
                        {value: '2-5', label: '2-5'},
                        {value: '6+', label: '6+'},
                    ] %}
                    {% for preset in facePresets %}
                        <button type="button"
                                class="btn{% if (filters.faceCountPreset ?? '') == preset.value %} active{% endif %}"
                                data-lens-value="{{ preset.value }}"
                                aria-pressed="{{ (filters.faceCountPreset ?? '') == preset.value ? 'true' : 'false' }}">
                            {{ preset.label }}
                        </button>
                    {% endfor %}
                </div>
                <input type="hidden" name="faceCountPreset" value="{{ filters.faceCountPreset ?? '' }}">
            </div>
        </div>

        {# Quality Preset #}
        <div class="field">
            <div class="heading"><label>{{ 'Quality'|t('lens') }}</label></div>
            <div class="input">
                <div class="btngroup" data-lens-preset="qualityPreset">
                    {% set qualityPresets = [
                        {value: 'high', label: 'High'|t('lens')},
                        {value: 'medium', label: 'Medium'|t('lens')},
                        {value: 'low', label: 'Low'|t('lens')},
                    ] %}
                    {% for preset in qualityPresets %}
                        <button type="button"
                                class="btn{% if (filters.qualityPreset ?? '') == preset.value %} active{% endif %}"
                                data-lens-value="{{ preset.value }}"
                                aria-pressed="{{ (filters.qualityPreset ?? '') == preset.value ? 'true' : 'false' }}">
                            {{ preset.label }}
                        </button>
                    {% endfor %}
                </div>
                <input type="hidden" name="qualityPreset" value="{{ filters.qualityPreset ?? '' }}">
            </div>
        </div>

        {# Quality Issues — checkbox group #}
        <div class="field">
            <div class="heading"><label>{{ 'Quality Issues'|t('lens') }}</label></div>
            <div class="input">
                {% set qualityIssueOptions = [
                    {value: 'blurry', label: 'Blurry'|t('lens')},
                    {value: 'tooDark', label: 'Too Dark'|t('lens')},
                    {value: 'overexposed', label: 'Overexposed'|t('lens')},
                    {value: 'noisy', label: 'Noisy'|t('lens')},
                    {value: 'lowOverall', label: 'Low Overall Quality'|t('lens')},
                ] %}
                {% set activeQualityIssues = filters.qualityIssues ?? [] %}
                {% for option in qualityIssueOptions %}
                    <div>
                        <label>
                            <input type="checkbox" name="qualityIssues[]" value="{{ option.value }}"
                                   {% if option.value in activeQualityIssues %}checked{% endif %}>
                            {{ option.label }}
                        </label>
                    </div>
                {% endfor %}
            </div>
        </div>

        {# Web Readiness Issues — checkbox group #}
        <div class="field">
            <div class="heading"><label>{{ 'Web Readiness'|t('lens') }}</label></div>
            <div class="input">
                {% set webReadinessOptions = [
                    {value: 'fileTooLarge', label: 'File Too Large (>1MB)'|t('lens')},
                    {value: 'resolutionTooSmall', label: 'Resolution Too Small'|t('lens')},
                    {value: 'unsupportedFormat', label: 'Unsupported Format'|t('lens')},
                ] %}
                {% set activeWebIssues = filters.webReadinessIssues ?? [] %}
                {% for option in webReadinessOptions %}
                    <div>
                        <label>
                            <input type="checkbox" name="webReadinessIssues[]" value="{{ option.value }}"
                                   {% if option.value in activeWebIssues %}checked{% endif %}>
                            {{ option.label }}
                        </label>
                    </div>
                {% endfor %}
            </div>
        </div>

        {# Has Text in Image #}
        {{ forms.selectField({
            label: 'Text in Image'|t('lens'),
            name: 'hasTextInImage',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Has Text'|t('lens')},
                {value: '0', label: 'No Text'|t('lens')},
            ],
            value: (filters.hasTextInImage ?? null) is same as(true) ? '1' : ((filters.hasTextInImage ?? null) is same as(false) ? '0' : ''),
        }) }}

        {# — Row 2: Image Marks — #}

        {# Has Watermark #}
        {{ forms.selectField({
            label: 'Watermark'|t('lens'),
            name: 'hasWatermark',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Has Watermark'|t('lens')},
                {value: '0', label: 'No Watermark'|t('lens')},
            ],
            value: (filters.hasWatermark ?? null) is same as(true) ? '1' : ((filters.hasWatermark ?? null) is same as(false) ? '0' : ''),
        }) }}

        {# Contains Brand Logo #}
        {{ forms.selectField({
            label: 'Brand Logo'|t('lens'),
            name: 'containsBrandLogo',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Has Brand Logo'|t('lens')},
                {value: '0', label: 'No Brand Logo'|t('lens')},
            ],
            value: (filters.containsBrandLogo ?? null) is same as(true) ? '1' : ((filters.containsBrandLogo ?? null) is same as(false) ? '0' : ''),
        }) }}

        {# — Row 3: Color — #}

        {# Color Filter #}
        <div class="field">
            <div class="heading"><label>{{ 'Color'|t('lens') }}</label></div>
            <div class="input">
                {{ forms.color({
                    name: 'color',
                    value: filters.color ?? '',
                    small: true,
                }) }}
                {% set toleranceValue = filters.colorTolerance ?? 30 %}
                {% set toleranceLabel = toleranceValue <= 20 ? 'Exact' : (toleranceValue <= 50 ? 'Similar' : (toleranceValue <= 75 ? 'Broad' : 'Very broad')) %}
                <div class="lens-filter-tolerance{% if not (filters.color ?? false) %} hidden{% endif %}" data-lens-target="color-tolerance-wrap">
                    <label class="light">
                        {{ 'Tolerance'|t('lens') }}: <span data-lens-target="tolerance-value">{{ toleranceValue }}</span>%
                        <span class="light" data-lens-target="tolerance-label">({{ toleranceLabel|t('lens') }})</span>
                    </label>
                    <input type="range"
                           name="colorTolerance"
                           data-lens-control="color-tolerance"
                           min="0" max="100" step="5"
                           value="{{ toleranceValue }}"
                           class="lens-filter-range">
                </div>
            </div>
        </div>

        {# — Row 4: Metadata — #}

        {# Status Filter #}
        {{ forms.selectizeField({
            label: 'Status'|t('lens'),
            name: 'status',
            options: statusOptions,
            values: filters.status ?? [],
            multi: true,
            selectizeOptions: {
                placeholder: 'Any'|t('lens'),
            },
        }) }}

        {# Date Analyzed Range #}
        <div class="field">
            <div class="heading"><label>{{ 'Date Analyzed'|t('lens') }}</label></div>
            <div class="input">
                <div class="lens-filter-display">
                    <div class="datewrapper">
                        <input type="text"
                               class="text"
                               name="processedFrom"
                               data-lens-control="date-from"
                               placeholder="{{ 'From'|t('lens') }}"
                               value="{{ (filters.processedFrom ?? null) ? filters.processedFrom|date('Y-m-d') : '' }}"
                               autocomplete="off">
                    </div>
                    <span class="light">{{ 'to'|t('lens') }}</span>
                    <div class="datewrapper">
                        <input type="text"
                               class="text"
                               name="processedTo"
                               data-lens-control="date-to"
                               placeholder="{{ 'To'|t('lens') }}"
                               value="{{ (filters.processedTo ?? null) ? filters.processedTo|date('Y-m-d') : '' }}"
                               autocomplete="off">
                    </div>
                </div>
            </div>
        </div>

        {# Duplicates Filter #}
        {{ forms.selectField({
            label: 'Duplicates'|t('lens'),
            name: 'hasDuplicates',
            options: [
                {value: '', label: 'Any'|t('lens')},
                {value: '1', label: 'Has Duplicates'|t('lens')},
                {value: '0', label: 'No Duplicates'|t('lens')},
            ],
            value: (filters.hasDuplicates ?? '') == '1' ? '1' : ((filters.hasDuplicates ?? '') == '0' ? '0' : ''),
        }) }}
    </div>

    {# Actions #}
    <div class="lens-filter-actions">
        <button type="submit" class="btn submit">{{ 'Apply Filters'|t('lens') }}</button>
        {% if hasActiveFilters %}
            <a href="{{ cpUrl('lens/search') }}" class="btn">{{ 'Clear All'|t('lens') }}</a>
        {% endif %}
    </div>
</div>
